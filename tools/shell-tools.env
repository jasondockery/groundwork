# Central, machine-readable pin for Groundwork's shell-quality tools. One source
# of truth so CI (Linux + macOS, Intel + Arm) and local dev all run the SAME
# analyzers at the SAME versions. Sourced by scripts/ensure-shell-tools (which
# downloads/caches the pinned binaries) and scripts/update-shell-tool-pins (which
# rewrites this file). scripts/lint-shell is the gate that uses them.
#
# ShellCheck = semantic lint (quoting, word splitting, command misuse). shfmt =
# parsing + formatting consistency. Neither replaces the other, and neither
# replaces the behavioral fixtures in scripts/validate-groundwork.
#
# To bump a version, run (it updates the version AND every arch checksum from the
# actual release assets, so there is never a half-updated, guaranteed-red state):
#
#   scripts/update-shell-tool-pins shellcheck <version>
#   scripts/update-shell-tool-pins shfmt <version>
#
# Checksums are over the exact release assets ensure-shell-tools downloads:
# ShellCheck  shellcheck-v<ver>.<os>.<arch>.tar.xz   (arch: x86_64 | aarch64)
# shfmt       shfmt_v<ver>_<os>_<arch>               (arch: amd64  | arm64)

SHELLCHECK_VERSION=0.11.0
SHELLCHECK_SHA256_LINUX_X86_64=8c3be12b05d5c177a04c29e3c78ce89ac86f1595681cab149b65b97c4e227198
SHELLCHECK_SHA256_LINUX_AARCH64=12b331c1d2db6b9eb13cfca64306b1b157a86eb69db83023e261eaa7e7c14588
SHELLCHECK_SHA256_DARWIN_X86_64=3c89db4edcab7cf1c27bff178882e0f6f27f7afdf54e859fa041fca10febe4c6
SHELLCHECK_SHA256_DARWIN_AARCH64=56affdd8de5527894dca6dc3d7e0a99a873b0f004d7aabc30ae407d3f48b0a79

SHFMT_VERSION=3.13.1
SHFMT_SHA256_LINUX_AMD64=fb096c5d1ac6beabbdbaa2874d025badb03ee07929f0c9ff67563ce8c75398b1
SHFMT_SHA256_LINUX_ARM64=32d92acaa5cd8abb29fc49dac123dc412442d5713967819d8af2c29f1b3857c7
SHFMT_SHA256_DARWIN_AMD64=6feedafc72915794163114f512348e2437d080d0047ef8b8fa2ec63b575f12af
SHFMT_SHA256_DARWIN_ARM64=9680526be4a66ea1ffe988ed08af58e1400fe1e4f4aef5bd88b20bb9b3da33f8

# Canonical shfmt formatting for this repo, chosen to MINIMIZE churn against the
# existing hand-formatting (measured): 2-space indent, indent switch/case (-ci),
# and binary operators at the START of a continued line (-bn), which preserves
# Groundwork's `cmd \` + `|| fail` idiom. Deliberately NOT -sr: the tree already
# uses no-space redirects (shfmt's default), so -sr would add ~4000 lines of
# churn rather than remove it.
SHFMT_FLAGS="-i 2 -ci -bn"
