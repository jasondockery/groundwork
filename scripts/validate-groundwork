grep -qF 'animateExplosion: false' home/dot_config/lazygit/config.yml
grep -qF 'Open repository in Neovim' home/dot_config/lazygit/config.yml
# lazygit only reads ~/.config on macOS when XDG_CONFIG_HOME says so; the
# export lives in the login shell so tmux servers and tool runners inherit it.
grep -qF "export XDG_CONFIG_HOME=\"\${XDG_CONFIG_HOME:-\$HOME/.config}\"" home/dot_zprofile.tmpl
# tmux: the picker and dirty-repo bindings exist, call the helper by absolute
# path, and the current-repo lazygit popup (prefix g) stays.
grep -qF 'bind -N "repo picker" R display-popup' home/dot_config/tmux/tmux.conf.tmpl
