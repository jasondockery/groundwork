grep -qF 'bind -N "lazygit for every dirty repo" G run-shell -b' home/dot_config/tmux/tmux.conf.tmpl
grep -qF "\"\$HOME/.local/bin/groundwork-repos\" changed" home/dot_config/tmux/tmux.conf.tmpl
grep -qF 'bind g display-popup' home/dot_config/tmux/tmux.conf.tmpl
# Catalog rows stay discoverable.
grep -qF $'project\tgroundwork-repos\tcommand\t' home/dot_local/share/groundwork/commands.tsv
grep -qF $'tmux\tCtrl+a then Shift+R\tkey\t' home/dot_local/share/groundwork/commands.tsv
grep -qF $'tmux\tCtrl+a then Shift+G\tkey\t' home/dot_local/share/groundwork/commands.tsv
# The skill that guards this surface keeps its central rule verbatim.
grep -qF 'Repository behavior is discovered dynamically. Never hardcode a user'"'"'s current repository list into tmux, shell, Lazygit, or documentation.' skills/developer-workspace-navigation/SKILL.md

# Behavior suite. Fixtures are real throwaway git repos (git is already a
# dependency of this script and discovery is read-only data inspection);
# tmux, fzf, and lazygit are PATH stubs that record argv one word per line,
# so quoting mistakes (a path with spaces splitting into two words) are
# provable, not assumed. The tool PATH is hermetic: only the stubs plus
# symlinks to the exact real binaries the helper is allowed to need.
repos_dir="$out_dir/repos"
repos_root="$repos_dir/root"
repos_root2="$repos_dir/root2"
repos_xdg="$repos_dir/xdg"
repos_cache="$repos_dir/cache"
repos_stub="$repos_dir/stub"
repos_stub_nofzf="$repos_dir/stub-nofzf"
repos_tools="$repos_dir/tools"
repos_tmux_log="$repos_dir/tmux-log"
repos_fzf_in="$repos_dir/fzf-in"
repos_fzf_args="$repos_dir/fzf-args"
mkdir -p "$repos_root" "$repos_root2" "$repos_xdg/groundwork" "$repos_cache" \
  "$repos_stub" "$repos_stub_nofzf" "$repos_tools"
repos_dir="$(cd "$repos_dir" && pwd -P)"
repos_root="$(cd "$repos_root" && pwd -P)"
repos_root2="$(cd "$repos_root2" && pwd -P)"

for repos_tool in git find sort awk grep head uniq stat date mktemp mv mkdir cat rm; do
  repos_tool_path="$(command -v "$repos_tool")" \
    || fail "groundwork-repos suite: required tool missing: $repos_tool"
  ln -s "$repos_tool_path" "$repos_tools/$repos_tool"
done
unset repos_tool repos_tool_path

# /bin/sh shebangs: the stubs run under the hermetic PATH, where an
# `env bash` lookup would find nothing.
cat >"$repos_stub/tmux" <<'SH'
#!/bin/sh
printf '%s\n' "$@" >>"${REPOS_TMUX_LOG:?}"
case "${1:-}" in
  has-session) exit 1 ;;
esac
exit 0
SH
cat >"$repos_stub/lazygit" <<'SH'
#!/bin/sh
exit 0
SH
cat >"$repos_stub/fzf" <<'SH'
#!/bin/sh
printf '%s\n' "$@" >"${REPOS_FZF_ARGS:?}"
cat >"${REPOS_FZF_INPUT:?}"
grep -F -- "${REPOS_FZF_CHOOSE:?}" "$REPOS_FZF_INPUT" | head -n 1
SH
chmod +x "$repos_stub/tmux" "$repos_stub/lazygit" "$repos_stub/fzf"
cp "$repos_stub/tmux" "$repos_stub_nofzf/tmux"
cp "$repos_stub/lazygit" "$repos_stub_nofzf/lazygit"
chmod +x "$repos_stub_nofzf/tmux" "$repos_stub_nofzf/lazygit"

repos_git() {
  GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_SYSTEM=/dev/null \
    git -c init.defaultBranch=main -c user.name=groundwork \
    -c user.email=groundwork@example.invalid "$@"
}
repos_mk() {
  mkdir -p "$1"
  repos_git -C "$1" init -q
  repos_git -C "$1" commit -q --allow-empty -m init
}
repos_mk "$repos_root/alpha"
repos_mk "$repos_root/space repo"
repos_mk "$repos_root/one/app"
repos_mk "$repos_root/two/app"
repos_mk "$repos_root/outer"
# The nested repo must exercise nesting, not dirtiness: without this ignore,
# inner/ would be untracked content that makes outer permanently dirty.
printf 'inner/\n' >"$repos_root/outer/.gitignore"
repos_git -C "$repos_root/outer" add .gitignore
repos_git -C "$repos_root/outer" commit -q -m ignore-inner
repos_mk "$repos_root/outer/inner"
repos_mk "$repos_root/node_modules/hidden"
repos_mk "$repos_root/d1/d2/d3/d4/toodeep"
repos_git -C "$repos_root/alpha" worktree add -q "$repos_root/alpha-wt"
mkdir -p "$repos_root/loop"
ln -s .. "$repos_root/loop/back"
echo change >"$repos_root/space repo/untracked.txt"
# Cross-root collisions for shortest-unique-suffix window naming: identical
# basename AND parent across two roots (client/app under both), plus a
# triple-depth collision (aa/bb/deep under both) that only the root
# directory itself disambiguates.
repos_mk "$repos_root/client/app"
repos_mk "$repos_root2/client/app"
repos_mk "$repos_root/aa/bb/deep"
repos_mk "$repos_root2/aa/bb/deep"
# The fsmonitor tripwire: a repo whose own config points core.fsmonitor at a
# script that writes a sentinel. Discovery and status must never trigger it.
repos_mk "$repos_root/fsmon"
repos_fsmon_sentinel="$repos_dir/fsmon-sentinel"
cat >"$repos_dir/fsmon-hook" <<SH
#!/bin/sh
echo ran >>"$repos_fsmon_sentinel"
echo "/"
SH
chmod +x "$repos_dir/fsmon-hook"
repos_git -C "$repos_root/fsmon" config core.fsmonitor "$repos_dir/fsmon-hook"

cat >"$repos_xdg/groundwork/repos.conf" <<EOF
root = $repos_root
root = $repos_root2
max_depth = 4
include_worktrees = true
cache_ttl_seconds = 0
exclude = node_modules
exclude = .cache
exclude = dist
exclude = vendor
EOF

# repos_run <TMUX value> <PATH> <args...>
repos_run() {
  local tmux_env="$1" path_env="$2"
  shift 2
  TMUX="$tmux_env" PATH="$path_env" \
    XDG_CONFIG_HOME="$repos_xdg" XDG_CACHE_HOME="$repos_cache" \
    GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_SYSTEM=/dev/null \
    REPOS_TMUX_LOG="$repos_tmux_log" REPOS_FZF_INPUT="$repos_fzf_in" \
    REPOS_FZF_ARGS="$repos_fzf_args" \
    REPOS_FZF_CHOOSE="${REPOS_FZF_CHOOSE:-}" NO_COLOR=1 \
    /bin/bash home/dot_local/bin/executable_groundwork-repos "$@"
}
repos_path="$repos_stub:$repos_tools"

# Discovery: repos with .git dirs AND .git files (worktrees), spaces,
# duplicate basenames, and nested repos all appear; excluded dirs and
# repos beyond max_depth do not; the symlink loop terminates and the
# canonical dedupe leaves every repo listed exactly once.
repos_run '' "$repos_path" list >"$repos_dir/list-out"
grep -qF "$repos_root/alpha"$'\t' "$repos_dir/list-out"
grep -qF "$repos_root/space repo"$'\t' "$repos_dir/list-out"
grep -qF "$repos_root/one/app"$'\t' "$repos_dir/list-out"
grep -qF "$repos_root/two/app"$'\t' "$repos_dir/list-out"
grep -qF "$repos_root/client/app"$'\t' "$repos_dir/list-out"
grep -qF "$repos_root2/client/app"$'\t' "$repos_dir/list-out"
grep -qF "$repos_root/outer"$'\t' "$repos_dir/list-out"
grep -qF "$repos_root/outer/inner"$'\t' "$repos_dir/list-out"
grep -qF "$repos_root/alpha-wt"$'\t'"wt" "$repos_dir/list-out"
assert_no_matches "excluded directory leaked into discovery" grep -n 'node_modules' "$repos_dir/list-out"
assert_no_matches "repo beyond max_depth leaked into discovery" grep -n 'toodeep' "$repos_dir/list-out"
assert_no_matches "symlink-loop paths leaked past canonical dedupe" grep -n '/loop/back/' "$repos_dir/list-out"
if [[ -n "$(awk -F'\t' '{print $1}' "$repos_dir/list-out" | sort | uniq -d)" ]]; then
  fail "groundwork-repos listed a repository more than once"
fi

# A fresh clone appears with zero config changes.
repos_mk "$repos_root/charlie"
repos_run '' "$repos_path" list | grep -qF "$repos_root/charlie"

# The include_worktrees toggle is honored via the unmanaged local overlay.
echo 'include_worktrees = false' >"$repos_xdg/groundwork/repos.local.conf"
repos_run '' "$repos_path" list >"$repos_dir/list-nowt"
assert_no_matches "worktree listed despite include_worktrees=false" grep -n 'alpha-wt' "$repos_dir/list-nowt"
rm -f "$repos_xdg/groundwork/repos.local.conf"

# The status table: dirty/clean as symbol + word (never color-only; NO_COLOR
# is set for the whole suite), shortest-unique-suffix repo names, the
# worktree marker, and the branch.
repos_run '' "$repos_path" status >"$repos_dir/status-out"
grep -F 'space repo' "$repos_dir/status-out" | grep -qF '● dirty'
grep -- '/alpha$' "$repos_dir/status-out" | grep -qF '✓ clean'
grep -qF 'one/app' "$repos_dir/status-out"
grep -qF 'two/app' "$repos_dir/status-out"
grep -- '/alpha-wt$' "$repos_dir/status-out" | grep -qF ' wt '
grep -qF 'main' "$repos_dir/status-out"
assert_no_matches "status table must not emit color under NO_COLOR" grep -n $'\033\[' "$repos_dir/status-out"
# Shortest-unique-suffix names: identical basename+parent across two roots
# extends to the root component; a triple-depth collision extends further;
# nothing keeps an ambiguous shorter name; and every name is unique.
awk '{ print $1 }' "$repos_dir/status-out" >"$repos_dir/status-names"
grep -qxF 'root/client/app' "$repos_dir/status-names"
grep -qxF 'root2/client/app' "$repos_dir/status-names"
grep -qxF 'root/aa/bb/deep' "$repos_dir/status-names"
grep -qxF 'root2/aa/bb/deep' "$repos_dir/status-names"
assert_no_matches "an ambiguous shorter name survived (client/app)" grep -nxF 'client/app' "$repos_dir/status-names"
assert_no_matches "an ambiguous shorter name survived (bb/deep)" grep -nxF 'bb/deep' "$repos_dir/status-names"
assert_no_matches "an ambiguous shorter name survived (deep)" grep -nxF 'deep' "$repos_dir/status-names"
if [[ -n "$(sort "$repos_dir/status-names" | uniq -d)" ]]; then
  fail "groundwork-repos status produced duplicate repo names"
fi

# Clean/dirty transitions show immediately: the cache stores paths only,
# state is always read live.
rm "$repos_root/space repo/untracked.txt"
repos_run '' "$repos_path" status | grep -F 'space repo' | grep -qF '✓ clean'

# The fsmonitor tripwire. First prove the fixture is LIVE: plain git status
# in that repo executes the configured core.fsmonitor script.
rm -f "$repos_fsmon_sentinel"
repos_git -C "$repos_root/fsmon" status --porcelain >/dev/null
if [[ ! -f "$repos_fsmon_sentinel" ]]; then
  fail "fsmonitor fixture is not live: plain git status did not run the configured core.fsmonitor"
fi
# Now every groundwork-repos mode walks the same repo, and the safe wrapper
# (hooks and fsmonitor disabled per git call) must keep the script silent.
rm -f "$repos_fsmon_sentinel"
repos_run '' "$repos_path" list >/dev/null
repos_run '' "$repos_path" status >/dev/null
: >"$repos_tmux_log"
REPOS_FZF_CHOOSE='alpha' repos_run 'validate,0,0' "$repos_path" pick
repos_run 'validate,0,0' "$repos_path" changed >/dev/null
if [[ -f "$repos_fsmon_sentinel" ]]; then
  fail "a groundwork-repos mode executed a discovered repo's core.fsmonitor — inspection must disable repository hooks and the fsmonitor"
fi
# The fzf preview runs git OUTSIDE the helper process; it must carry the
# same neutralizing flags — asserted on the recorded fzf argv, then proven
# by executing the preview command against the tripwire repo.
repos_preview_cmd="$(awk 'found { print; exit } $0 == "--preview" { found = 1 }' "$repos_fzf_args")"
[[ -n "$repos_preview_cmd" ]] || fail "the picker no longer passes an fzf --preview command"
case "$repos_preview_cmd" in
  *GIT_OPTIONAL_LOCKS=0*core.fsmonitor=false*core.untrackedCache=false*core.hooksPath=/dev/null*) : ;;
  *) fail "the fzf preview git command lost its hook/fsmonitor-disabling flags: $repos_preview_cmd" ;;
esac
rm -f "$repos_fsmon_sentinel"
repos_fsmon_quoted="'$repos_root/fsmon'"
repos_preview_run="${repos_preview_cmd//\{2\}/$repos_fsmon_quoted}"
GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_SYSTEM=/dev/null PATH="$repos_path" \
  /bin/sh -c "$repos_preview_run" >/dev/null
if [[ -f "$repos_fsmon_sentinel" ]]; then
  fail "the fzf preview command executed a discovered repo's core.fsmonitor"
fi

# The picker, inside tmux: fzf sees every repo, and the selected repo's
# window opens via new-window -S (reuse, never duplicate) with the path
# travelling as ONE argv word — spaces intact.
: >"$repos_tmux_log"
REPOS_FZF_CHOOSE='space repo' repos_run 'validate,0,0' "$repos_path" pick
grep -qF "$repos_root/alpha" "$repos_fzf_in"
grep -qxF -- 'new-window' "$repos_tmux_log"
grep -qxF -- '-S' "$repos_tmux_log"
grep -qxF -- 'space repo' "$repos_tmux_log"
grep -qxF -- "$repos_root/space repo" "$repos_tmux_log"
grep -qxF -- 'lazygit' "$repos_tmux_log"
assert_no_matches "picker inside tmux must not create sessions" grep -n 'new-session' "$repos_tmux_log"

# The picker, outside tmux: it creates the repos session and attaches.
: >"$repos_tmux_log"
REPOS_FZF_CHOOSE='alpha' repos_run '' "$repos_path" pick
grep -qxF -- 'new-session' "$repos_tmux_log"
grep -qxF -- 'repos' "$repos_tmux_log"
grep -qxF -- 'attach-session' "$repos_tmux_log"

# Window names in tmux carry the shortest unique suffix: two dirty repos
# with identical basename+parent across roots open under distinct names.
echo dirt >"$repos_root/client/app/wip.txt"
echo dirt >"$repos_root2/client/app/wip.txt"
: >"$repos_tmux_log"
repos_run 'validate,0,0' "$repos_path" changed >/dev/null
grep -qxF -- 'root/client/app' "$repos_tmux_log"
grep -qxF -- 'root2/client/app' "$repos_tmux_log"
rm "$repos_root/client/app/wip.txt" "$repos_root2/client/app/wip.txt"

# changed: one window per dirty repo, none for clean repos.
echo dirt >"$repos_root/alpha/wip.txt"
echo dirt >"$repos_root/one/app/wip.txt"
: >"$repos_tmux_log"
repos_run 'validate,0,0' "$repos_path" changed >"$repos_dir/changed-out"
test "$(grep -cxF -- 'new-window' "$repos_tmux_log")" = 2
grep -qxF -- 'one/app' "$repos_tmux_log"
assert_no_matches "changed opened a window for a clean repo" grep -n "$repos_root/two/app" "$repos_tmux_log"
grep -qF 'opened 2 lazygit window(s)' "$repos_dir/changed-out"

# changed with everything clean opens nothing and says so.
rm "$repos_root/alpha/wip.txt" "$repos_root/one/app/wip.txt"
: >"$repos_tmux_log"
repos_run 'validate,0,0' "$repos_path" changed >"$repos_dir/changed-clean"
grep -qF 'every discovered repository is clean' "$repos_dir/changed-clean"
test ! -s "$repos_tmux_log"

# Without fzf the picker degrades to a message plus the list, not a stack trace.
if repos_run 'validate,0,0' "$repos_stub_nofzf:$repos_tools" pick \
  >"$repos_dir/pick-nofzf" 2>&1; then
  fail "groundwork-repos pick succeeded without fzf"
fi
grep -qF 'needs fzf' "$repos_dir/pick-nofzf"
grep -qF "$repos_root/alpha" "$repos_dir/pick-nofzf"

# The discovery cache honors its TTL, and paths (not state) are what it holds.
cat >"$repos_xdg/groundwork/repos.local.conf" <<'EOF'
cache_ttl_seconds = 300
EOF
repos_run '' "$repos_path" list >/dev/null
rm -rf "$repos_root/charlie"
repos_run '' "$repos_path" list | grep -qF "$repos_root/charlie" \
  || fail "warm cache inside TTL should still list the removed repo"
# --refresh bypasses AND rewrites the cache: the change shows immediately,
# and the next plain run reads the rewritten cache, not the stale one.
repos_run '' "$repos_path" --refresh list >"$repos_dir/list-refresh"
assert_no_matches "--refresh still served the stale cache" \
  grep -nF "$repos_root/charlie" "$repos_dir/list-refresh"
repos_run '' "$repos_path" list >"$repos_dir/list-after-refresh"
assert_no_matches "--refresh did not rewrite the cache for the next run" \
  grep -nF "$repos_root/charlie" "$repos_dir/list-after-refresh"
rm -f "$repos_xdg/groundwork/repos.local.conf" "$repos_cache/groundwork/repos.list"

# The same cache path under a GNU-like stat — the exact CI failure: Ubuntu's
# stat answered `-f %m` with a "File:" block and exit 0, which reached the
# TTL arithmetic as "File: unbound variable". Shadow stat with a GNU-like
# stub (delegating -c %Y to python for a real mtime) and run the REAL helper
# twice: warm the cache, then evaluate its freshness end to end.
repos_python="$(command -v python3)" || fail "groundwork-repos suite: python3 missing"
repos_gnu_bin="$repos_dir/gnu-stat-bin"
mkdir -p "$repos_gnu_bin"
cat >"$repos_gnu_bin/stat" <<SH
#!/bin/sh
if [ "\$1" = "-c" ] && [ "\$2" = "%Y" ]; then
  exec "$repos_python" -c 'import os,sys;print(int(os.stat(sys.argv[1]).st_mtime))' "\$3"
fi
printf '  File: "irrelevant"\n    ID: 100000 Namelen: 255\n'
exit 0
SH
chmod +x "$repos_gnu_bin/stat"
cat >"$repos_xdg/groundwork/repos.local.conf" <<'EOF'
cache_ttl_seconds = 300
EOF
repos_run '' "$repos_gnu_bin:$repos_path" list >"$repos_dir/gnu-cache-warm" \
  || fail "groundwork-repos failed discovery under a GNU-like stat"
grep -qF "$repos_root/alpha"$'\t' "$repos_dir/gnu-cache-warm" \
  || fail "discovery under a GNU-like stat lost a repository"
repos_run '' "$repos_gnu_bin:$repos_path" list \
  >"$repos_dir/gnu-cache-hit" 2>"$repos_dir/gnu-cache-err" \
  || fail "groundwork-repos failed evaluating a warm cache under a GNU-like stat"
grep -qF "$repos_root/alpha"$'\t' "$repos_dir/gnu-cache-hit" \
  || fail "the warm-cache run under a GNU-like stat lost a repository"
assert_no_matches "the GNU-stat cache path hit an unbound-variable error" \
  grep -n 'unbound variable' "$repos_dir/gnu-cache-err"
rm -f "$repos_xdg/groundwork/repos.local.conf" "$repos_cache/groundwork/repos.list"

# Help and option hygiene, same contract as the other helpers.
repos_run '' "$repos_path" --help | grep -qF 'groundwork-help repos'
if repos_run '' "$repos_path" --bogus >/dev/null 2>&1; then
  fail "groundwork-repos accepted an unknown option"
fi

check "chezmoi root"
test "$(cat .chezmoiroot)" = "home"
grep -q '^2\.70\.0$' .chezmoiversion
test -f home/.chezmoi.toml.tmpl
test ! -f .chezmoi.toml.tmpl
test -f home/dot_zprofile.tmpl
test -x home/dot_codex/modify_private_config.toml
grep -qF 'mise activate zsh --shims' home/dot_zprofile.tmpl
grep -qF 'experimental_use_profile = true' home/dot_codex/modify_private_config.toml
grep -qF 'config.global.show_in_menu_bar = true;' home/dot_config/private_karabiner/modify_karabiner.json
assert_no_matches "Karabiner menu bar icon must stay visible for setup/debugging" rg -n 'show_in_menu_bar[[:space:]]*=[[:space:]]*false|show_in_menu_bar"[[:space:]]*:[[:space:]]*false' home/dot_config/private_karabiner
# Karabiner-Elements chmods ~/.config/karabiner to 700, so the source dir must
# carry the private_ attribute; without it every apply wants the mode back to
# 755 and prompts ".config/karabiner has changed since chezmoi last wrote it".
test -d home/dot_config/private_karabiner \
  || fail "karabiner must live at home/dot_config/private_karabiner (private_ = mode 700, matching what the app enforces)"
test ! -e home/dot_config/karabiner \
  || fail "home/dot_config/karabiner must not exist alongside private_karabiner"
# The modify script must pass a semantically settled config through
# byte-for-byte — in Karabiner's own serialization (4-space, alphabetized
# keys), not just its own: anything else rewrites the file and prompts on
# every apply forever. JXA needs macOS, so this only runs where osascript is.
if command -v osascript >/dev/null 2>&1; then
  karabiner_fixture="$out_dir/karabiner-idempotence"
  mkdir -p "$karabiner_fixture"
  /bin/bash home/dot_config/private_karabiner/modify_karabiner.json \
    </dev/null >"$karabiner_fixture/seeded.json" \
    || fail "karabiner modify failed on an empty config"
  grep -qF 'Groundwork: Caps Lock' "$karabiner_fixture/seeded.json" \
    || fail "karabiner modify must add the Groundwork rule to an empty config"
  python3 -c 'import json,sys
config = json.load(open(sys.argv[1]))
open(sys.argv[2], "w").write(json.dumps(config, indent=4, sort_keys=True) + "\n")' \
    "$karabiner_fixture/seeded.json" "$karabiner_fixture/app-format.json"
  /bin/bash home/dot_config/private_karabiner/modify_karabiner.json \
    <"$karabiner_fixture/app-format.json" >"$karabiner_fixture/app-format-out.json" \
    || fail "karabiner modify failed on an app-formatted config"
  cmp -s "$karabiner_fixture/app-format.json" "$karabiner_fixture/app-format-out.json" \
    || fail "karabiner modify must pass an already-settled app-formatted config through byte-for-byte"
  # A rule the user added themselves — even one Karabiner appended AFTER the
  # Groundwork rule — must survive byte-for-byte and keep its position.
  python3 -c 'import json,sys
config = json.load(open(sys.argv[1]))
profile = next(p for p in config["profiles"] if p.get("selected")) if any(p.get("selected") for p in config["profiles"]) else config["profiles"][0]
profile["complex_modifications"]["rules"].append({"description": "user rule", "manipulators": []})
open(sys.argv[2], "w").write(json.dumps(config, indent=4, sort_keys=True) + "\n")' \
    "$karabiner_fixture/seeded.json" "$karabiner_fixture/user-rule.json"
  /bin/bash home/dot_config/private_karabiner/modify_karabiner.json \
    <"$karabiner_fixture/user-rule.json" >"$karabiner_fixture/user-rule-out.json" \
    || fail "karabiner modify failed on a config with a user rule"
  cmp -s "$karabiner_fixture/user-rule.json" "$karabiner_fixture/user-rule-out.json" \
    || fail "karabiner modify must preserve user rules byte-for-byte, in position"
  # A corrupt existing file must FAIL the merge, never be silently replaced.
  printf 'not json {' >"$karabiner_fixture/corrupt.json"
  if /bin/bash home/dot_config/private_karabiner/modify_karabiner.json \
    <"$karabiner_fixture/corrupt.json" >/dev/null 2>&1; then
    fail "karabiner modify must refuse (exit nonzero) on a corrupt existing file"
  fi
fi
test -f home/dot_local/bin/executable_groundwork-apps-start
test -x home/dot_local/bin/executable_groundwork-apps-start
grep -qF 'groundwork-apps-start' home/run_onchange_after_10-brew-bundle.sh.tmpl
grep -qF 'groundwork-apps-start' home/dot_local/bin/executable_groundwork-update-run.tmpl
# Every always-on app stays in the relaunch guard; Homebrew quits them on
# cask upgrades and never brings them back.
for always_on_app in Karabiner-Elements Raycast BetterDisplay Anybox; do
  grep -qF "start_app \"$always_on_app\"" home/dot_local/bin/executable_groundwork-apps-start \
    || { echo "groundwork-apps-start must relaunch $always_on_app" >&2; exit 1; }
done
grep -qxF '.local/bin/groundwork-karabiner-start' home/.chezmoiremove
# update-all is a stable disk-backed launcher that syncs and then execs the
# freshly applied runner; .zshrc must never regain a substantive in-memory
# implementation, and the launcher must never regain update stages.
test -x home/dot_local/bin/executable_update-all
test -x home/dot_local/bin/executable_groundwork-update-run.tmpl
grep -qF 'chezmoi update --init' home/dot_local/bin/executable_update-all
grep -qF "exec \"\$runner\" \"\$@\"" home/dot_local/bin/executable_update-all
assert_no_matches "update stages leaked into the stable update-all launcher" \
  rg -n 'brew upgrade|mise upgrade|groundwork-brew-update' home/dot_local/bin/executable_update-all
grep -qF "\"\$HOME/.local/bin/groundwork-brew-update\"" home/dot_local/bin/executable_groundwork-update-run.tmpl
assert_no_matches "substantive update-all shell function returned" rg -n '^update-all\(\) \{' home/dot_zshrc.tmpl
grep -qF $'daily\tupdate-all\tcommand\t' home/dot_local/share/groundwork/commands.tsv
