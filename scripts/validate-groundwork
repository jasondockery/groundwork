grep -q "beta channel on" "$out_dir/darwin-beta/update-run"
render darwin false arm64 home/dot_config/homebrew/Brewfile.tmpl "$out_dir/darwin-nobeta/Brewfile" false true false
assert_not_contains '^brew "xcodes"' "$out_dir/darwin-nobeta/Brewfile" "xcodes leaked without the beta channel"
render darwin false arm64 home/dot_local/bin/executable_groundwork-update-run.tmpl "$out_dir/darwin-nobeta/update-run" false true false
assert_not_contains "beta channel on" "$out_dir/darwin-nobeta/update-run" "beta reminder leaked into update-all without the beta channel"
# beta is only meaningful with Xcode: xcode=false + beta=true must normalize to
# no xcodes and no reminder, matching the prompt that only offers beta under Xcode.
render darwin false arm64 home/dot_config/homebrew/Brewfile.tmpl "$out_dir/darwin-beta-noxcode/Brewfile" false false true
assert_not_contains '^brew "xcodes"' "$out_dir/darwin-beta-noxcode/Brewfile" "xcodes installed with beta but no Xcode"
render darwin false arm64 home/dot_local/bin/executable_groundwork-update-run.tmpl "$out_dir/darwin-beta-noxcode/update-run" false false true
assert_not_contains "beta channel on" "$out_dir/darwin-beta-noxcode/update-run" "beta reminder shown with beta but no Xcode"
# Lock the update-all Homebrew policy: checksums required, and no --greedy of
# any kind. --greedy re-downloads and re-quarantines self-updating casks
# (repeated Gatekeeper prompts); --greedy-latest only adds `version :latest`
# casks, which Groundwork installs none of — and those are the casks Homebrew
# requires to ship `sha256 :no_check`, so admitting them would defeat
# --require-sha.
grep -q 'HOMEBREW_NO_AUTO_UPDATE=1 HOMEBREW_NO_UPGRADE_AUTO_UPDATES_CASKS=1' "$out_dir/darwin-beta/update-run"
grep -q 'brew upgrade --require-sha' "$out_dir/darwin-beta/update-run"
assert_not_contains '^[^#]*brew upgrade[^#]*--greedy' "$out_dir/darwin-beta/update-run" \
  "update-all must not use any --greedy flag (unchecked or re-quarantined casks)"
# The safe lane must never silently fall back when a checksum check fails.
assert_no_matches "a failed --require-sha upgrade must not be retried without it" \
  rg -n 'require-sha.*\|\||\|\|.*brew upgrade' home/dot_local/bin/executable_groundwork-update-run.tmpl

check "rendered agent adapters"
render darwin false arm64 home/dot_claude/CLAUDE.md.tmpl "$out_dir/CLAUDE.md"
render darwin false arm64 home/dot_codex/AGENTS.md.tmpl "$out_dir/AGENTS.md"
grep -q "AI-Native Groundwork" "$out_dir/CLAUDE.md"
grep -q "AI-Native Groundwork" "$out_dir/AGENTS.md"
grep -q "Claude Code Notes" "$out_dir/CLAUDE.md"
grep -q "Codex Notes" "$out_dir/AGENTS.md"

check "Codex shell profile config merge"
codex_config_fixture="$out_dir/codex-config.toml"
codex_config_once="$out_dir/codex-config-once.toml"
codex_config_twice="$out_dir/codex-config-twice.toml"
cat >"$codex_config_fixture" <<'EOF'
model = "gpt-example"

[shell_environment_policy]
experimental_use_profile = false
inherit = "core"

[features]
memories = true
EOF
home/dot_codex/modify_private_config.toml <"$codex_config_fixture" >"$codex_config_once"
home/dot_codex/modify_private_config.toml <"$codex_config_once" >"$codex_config_twice"
cmp -s "$codex_config_once" "$codex_config_twice" || fail "Codex config merge must be idempotent"
grep -q '^model = "gpt-example"$' "$codex_config_once"
grep -q '^\[features\]$' "$codex_config_once"
grep -q '^inherit = "core"$' "$codex_config_once"
test "$(grep -c '^\[shell_environment_policy\]$' "$codex_config_once")" = 1
test "$(grep -c '^experimental_use_profile = true$' "$codex_config_once")" = 1

check "docs links"
for page in docs/*.html; do
  dir="$(dirname "$page")"
  while IFS= read -r href; do
    case "$href" in
      http:*|https:*|mailto:*|"") continue ;;
    esac
    target="${href%%#*}"
    fragment=""
    [[ "$href" == *#* ]] && fragment="${href#*#}"
    target_path="$dir/${target:-$(basename "$page")}"
    if [[ ! -e "$target_path" ]]; then
      echo "missing $page: $href" >&2
      exit 1
    fi
    if [[ -n "$fragment" ]] && ! grep -Eq "(id|name)=\"$fragment\"" "$target_path"; then
      echo "missing fragment $page: $href" >&2
      exit 1
    fi
  done < <(grep -Eo 'href="[^"]+"' "$page" | sed -E 's/^href="([^"]*)"$/\1/')
  while IFS= read -r src; do
    case "$src" in
      http:*|https:*|data:*|"") continue ;;
    esac
    if [[ ! -e "$dir/$src" ]]; then
      echo "missing asset $page: $src" >&2
      exit 1
    fi
  done < <(grep -Eo 'src="[^"]+"' "$page" | sed -E 's/^src="([^"]*)"$/\1/')
done

check "line endings stay LF"
grep -q '^\* text=auto eol=lf$' .gitattributes
assert_no_matches "CRLF line endings found in tracked files" git grep -Il $'\r' -- .

check "common secret patterns"
assert_no_matches "secret-like pattern found" git grep -n -E '(-----BEGIN [A-Z ]*PRIVATE KEY-----|ghp_[A-Za-z0-9_]{20,}|github_pat_[A-Za-z0-9_]{20,}|sk-[A-Za-z0-9_-]{20,}|xox[baprs]-[A-Za-z0-9-]{20,}|AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{35})'

if [[ -n "${GROUNDWORK_PUBLIC_DENYLIST_PATTERN:-}" ]]; then
  check "local public denylist env pattern"
  assert_no_matches "local public denylist env pattern matched" rg -n "$GROUNDWORK_PUBLIC_DENYLIST_PATTERN" . --hidden -g '!.git' -g '!node_modules'
fi

if [[ -f .groundwork-public-denylist ]]; then
  check "local public denylist file"
  while IFS= read -r pattern; do
    [[ -z "$pattern" || "$pattern" == \#* ]] && continue
    assert_no_matches "local public denylist file pattern matched" rg -n "$pattern" . --hidden -g '!.git' -g '!node_modules' -g '!.groundwork-public-denylist'
  done < .groundwork-public-denylist
fi

check "old name residue"
assert_no_matches "old name residue found" rg -n "Primer|primer|mac-dev-primer|Mac Dev|MAC_DEV_PRIMER|validate-primer|jasondockery/mac-dev-primer|PRIMER" . --hidden -g '!.git' -g '!node_modules' -g '!scripts/validate-groundwork'

check "discovery artifacts current (descriptions, sitemap, llms.txt)"
scripts/generate-discovery --check

check "discovery generator fails closed on a shallow clone"
# The regression: a shallow checkout made git log report HEAD's date for every
# page. The generator must now refuse rather than emit silently-wrong dates.
# file:// forces the transport that honors --depth (a plain path hardlink-clones
# and ignores it). Test the working-tree generator, not the committed copy.
shallow_dir="$(mktemp -d "${TMPDIR:-/tmp}/groundwork-shallow.XXXXXX")"
git clone --quiet --depth 1 "file://$PWD/.git" "$shallow_dir/repo"
cp scripts/generate-discovery "$shallow_dir/repo/scripts/generate-discovery"
if (cd "$shallow_dir/repo" && python3 scripts/generate-discovery --check) \
    >/dev/null 2>"$shallow_dir/err"; then
  echo "generate-discovery did not fail closed in a shallow clone" >&2
  rm -rf "$shallow_dir"
  exit 1
fi
if ! grep -qi shallow "$shallow_dir/err"; then
  echo "generate-discovery failed in a shallow clone but not with the shallow message" >&2
  cat "$shallow_dir/err" >&2
  rm -rf "$shallow_dir"
  exit 1
fi
rm -rf "$shallow_dir"

check "discovery generator lastmod: committed date vs today for dirty/untracked"
# Black-box all three date paths in a throwaway repo: a clean committed page
# keeps its actual commit date, while dirty and untracked pages get today.
# Pages carry the description the generator would compute, so it stays
# idempotent (no metadata rewrite that would otherwise dirty a committed page).
datefx_dir="$(mktemp -d "${TMPDIR:-/tmp}/groundwork-datefx.XXXXXX")"
write_fixture_page() {
  printf '%s' '<html><head><meta name="description" content="Lead."><meta property="og:site_name" content="Groundwork"><title>T</title></head><body><div class="content"><p class="lead">Lead.</p></div></body></html>' > "$1"
}
if ! (
  cd "$datefx_dir" || exit 1
  git init -q
  git config user.email t@example.com
  git config user.name tester
  mkdir -p docs scripts
  cp "$repo/scripts/generate-discovery" scripts/generate-discovery
  write_fixture_page docs/a.html
  write_fixture_page docs/b.html
  export GIT_AUTHOR_DATE="2020-01-01T00:00:00" GIT_COMMITTER_DATE="2020-01-01T00:00:00"
  git add -A
  git commit -qm init
  unset GIT_AUTHOR_DATE GIT_COMMITTER_DATE
  printf '\n' >> docs/b.html       # tracked and dirty
  write_fixture_page docs/c.html   # untracked
  python3 scripts/generate-discovery >/dev/null
  python3 - <<'PY'
import datetime
import xml.etree.ElementTree as ET

namespace = {"sitemap": "http://www.sitemaps.org/schemas/sitemap/0.9"}
entries = [
    (
        element.findtext("sitemap:loc", namespaces=namespace),
        element.findtext("sitemap:lastmod", namespaces=namespace),
    )
    for element in ET.parse("docs/sitemap.xml").getroot().findall("sitemap:url", namespace)
]
actual = dict(entries)
today = datetime.date.today().isoformat()
expected = {
    "https://jasondockery.github.io/groundwork/a.html": "2020-01-01",
    "https://jasondockery.github.io/groundwork/b.html": today,
    "https://jasondockery.github.io/groundwork/c.html": today,
}
if len(entries) != len(actual) or actual != expected:
    raise SystemExit(f"unexpected sitemap lastmod mapping: {actual!r}; expected {expected!r}")
PY
); then
  rm -rf "$datefx_dir"
  exit 1
fi
rm -rf "$datefx_dir"

check "whitespace"
git diff --check

echo "ok: Groundwork validation passed"
