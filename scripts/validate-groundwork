#!/usr/bin/env bash
set -euo pipefail

repo="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo"
shopt -s nullglob

out_dir="$(mktemp -d "${TMPDIR:-/tmp}/groundwork-rendered.XXXXXX")"

# GitHub-aware failure reporting. Locally this is inert: the EXIT trap only
# cleans up, `check` only echoes the progress line, and `fail` behaves exactly
# like the echo >&2 + exit 1 it replaces. In GitHub Actions the trap turns a
# failure into one ::error annotation naming the failing check, and appends a
# pass/fail summary to $GITHUB_STEP_SUMMARY. Summary/annotation writes are
# fail-open: they never change the script's exit status.
current_check="startup"
checks_started=0
fail_reason=""

check() {
  current_check="$1"
  checks_started=$((checks_started + 1))
  echo "check: $1"
}

fail() {
  fail_reason="$1"
  echo "$1" >&2
  exit 1
}

# Toolkit-exact annotation escaping (@actions/core's escapeData/escapeProperty).
#
# The contract and its test vectors live in Roost's `@roost/ci-diagnostics`
# (packages/ci-diagnostics/src/diagnostics.ts — escapeWorkflowData,
# escapeWorkflowProperty, capWorkflowPayload — with the shared cases in that
# package's src/vectors.json). This shell mirrors that TypeScript rather than
# vendoring it: a Node toolchain does not belong in a shell-first repo, so what
# travels between the repos is the contract, not the package. When the contract
# changes, change it there first and mirror it here.
#
# Order matters. `%` is escaped FIRST, or the `%` that the later escapes
# introduce would itself be escaped again (`\n` -> `%0A` -> `%250A`). CR and LF
# become %0D/%0A rather than being collapsed to spaces: both forms are
# injection-safe, since a workflow command is only recognized at the start of a
# line and neither form lets content open one, but the encoded form is also
# lossless — GitHub renders the annotation as the multi-line text it was.
# U+2028/U+2029 terminate a line for the runner's command parser exactly like
# LF, so they escape to %0A too.
annotation_max_length=500

# bash counts CODE POINTS in ${#s} and ${s:o:n} only under a multibyte locale;
# under C/POSIX it counts BYTES, and a cut at 499 bytes can land inside a
# multibyte character. A runner with no LANG set (GitHub's macOS images) is
# exactly that case, so the cap forces a locale of its own rather than inheriting
# whatever the caller happened to have. Assigning LC_ALL re-runs setlocale in the
# current shell — no subshell needed, and none wanted, since the capped string
# has to come back out.
annotation_saved_lc_all=""
annotation_saved_lc_all_set=0
annotation_force_locale() {
  annotation_saved_lc_all=""
  annotation_saved_lc_all_set=0
  if [[ -n "${LC_ALL+set}" ]]; then
    annotation_saved_lc_all="$LC_ALL"
    annotation_saved_lc_all_set=1
  fi
  LC_ALL="$1"
}

annotation_restore_locale() {
  if [[ "$annotation_saved_lc_all_set" -eq 1 ]]; then
    LC_ALL="$annotation_saved_lc_all"
  else
    unset LC_ALL
  fi
}

# Resolve a usable UTF-8 locale once, probing with a real 2-byte character rather
# than trusting a locale's name: an unknown name leaves setlocale on C, where the
# probe is 2 characters long instead of 1. Empty means this machine has none.
annotation_utf8_locale=""
for annotation_locale_candidate in "${LC_ALL:-}" "${LC_CTYPE:-}" "${LANG:-}" C.UTF-8 en_US.UTF-8; do
  [[ -n "$annotation_locale_candidate" ]] || continue
  annotation_force_locale "$annotation_locale_candidate"
  annotation_locale_probe=$'\303\251'
  if [[ ${#annotation_locale_probe} -eq 1 ]]; then
    annotation_restore_locale
    annotation_utf8_locale="$annotation_locale_candidate"
    break
  fi
  annotation_restore_locale
done
unset annotation_locale_candidate annotation_locale_probe

# Caps the RAW payload (before escaping), so the limit is a content limit rather
# than an escaped-length limit and both emitters truncate at the same character.
# Answers in the global `annotation_capped` instead of on stdout: a message may
# legitimately end in a newline (it becomes %0A), and $(...) would eat it.
annotation_capped=""
annotation_cap() {
  local s="$1" keep=$((annotation_max_length - 1)) last
  if [[ -n "$annotation_utf8_locale" ]]; then
    annotation_force_locale "$annotation_utf8_locale"
    [[ ${#s} -le $annotation_max_length ]] || s="${s:0:$keep}…"
    annotation_restore_locale
    annotation_capped="$s"
    return
  fi
  # No UTF-8 locale exists on this machine. Force C so the semantics are known to
  # be BYTES (rather than assuming it of whatever the caller had), cut at 499
  # bytes, then back off any trailing partial character: drop trailing
  # continuation bytes (0x80-0xBF), then a trailing lead byte (0xC0+), which at
  # the end of the string can only be a sequence whose continuations were cut.
  # Stricter than the 499-code-point contract — it can drop one extra whole
  # character — but it can never emit a split one. Unreachable on a supported
  # platform: macOS and Ubuntu both ship a UTF-8 locale.
  annotation_force_locale C
  if [[ ${#s} -gt $annotation_max_length ]]; then
    s="${s:0:$keep}"
    while [[ -n "$s" ]]; do
      last="${s:$((${#s} - 1)):1}"
      [[ "$last" == [$'\200'-$'\277'] ]] || break
      s="${s:0:$((${#s} - 1))}"
    done
    if [[ -n "$s" ]]; then
      last="${s:$((${#s} - 1)):1}"
      [[ "$last" != [$'\300'-$'\375'] ]] || s="${s:0:$((${#s} - 1))}"
    fi
    # Braced deliberately: under a UTF-8 locale bash 3.2 scans the ellipsis bytes
    # as part of an unbraced variable name.
    s="${s}…"
  fi
  annotation_restore_locale
  annotation_capped="$s"
}

annotation_escape_message() {
  local cr=$'\r' nl=$'\n' ls=$'\342\200\250' ps=$'\342\200\251' s
  annotation_cap "$1"
  s="$annotation_capped"
  s="${s//%/%25}"
  s="${s//"$cr"/%0D}"
  s="${s//"$nl"/%0A}"
  s="${s//"$ls"/%0A}"
  s="${s//"$ps"/%0A}"
  printf '%s' "$s"
}

annotation_escape_title() {
  local s
  s="$(annotation_escape_message "$1")"
  s="${s//:/%3A}"
  s="${s//,/%2C}"
  printf '%s' "$s"
}

report_and_cleanup() {
  local status=$?
  rm -rf "$out_dir"
  if [[ -n "${copylast_socket:-}" ]]; then
    tmux -L "$copylast_socket" kill-server 2>/dev/null || true
  fi
  local reason title
  reason="$(annotation_escape_message "${fail_reason:-see the failing check output in the job log}")"
  title="$(annotation_escape_title "$current_check")"
  local passed="$checks_started"
  if [[ "$status" -ne 0 && "$checks_started" -gt 0 ]]; then
    passed=$((checks_started - 1))
  fi
  if [[ "$status" -ne 0 && "${GITHUB_ACTIONS:-}" == "true" ]]; then
    printf '::error title=validate-groundwork %s failed::%s. Reproduce locally: scripts/validate-groundwork\n' \
      "$title" "$reason" || true
  fi
  if [[ -n "${GITHUB_STEP_SUMMARY:-}" ]]; then
    {
      echo "## validate-groundwork"
      echo
      if [[ "$status" -eq 0 ]]; then
        echo "**Pass** — all $passed checks passed."
      else
        echo "**Fail** — check \`$current_check\` failed after $passed checks passed."
        echo
        echo "Reason: ${reason//|/\\|}"
      fi
      echo
      echo "Reproduce locally: \`scripts/validate-groundwork\`"
    } >>"$GITHUB_STEP_SUMMARY" || true
  fi
  exit "$status"
}
trap report_and_cleanup EXIT

# In GitHub Actions, gcc format feeds the shellcheck-gcc problem matcher
# (.github/problem-matchers/shellcheck-gcc.json) so findings surface as
# file/line annotations; locally keep shellcheck's readable tty output.
run_shellcheck() {
  if [[ "${GITHUB_ACTIONS:-}" == "true" ]]; then
    shellcheck --format=gcc "$@"
  else
    shellcheck "$@"
  fi
}

# Render hermetically: without --config, chezmoi merges the developer's real
# ~/.config/chezmoi data under --override-data, so keys a test omits on purpose
# (like xcode) leak in from the local machine and pass/fail differs from CI.
empty_config="$out_dir/empty-config.toml"
: > "$empty_config"

base_data='"name":"CI User","email_personal":"ci@example.com","email_work":"","code_dir":"~/code","reset_existing_configs":false,"password_manager":"bitwarden","signingkey":"","obsidian_vault_name":"ci","game_dev":false'

render() {
  local os="$1" headless="$2" arch="${3:-arm64}" input="$4" output="$5"
  local work="${6:-false}"
  local xcode="${7:-false}"
  local beta="${8:-false}"
  local os_release='{}'
  [[ "$os" == "linux" ]] && os_release='{"ID":"ubuntu"}'
  local data="{${base_data},\"work\":${work},\"headless\":${headless},\"xcode\":${xcode},\"beta\":${beta},\"chezmoi\":{\"os\":\"${os}\",\"arch\":\"${arch}\",\"osRelease\":${os_release}}}"
  chezmoi --config "$empty_config" --source "$PWD" --destination "$out_dir/home" --override-data "$data" execute-template < "$input" > "$output"
}

render_without_xcode_key() {
  local os="$1" headless="$2" arch="${3:-arm64}" input="$4" output="$5"
  local work="${6:-false}"
  local os_release='{}'
  [[ "$os" == "linux" ]] && os_release='{"ID":"ubuntu"}'
  local data="{${base_data},\"work\":${work},\"headless\":${headless},\"chezmoi\":{\"os\":\"${os}\",\"arch\":\"${arch}\",\"osRelease\":${os_release}}}"
  chezmoi --config "$empty_config" --source "$PWD" --destination "$out_dir/home" --override-data "$data" execute-template < "$input" > "$output"
}

assert_not_contains() {
  local pattern="$1" file="$2" message="$3"
  if grep -Eq "$pattern" "$file"; then
    fail_reason="$message"
    echo "$message" >&2
    sed -n '1,160p' "$file" >&2
    exit 1
  fi
}

assert_symlink_target() {
  local path="$1" target="$2"
  if [[ ! -L "$path" ]]; then
    fail "$path must be a symlink to $target"
  fi
  if [[ "$(readlink "$path")" != "$target" ]]; then
    fail "$path must point to $target"
  fi
}

assert_no_matches() {
  local message="$1" status
  shift
  if "$@"; then
    fail "$message"
  else
    status=$?
    if [[ "$status" -gt 1 ]]; then
      fail_reason="failed while checking: $message"
      echo "$fail_reason" >&2
      exit "$status"
    fi
  fi
}

line_number() {
  local pattern="$1" file="$2" line
  line="$(grep -nF -m1 "$pattern" "$file" | cut -d: -f1 || true)"
  if [[ -z "$line" ]]; then
    echo "$file: missing expected line: $pattern" >&2
    exit 1
  fi
  printf '%s\n' "$line"
}

check "bootstrap syntax"
bash -n bootstrap-mac.sh

check "helper script syntax"
shellcheck_files=(bootstrap-mac.sh)
# The shared docker-scan library is sourced, not executed, so the executable_*
# glob misses it; lint it explicitly (bash -n needs a shell, so use bash).
bash -n home/dot_local/share/groundwork/lib/docker-scan.sh
shellcheck_files+=(home/dot_local/share/groundwork/lib/docker-scan.sh)
for script in docker/*.sh home/dot_local/bin/executable_* home/dot_codex/modify_private_config.toml home/dot_config/private_karabiner/modify_karabiner.json scripts/*; do
  [[ -f "$script" ]] || continue
  [[ "$script" == *.tmpl ]] && continue
  if head -n 1 "$script" | grep -q 'bash'; then
    bash -n "$script"
    shellcheck_files+=("$script")
  fi
done

check "shellcheck"
run_shellcheck "${shellcheck_files[@]}"

check "Homebrew update retry helper"
test -x home/dot_local/bin/executable_groundwork-brew-update
brew_retry_bin="$out_dir/brew-retry-bin"
mkdir -p "$brew_retry_bin"
cat >"$brew_retry_bin/brew" <<'SH'
#!/usr/bin/env bash
printf '%s\n' "$*" >>"$BREW_COMMANDS_FILE"
count=0
[[ ! -f "$BREW_ATTEMPTS_FILE" ]] || count="$(<"$BREW_ATTEMPTS_FILE")"
count=$((count + 1))
printf '%s\n' "$count" >"$BREW_ATTEMPTS_FILE"
echo "fake brew update attempt $count"
[[ -z "${BREW_FORCE_STATUS:-}" ]] || exit "$BREW_FORCE_STATUS"
[[ "$count" -ge "${BREW_SUCCEED_ON:-3}" ]]
SH
cat >"$brew_retry_bin/sleep" <<'SH'
#!/usr/bin/env bash
printf '%s\n' "$1" >>"$BREW_SLEEPS_FILE"
SH
chmod +x "$brew_retry_bin/brew" "$brew_retry_bin/sleep"

# First-attempt success performs one update and no sleep.
BREW_SUCCEED_ON=1 BREW_ATTEMPTS_FILE="$out_dir/brew-attempts" \
  BREW_COMMANDS_FILE="$out_dir/brew-commands" BREW_SLEEPS_FILE="$out_dir/brew-sleeps" \
  PATH="$brew_retry_bin:$PATH" home/dot_local/bin/executable_groundwork-brew-update >/dev/null 2>&1
grep -qxF '1' "$out_dir/brew-attempts"
diff -u <(printf 'update\n') "$out_dir/brew-commands"
test ! -e "$out_dir/brew-sleeps"

# Second-attempt success sleeps once; third-attempt success uses both delays.
rm -f "$out_dir/brew-attempts" "$out_dir/brew-commands"
BREW_SUCCEED_ON=2 BREW_ATTEMPTS_FILE="$out_dir/brew-attempts" \
  BREW_COMMANDS_FILE="$out_dir/brew-commands" BREW_SLEEPS_FILE="$out_dir/brew-sleeps" \
  PATH="$brew_retry_bin:$PATH" home/dot_local/bin/executable_groundwork-brew-update >/dev/null 2>&1
grep -qxF '2' "$out_dir/brew-attempts"
diff -u <(printf 'update\nupdate\n') "$out_dir/brew-commands"
diff -u <(printf '3\n') "$out_dir/brew-sleeps"

rm -f "$out_dir/brew-attempts" "$out_dir/brew-commands" "$out_dir/brew-sleeps"
BREW_SUCCEED_ON=3 BREW_ATTEMPTS_FILE="$out_dir/brew-attempts" \
  BREW_COMMANDS_FILE="$out_dir/brew-commands" BREW_SLEEPS_FILE="$out_dir/brew-sleeps" \
  PATH="$brew_retry_bin:$PATH" home/dot_local/bin/executable_groundwork-brew-update \
  >"$out_dir/brew-retry-output" 2>&1
grep -qxF '3' "$out_dir/brew-attempts"
diff -u <(printf 'update\nupdate\nupdate\n') "$out_dir/brew-commands"
diff -u <(printf '3\n6\n') "$out_dir/brew-sleeps"

# Persistent failures stop after three exact `brew update` commands.
rm -f "$out_dir/brew-attempts" "$out_dir/brew-commands" "$out_dir/brew-sleeps"
if BREW_SUCCEED_ON=99 BREW_ATTEMPTS_FILE="$out_dir/brew-attempts" \
  BREW_COMMANDS_FILE="$out_dir/brew-commands" BREW_SLEEPS_FILE="$out_dir/brew-sleeps" \
  PATH="$brew_retry_bin:$PATH" home/dot_local/bin/executable_groundwork-brew-update \
  >"$out_dir/brew-retry-failure" 2>&1; then
  fail "groundwork-brew-update succeeded after three failed attempts"
fi
grep -qxF '3' "$out_dir/brew-attempts"
diff -u <(printf 'update\nupdate\nupdate\n') "$out_dir/brew-commands"
grep -qF 'stopped before package upgrades' "$out_dir/brew-retry-failure"

# Ctrl-C/termination statuses are authoritative: one attempt, no retry sleep.
for interrupt_status in 130 143; do
  rm -f "$out_dir/brew-attempts" "$out_dir/brew-commands" "$out_dir/brew-sleeps"
  set +e
  BREW_FORCE_STATUS="$interrupt_status" BREW_ATTEMPTS_FILE="$out_dir/brew-attempts" \
    BREW_COMMANDS_FILE="$out_dir/brew-commands" BREW_SLEEPS_FILE="$out_dir/brew-sleeps" \
    PATH="$brew_retry_bin:$PATH" home/dot_local/bin/executable_groundwork-brew-update >/dev/null 2>&1
  helper_status=$?
  set -e
  [[ "$helper_status" -eq "$interrupt_status" ]] \
    || fail "groundwork-brew-update changed interrupt status $interrupt_status to $helper_status"
  grep -qxF '1' "$out_dir/brew-attempts"
  diff -u <(printf 'update\n') "$out_dir/brew-commands"
  test ! -e "$out_dir/brew-sleeps"
done

# A missing brew command fails immediately with the documented error.
no_brew_bin="$out_dir/no-brew-bin"
mkdir -p "$no_brew_bin"
if PATH="$no_brew_bin" /bin/bash home/dot_local/bin/executable_groundwork-brew-update \
  >"$out_dir/brew-missing" 2>&1; then
  fail "groundwork-brew-update succeeded without brew on PATH"
fi
grep -qF 'Homebrew is not on PATH' "$out_dir/brew-missing"

check "update-all launcher handoff and runner transaction"
update_all_fixture="$out_dir/update-all-fixture"
update_all_home="$update_all_fixture/home"
update_all_bin="$update_all_home/.local/bin"
mkdir -p "$update_all_bin" "$update_all_home/.local/state/groundwork"
# The launcher under test is deliberately an "old" copy outside $HOME/.local/bin,
# proving a stale process still hands off to whatever the sync just installed.
cp home/dot_local/bin/executable_update-all "$update_all_fixture/old-launcher"
render linux false amd64 home/dot_local/bin/executable_groundwork-update-run.tmpl \
  "$update_all_fixture/rendered-runner"
chmod +x "$update_all_fixture/old-launcher" "$update_all_fixture/rendered-runner"

# The stub mirrors the real contract: ONLY a successful `apply` installs the
# runner — an update or status call installing it would let the fixture pass
# while the real flow ran a stale runner.
cat >"$update_all_bin/chezmoi" <<'SH'
#!/usr/bin/env bash
printf 'chezmoi %s color=%s\n' "$*" "${GROUNDWORK_COLOR:-unset}" >>"$GROUNDWORK_TEST_LOG"
[[ "${CHEZMOI_STATUS:-0}" == "0" ]] || exit "$CHEZMOI_STATUS"
case "${1:-}" in
  status)
    [[ "${CHEZMOI_STATUS_FAIL:-0}" == "0" ]] || exit 1
    [[ -z "${CHEZMOI_DRIFT:-}" ]] || printf '%s\n' "$CHEZMOI_DRIFT"
    ;;
  verify)
    exit "${CHEZMOI_VERIFY_STATUS:-0}"
    ;;
  apply)
    [[ "${CHEZMOI_APPLY_FAIL:-0}" == "0" ]] || exit 1
    if [[ "${CHEZMOI_INSTALL_RUNNER:-0}" == "1" ]]; then
      cp "$FRESH_RUNNER" "$HOME/.local/bin/groundwork-update-run"
      chmod +x "$HOME/.local/bin/groundwork-update-run"
    fi
    ;;
esac
SH
cat >"$update_all_fixture/fresh-runner" <<'SH'
#!/usr/bin/env bash
printf 'fresh runner color=%s\n' "${GROUNDWORK_COLOR:-unset}" >>"$GROUNDWORK_TEST_LOG"
for arg in "$@"; do
  printf 'arg=%s\n' "$arg" >>"$GROUNDWORK_TEST_LOG"
done
exit "${FRESH_RUNNER_STATUS:-0}"
SH
cat >"$update_all_home/.local/bin/groundwork-brew-update" <<'SH'
#!/usr/bin/env bash
printf 'brew-update\n' >>"$GROUNDWORK_TEST_LOG"
exit "${BREW_UPDATE_STATUS:-0}"
SH
# Default to "nothing actionable" (1); tests override to prove each outcome
# of the repair/refetch contract actually drives the runner's behavior.
cat >"$update_all_home/.local/bin/groundwork-brew-repair" <<'SH'
#!/usr/bin/env bash
printf 'brew-repair\n' >>"$GROUNDWORK_TEST_LOG"
exit "${REPAIR_STATUS:-1}"
SH
cat >"$update_all_home/.local/bin/groundwork-brew-refetch" <<'SH'
#!/usr/bin/env bash
printf 'brew-refetch\n' >>"$GROUNDWORK_TEST_LOG"
exit "${REFETCH_STATUS:-1}"
SH
chmod +x "$update_all_home/.local/bin/groundwork-brew-repair" \
  "$update_all_home/.local/bin/groundwork-brew-refetch"
cat >"$update_all_bin/brew" <<'SH'
#!/usr/bin/env bash
if [[ "${1:-}" == "upgrade" ]]; then
  printf 'brew %s auto=%s casks=%s hb-color=%s\n' "$*" \
    "${HOMEBREW_NO_AUTO_UPDATE:-unset}" \
    "${HOMEBREW_NO_UPGRADE_AUTO_UPDATES_CASKS:-unset}" \
    "${HOMEBREW_COLOR:-unset}" >>"$GROUNDWORK_TEST_LOG"
else
  printf 'brew %s\n' "$*" >>"$GROUNDWORK_TEST_LOG"
fi
exit "${BREW_STAGE_STATUS:-0}"
SH
cat >"$update_all_bin/groundwork-platform" <<'SH'
#!/usr/bin/env bash
echo "${FAKE_PLATFORM:-linux}"
SH
cat >"$update_all_bin/mise" <<'SH'
#!/usr/bin/env bash
if [[ "${1:-}" == "upgrade" && "${2:-}" == "--help" ]]; then
  [[ "${MISE_HAS_RELEASE_AGE:-1}" == "1" ]] && echo "      --minimum-release-age <MINIMUM_RELEASE_AGE>"
  exit 0
fi
printf 'mise %s\n' "$*" >>"$GROUNDWORK_TEST_LOG"
exit "${MISE_STATUS:-0}"
SH
chmod +x "$update_all_bin/chezmoi" "$update_all_bin/brew" "$update_all_bin/mise" \
  "$update_all_bin/groundwork-brew-update" "$update_all_bin/groundwork-platform" \
  "$update_all_fixture/fresh-runner"

update_all_log="$update_all_fixture/commands.log"
update_all_stamp="$update_all_home/.local/state/groundwork/last-update-all"
update_all_path="/usr/bin:/bin"

# An old launcher process syncs once, then hands the same invocation to the
# runner the sync just installed, with arguments and exit status intact.
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' \
  CHEZMOI_INSTALL_RUNNER=1 FRESH_RUNNER="$update_all_fixture/fresh-runner" \
  FRESH_RUNNER_STATUS=42 "$update_all_fixture/old-launcher" alpha "two words" \
  >"$update_all_fixture/handoff-output" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -eq 42 ]] || fail "update-all did not preserve the freshly installed runner's exit status"
# color=0 on the chezmoi line proves the launcher decided color BEFORE the
# sync (hook scripts inherit it), and on the runner line that the exec'd
# runner inherits the same decision; stdout is a file here, so it is 0.
update_all_runner_path="$update_all_home/.local/bin/groundwork-update-run"
cat >"$update_all_fixture/expected-handoff" <<EOF
chezmoi update --init --apply=false color=0
chezmoi status color=0
chezmoi apply $update_all_runner_path color=0
chezmoi verify $update_all_runner_path color=0
fresh runner color=0
arg=alpha
arg=two words
EOF
diff -u "$update_all_fixture/expected-handoff" "$update_all_log"

# Drift preflight: an MM file (changed locally AND changed by this update) is
# named and the overwrite question explained BEFORE chezmoi can ask it. With
# a usable terminal (the GROUNDWORK_PROMPT_TTY seam) the run continues into
# the runner, which owns the full apply.
printf '\n' >"$update_all_fixture/tty-drift"
: >"$update_all_log"
printf '' | env HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' \
  GROUNDWORK_PROMPT_TTY="$update_all_fixture/tty-drift" \
  CHEZMOI_DRIFT='MM .config/karabiner/karabiner.json' \
  CHEZMOI_INSTALL_RUNNER=1 FRESH_RUNNER="$update_all_fixture/fresh-runner" \
  "$update_all_fixture/old-launcher" >"$update_all_fixture/drift-output" 2>&1 \
  || fail "update-all failed on the drift-with-terminal preflight case"
grep -qF 'chezmoi will ask about each one' "$update_all_fixture/drift-output" \
  || fail "the drift preflight must explain the upcoming overwrite question"
grep -qF '.config/karabiner/karabiner.json' "$update_all_fixture/drift-output" \
  || fail "the drift preflight must name the drifted file"
grep -qF 'fresh runner color=0' "$update_all_log" \
  || fail "the run must continue into the runner after the drift preflight"

# Drift with NO usable terminal stops BEFORE any apply with the documented
# review-required status (2): an agent or cron run must never leave chezmoi
# hanging on (or failing through) an overwrite question nobody can answer.
: >"$update_all_log"
set +e
printf '' | env HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' \
  GROUNDWORK_PROMPT_TTY=/nonexistent-groundwork-tty \
  CHEZMOI_DRIFT='MM .config/karabiner/karabiner.json' \
  "$update_all_fixture/old-launcher" >"$update_all_fixture/drift-no-tty" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -eq 2 ]] \
  || fail "drift without a terminal must exit 2 (review required), got $update_all_status"
grep -qF 'stopping before the apply' "$update_all_fixture/drift-no-tty" \
  || fail "the no-terminal drift stop must say it stopped before the apply"
assert_not_contains 'chezmoi apply' "$update_all_log" \
  "drift without a terminal must not reach any chezmoi apply"

# A failed `chezmoi status` fails CLOSED before any apply: it means the
# source cannot be rendered against this machine, and applying anyway would
# run install hooks against a state nobody inspected.
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' \
  CHEZMOI_STATUS_FAIL=1 "$update_all_fixture/old-launcher" \
  >"$update_all_fixture/status-failure" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -ne 0 ]] || fail "update-all continued after chezmoi status failed"
grep -qF 'could not inspect managed-file drift' "$update_all_fixture/status-failure" \
  || fail "a status failure must be reported, not silently treated as no drift"
assert_not_contains 'chezmoi apply' "$update_all_log" \
  "a status failure must stop the run before any chezmoi apply"

# A runner that fails verification (a kept local edit) is refused: the
# handoff contract promises the FRESHLY applied runner, never a stale copy
# wearing its name.
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' \
  CHEZMOI_VERIFY_STATUS=1 CHEZMOI_INSTALL_RUNNER=1 FRESH_RUNNER="$update_all_fixture/fresh-runner" \
  "$update_all_fixture/old-launcher" >"$update_all_fixture/stale-runner" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -ne 0 ]] || fail "update-all executed a runner that failed verification"
grep -qF 'Refusing to run a stale updater' "$update_all_fixture/stale-runner" \
  || fail "a verification failure must refuse the stale runner explicitly"
assert_not_contains 'fresh runner' "$update_all_log" \
  "a runner that failed verification must never be executed"

# A failed apply of the runner target stops the handoff.
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' \
  CHEZMOI_APPLY_FAIL=1 "$update_all_fixture/old-launcher" \
  >"$update_all_fixture/apply-failure" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -ne 0 ]] || fail "update-all continued after the runner apply failed"
assert_not_contains 'fresh runner' "$update_all_log" \
  "a failed runner apply must not execute any runner"

# The 2026 color-override contract on the one run-wide decision: FORCE_COLOR
# turns the signal on without a terminal, NO_COLOR beats FORCE_COLOR, and a
# caller's explicit GROUNDWORK_COLOR passes through untouched.
for color_case in 'FORCE_COLOR=1 NO_COLOR= GROUNDWORK_COLOR=:1' \
  'FORCE_COLOR=1 NO_COLOR=1 GROUNDWORK_COLOR=:0' \
  'FORCE_COLOR= NO_COLOR=1 GROUNDWORK_COLOR=1:1'; do
  color_env="${color_case%:*}"
  color_expected="${color_case#*:}"
  : >"$update_all_log"
  # shellcheck disable=SC2086
  env HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
    $color_env CHEZMOI_INSTALL_RUNNER=1 FRESH_RUNNER="$update_all_fixture/fresh-runner" \
    "$update_all_fixture/old-launcher" >/dev/null 2>&1 \
    || fail "update-all failed under color overrides: $color_env"
  grep -qxF "chezmoi update --init --apply=false color=$color_expected" "$update_all_log" \
    || fail "the launcher must decide color=$color_expected before the sync under: $color_env"
  grep -qxF "fresh runner color=$color_expected" "$update_all_log" \
    || fail "the exec'd runner must inherit color=$color_expected under: $color_env"
done

# The launcher gates the platform BEFORE syncing: chezmoi update runs the
# install hooks (Homebrew bootstrap, brew bundle, every run_ script), so an
# unsupported platform must never reach it. A gate that only lives in the
# runner fires after the machine has already been mutated.
for launcher_platform in wsl1 wsl-unknown freebsd; do
  : >"$update_all_log"
  set +e
  HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
    FAKE_PLATFORM="$launcher_platform" "$update_all_fixture/old-launcher" \
    >"$update_all_fixture/launcher-$launcher_platform" 2>&1
  update_all_status=$?
  set -e
  [[ "$update_all_status" -ne 0 ]] \
    || fail "update-all launcher proceeded on unsupported platform $launcher_platform"
  test ! -s "$update_all_log" \
    || fail "update-all launcher ran chezmoi update on unsupported platform $launcher_platform"
done
grep -qF 'WSL1 is unsupported' "$update_all_fixture/launcher-wsl1"
grep -qF 'wsl --list --verbose' "$update_all_fixture/launcher-wsl-unknown"

# Synchronization failure prevents the handoff and every package/runtime stage.
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' \
  CHEZMOI_STATUS=1 "$update_all_fixture/old-launcher" \
  >"$update_all_fixture/sync-failure-output" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -ne 0 ]] || fail "update-all continued after chezmoi update failed"
diff -u <(printf 'chezmoi update --init --apply=false color=0\n') "$update_all_log"

# A successful sync that does not deliver the runner fails loudly instead of
# continuing through stale logic.
rm -f "$update_all_bin/groundwork-update-run"
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' \
  "$update_all_fixture/old-launcher" >"$update_all_fixture/missing-output" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -ne 0 ]] || fail "update-all continued without the freshly installed runner"
grep -qF 'update runner is missing or not executable' "$update_all_fixture/missing-output"
diff -u <(printf 'chezmoi update --init --apply=false color=0\nchezmoi status color=0\nchezmoi apply %s color=0\nchezmoi verify %s color=0\n' \
  "$update_all_runner_path" "$update_all_runner_path") "$update_all_log"

# The remaining transactions exercise the rendered runner directly, exactly as
# the launcher execs it. Unsupported platforms fail closed before ANY stage:
# no Homebrew, no mise, no timestamp — a warning after mutation is not
# fail-closed.
for unsupported_platform in wsl1 wsl-unknown freebsd; do
  : >"$update_all_log"
  set +e
  HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
    FAKE_PLATFORM="$unsupported_platform" "$update_all_fixture/rendered-runner" \
    >"$update_all_fixture/unsupported-$unsupported_platform" 2>&1
  update_all_status=$?
  set -e
  [[ "$update_all_status" -ne 0 ]] \
    || fail "update-all runner proceeded on unsupported platform $unsupported_platform"
  test ! -s "$update_all_log" \
    || fail "update-all runner mutated tools on unsupported platform $unsupported_platform"
  test ! -e "$update_all_stamp" \
    || fail "update-all runner wrote the timestamp on unsupported platform $unsupported_platform"
done
grep -qF 'WSL1 is unsupported' "$update_all_fixture/unsupported-wsl1" \
  || fail "the WSL1 refusal must explain itself"
grep -qF 'wsl --list --verbose' "$update_all_fixture/unsupported-wsl-unknown" \
  || fail "the ambiguous-WSL refusal must point at wsl --list --verbose"

# Failed metadata refresh stops before every package/runtime stage and does
# not create the success timestamp.
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' \
  BREW_UPDATE_STATUS=1 "$update_all_fixture/rendered-runner" \
  >"$update_all_fixture/failure-output" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -ne 0 ]] || fail "update-all runner continued after its metadata refresh failed"
diff -u <(printf 'chezmoi apply color=0\nbrew-update\n') "$update_all_log"
test ! -e "$update_all_stamp"

# Ctrl-C and termination statuses from a managed stage propagate unchanged.
for interrupt_status in 130 143; do
  : >"$update_all_log"
  set +e
  HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
    NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' \
    BREW_UPDATE_STATUS="$interrupt_status" "$update_all_fixture/rendered-runner" \
    >/dev/null 2>&1
  update_all_status=$?
  set -e
  [[ "$update_all_status" -eq "$interrupt_status" ]] \
    || fail "update-all runner changed stage status $interrupt_status to $update_all_status"
  diff -u <(printf 'chezmoi apply color=0\nbrew-update\n') "$update_all_log"
  test ! -e "$update_all_stamp"
done

# A complete success runs in order against the approved metadata snapshot and
# only then atomically writes a UTC timestamp. The Linux render must not carry
# the macOS cask policy, and it reports the OS-ownership boundary: distro
# packages on Linux, the Windows host on WSL2, are never Groundwork's to touch.
: >"$update_all_log"
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' HOMEBREW_COLOR='' \
  "$update_all_fixture/rendered-runner" >"$update_all_fixture/success-output" 2>&1
cat >"$update_all_fixture/expected-success" <<'EOF'
chezmoi apply color=0
brew-update
brew upgrade auto=1 casks=unset hb-color=unset
brew autoremove
brew cleanup
mise upgrade --minimum-release-age 5d
EOF
diff -u "$update_all_fixture/expected-success" "$update_all_log"
test -f "$update_all_stamp"
grep -qE '^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$' "$update_all_stamp"
update_all_temps=("${update_all_stamp}.tmp."*)
(( ${#update_all_temps[@]} == 0 )) || fail "update-all runner left a temporary timestamp behind"
grep -qF 'managed separately by your distribution' "$update_all_fixture/success-output"
: >"$update_all_log"
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' HOMEBREW_COLOR='' \
  FAKE_PLATFORM=wsl2 "$update_all_fixture/rendered-runner" \
  >"$update_all_fixture/wsl-success-output" 2>&1
diff -u "$update_all_fixture/expected-success" "$update_all_log"
grep -qF 'managed separately on the host' "$update_all_fixture/wsl-success-output"

# The run-wide color signal reaches the brew stages: with GROUNDWORK_COLOR=1
# the runner forces Homebrew's documented HOMEBREW_COLOR through any capture,
# and with the signal off (or NO_COLOR set and no signal) it forces nothing —
# redirecting the whole run to a file stays monochrome.
for runner_color_case in 'GROUNDWORK_COLOR=1 NO_COLOR= FORCE_COLOR=:1' \
  'GROUNDWORK_COLOR=0 NO_COLOR= FORCE_COLOR=:unset' \
  'GROUNDWORK_COLOR= NO_COLOR=1 FORCE_COLOR=:unset' \
  'GROUNDWORK_COLOR= NO_COLOR= FORCE_COLOR=1:1'; do
  runner_color_env="${runner_color_case%:*}"
  runner_color_expected="${runner_color_case#*:}"
  rm -f "$update_all_stamp"
  : >"$update_all_log"
  # shellcheck disable=SC2086
  env HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
    HOMEBREW_COLOR= $runner_color_env "$update_all_fixture/rendered-runner" >/dev/null 2>&1 \
    || fail "update-all runner failed under color settings: $runner_color_env"
  grep -qxF "brew upgrade auto=1 casks=unset hb-color=$runner_color_expected" "$update_all_log" \
    || fail "brew must see HOMEBREW_COLOR=$runner_color_expected under: $runner_color_env"
done

# A later mise failure leaves the previous timestamp untouched, proving it
# represents the whole transaction rather than Homebrew alone.
printf 'previous-success\n' >"$update_all_stamp"
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' HOMEBREW_COLOR='' \
  MISE_STATUS=1 "$update_all_fixture/rendered-runner" \
  >"$update_all_fixture/mise-failure-output" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -ne 0 ]] || fail "update-all runner recorded success after mise upgrade failed"
diff -u "$update_all_fixture/expected-success" "$update_all_log"
grep -qxF 'previous-success' "$update_all_stamp"

# The machine-side 5-day floor: mise must be age-gated in the normal path, the
# same policy the renovate-config preset applies to repo dependencies. An older
# mise without the flag still upgrades, but must say so rather than pretend.
grep -qF 'mise upgrade --minimum-release-age 5d' "$update_all_fixture/expected-success" \
  || fail "update-all must apply the 5-day release floor to mise upgrades"
# A mise that cannot enforce the floor must FAIL CLOSED: the runtime stage is
# skipped, the run exits nonzero, and no success timestamp is written. Do NOT
# "restore" an ungated fallback here — a policy that steps aside whenever it
# cannot be enforced is not a policy.
rm -f "$update_all_stamp"
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  MISE_HAS_RELEASE_AGE=0 "$update_all_fixture/rendered-runner" \
  >"$update_all_fixture/mise-old" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -ne 0 ]] \
  || fail "update-all succeeded on a mise that cannot enforce the 5-day release floor"
assert_not_contains '^mise upgrade$' "$update_all_log" \
  "update-all ran an UNGATED mise upgrade when the release floor was unavailable"
grep -qF 'cannot enforce the 5-day release floor' "$update_all_fixture/mise-old"
grep -qF 'brew upgrade mise' "$update_all_fixture/mise-old" \
  || fail "the mise floor refusal must say how to fix it"
test ! -e "$update_all_stamp" \
  || fail "update-all recorded success although the release floor was skipped"
rm -f "$update_all_stamp"

# macOS is the primary platform, so run the transaction against the darwin
# render too — not just grep it. The cask policy and the app relaunch only
# exist in that branch.
render darwin false arm64 home/dot_local/bin/executable_groundwork-update-run.tmpl \
  "$update_all_fixture/darwin-runner"
chmod +x "$update_all_fixture/darwin-runner"
cat >"$update_all_bin/groundwork-apps-start" <<'SH'
#!/usr/bin/env bash
printf 'apps-start\n' >>"$GROUNDWORK_TEST_LOG"
exit "${APPS_START_STATUS:-0}"
SH
chmod +x "$update_all_bin/groundwork-apps-start"
rm -f "$update_all_stamp"
: >"$update_all_log"
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' HOMEBREW_COLOR='' \
  FAKE_PLATFORM=darwin "$update_all_fixture/darwin-runner" \
  >"$update_all_fixture/darwin-success" 2>&1
cat >"$update_all_fixture/expected-darwin" <<'EOF'
chezmoi apply color=0
brew-update
brew upgrade --require-sha auto=1 casks=1 hb-color=unset
brew-repair
brew autoremove
brew cleanup
apps-start
mise upgrade --minimum-release-age 5d
EOF
diff -u "$update_all_fixture/expected-darwin" "$update_all_log"
test -f "$update_all_stamp"

# BEHAVIOR, not wiring text: a failed upgrade whose downloads re-fetch (exit
# 0 from refetch) is retried exactly once; a still-failing retry fails the
# run and writes no timestamp.
rm -f "$update_all_stamp"
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' HOMEBREW_COLOR='' \
  FAKE_PLATFORM=darwin BREW_STAGE_STATUS=1 REFETCH_STATUS=0 \
  "$update_all_fixture/darwin-runner" >"$update_all_fixture/darwin-refetch-retry" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -ne 0 ]] \
  || fail "a retried upgrade that still fails must fail the run"
[[ "$(grep -c '^brew upgrade --require-sha' "$update_all_log")" -eq 2 ]] \
  || fail "a successful re-fetch must retry the failed upgrade exactly once"
grep -qxF 'brew-refetch' "$update_all_log" \
  || fail "a failed upgrade must consult groundwork-brew-refetch"
test ! -e "$update_all_stamp"

# An APPROVED repair that failed (exit 3) must fail the run even though the
# upgrade itself exited 0 — a broken machine must never be reported updated.
rm -f "$update_all_stamp"
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' HOMEBREW_COLOR='' \
  FAKE_PLATFORM=darwin REPAIR_STATUS=3 \
  "$update_all_fixture/darwin-runner" >"$update_all_fixture/darwin-repair-fail" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -ne 0 ]] \
  || fail "a failed approved repair must fail the run, not be reported as success"
grep -qF 'did not complete' "$update_all_fixture/darwin-repair-fail" \
  || fail "a failed approved repair must be reported in the output"
test ! -e "$update_all_stamp"
# A failed app relaunch must not fail the refresh (it is best-effort), and a
# failed Homebrew stage must still stop everything after it.
rm -f "$update_all_stamp"
: >"$update_all_log"
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' HOMEBREW_COLOR='' \
  FAKE_PLATFORM=darwin APPS_START_STATUS=1 "$update_all_fixture/darwin-runner" \
  >"$update_all_fixture/darwin-apps-fail" 2>&1 \
  || fail "a failed app relaunch must not fail update-all (it is best-effort)"
diff -u "$update_all_fixture/expected-darwin" "$update_all_log"
test -f "$update_all_stamp"
rm -f "$update_all_stamp"
: >"$update_all_log"
set +e
HOME="$update_all_home" PATH="$update_all_path" GROUNDWORK_TEST_LOG="$update_all_log" \
  NO_COLOR='' FORCE_COLOR='' GROUNDWORK_COLOR='' \
  FAKE_PLATFORM=darwin BREW_UPDATE_STATUS=1 "$update_all_fixture/darwin-runner" \
  >"$update_all_fixture/darwin-brew-fail" 2>&1
update_all_status=$?
set -e
[[ "$update_all_status" -ne 0 ]] || fail "the darwin runner continued after its metadata refresh failed"
diff -u <(printf 'chezmoi apply color=0\nbrew-update\n') "$update_all_log"
test ! -e "$update_all_stamp"

check "update-all migration notice"
migration_home="$out_dir/update-all-migration-home"
migration_flag="$migration_home/.local/state/groundwork/update-all-migration-pending"
mkdir -p "$migration_home"
cat >"$migration_home/.zshrc" <<'EOF'
update-all() {
  echo old
}
EOF
HOME="$migration_home" /bin/bash home/run_once_before_07-update-all-command-migration.sh \
  >"$out_dir/update-all-migration-notice"
grep -qF 'moved update-all from an in-memory shell function' "$out_dir/update-all-migration-notice"
grep -qF "Run \`exec zsh\` once" "$out_dir/update-all-migration-notice"
test -f "$migration_flag"
# The end-of-apply reminder repeats the one required action after Homebrew
# output has scrolled the first notice away, then clears the flag so it
# never repeats.
# A noninteractive apply (piped/CI) cannot deliver the reminder to anyone, so
# it must print nothing and leave the flag pending for the next interactive run.
HOME="$migration_home" /bin/bash home/run_after_98-update-all-migration-reminder.sh \
  >"$out_dir/update-all-migration-noninteractive"
test ! -s "$out_dir/update-all-migration-noninteractive" \
  || fail "the migration reminder printed to a non-terminal"
test -f "$migration_flag" \
  || fail "a noninteractive apply consumed the migration reminder"
# Interactive: shown, then the flag is cleared so it never repeats.
HOME="$migration_home" GROUNDWORK_REMINDER_ASSUME_TTY=1 \
  /bin/bash home/run_after_98-update-all-migration-reminder.sh \
  >"$out_dir/update-all-migration-reminder"
grep -qF 'one step left' "$out_dir/update-all-migration-reminder"
grep -qF 'exec zsh' "$out_dir/update-all-migration-reminder"
test ! -e "$migration_flag"
HOME="$migration_home" GROUNDWORK_REMINDER_ASSUME_TTY=1 \
  /bin/bash home/run_after_98-update-all-migration-reminder.sh \
  >"$out_dir/update-all-migration-reminder-repeat"
test ! -s "$out_dir/update-all-migration-reminder-repeat"
# Color keys on the run-wide signal update-all exports, not on a per-stage
# TTY probe: with GROUNDWORK_COLOR=1 the reminder emits ANSI even though
# stdout is a file here; with it 0 (or NO_COLOR and no signal) it stays plain.
reminder_esc="$(printf '\033')"
: >"$migration_flag"
HOME="$migration_home" GROUNDWORK_REMINDER_ASSUME_TTY=1 GROUNDWORK_COLOR=1 \
  /bin/bash home/run_after_98-update-all-migration-reminder.sh \
  >"$out_dir/update-all-migration-color-on"
grep -qF "${reminder_esc}[1;33m" "$out_dir/update-all-migration-color-on" \
  || fail "the migration reminder must emit color when GROUNDWORK_COLOR=1, even behind a capture"
: >"$migration_flag"
HOME="$migration_home" GROUNDWORK_REMINDER_ASSUME_TTY=1 GROUNDWORK_COLOR=0 \
  /bin/bash home/run_after_98-update-all-migration-reminder.sh \
  >"$out_dir/update-all-migration-color-off"
grep -qF 'one step left' "$out_dir/update-all-migration-color-off"
assert_not_contains "$reminder_esc" "$out_dir/update-all-migration-color-off" \
  "the migration reminder emitted color although GROUNDWORK_COLOR=0"
: >"$migration_flag"
HOME="$migration_home" GROUNDWORK_REMINDER_ASSUME_TTY=1 NO_COLOR=1 GROUNDWORK_COLOR='' \
  /bin/bash home/run_after_98-update-all-migration-reminder.sh \
  >"$out_dir/update-all-migration-no-color"
assert_not_contains "$reminder_esc" "$out_dir/update-all-migration-no-color" \
  "the migration reminder emitted color although NO_COLOR was set and no signal decided otherwise"
printf '# fresh install has no old function\n' >"$migration_home/.zshrc"
HOME="$migration_home" /bin/bash home/run_once_before_07-update-all-command-migration.sh \
  >"$out_dir/update-all-fresh-notice"
test ! -s "$out_dir/update-all-fresh-notice"
test ! -e "$migration_flag"

check "platform support contract"
# groundwork-platform reports exactly darwin/linux/wsl2/wsl1/wsl-unknown/
# unsupported. Default WSL2 kernels carry microsoft-standard (older ones
# without any WSL2 suffix); WSL1 kernels say Microsoft without either; a WSL
# environment variable with an unrecognizable kernel is ambiguous and must
# come back wsl-unknown, never silently wsl2.
test -x home/dot_local/bin/executable_groundwork-platform
platform_fixture="$out_dir/platform-fixture"
mkdir -p "$platform_fixture/bin"
cat >"$platform_fixture/bin/uname" <<'SH'
#!/usr/bin/env bash
echo "$FAKE_UNAME"
SH
chmod +x "$platform_fixture/bin/uname"
printf '6.8.0-generic\n' >"$platform_fixture/osrelease-generic"
printf '5.15.167.4-microsoft-standard-WSL2\n' >"$platform_fixture/osrelease-wsl2"
printf '4.19.104-microsoft-standard\n' >"$platform_fixture/osrelease-wsl2-old"
printf '4.4.0-19041-Microsoft\n' >"$platform_fixture/osrelease-wsl1"
platform_cmd=(env -u WSL_INTEROP -u WSL_DISTRO_NAME PATH="$platform_fixture/bin:/usr/bin:/bin")
platform_result="$("${platform_cmd[@]}" FAKE_UNAME=Darwin home/dot_local/bin/executable_groundwork-platform)"
[[ "$platform_result" == "darwin" ]] || fail "groundwork-platform reported '$platform_result' for Darwin"
platform_result="$("${platform_cmd[@]}" FAKE_UNAME=Linux \
  GROUNDWORK_OSRELEASE_FILE="$platform_fixture/osrelease-generic" home/dot_local/bin/executable_groundwork-platform)"
[[ "$platform_result" == "linux" ]] || fail "groundwork-platform reported '$platform_result' for generic Linux"
platform_result="$("${platform_cmd[@]}" FAKE_UNAME=Linux \
  GROUNDWORK_OSRELEASE_FILE="$platform_fixture/osrelease-wsl2" home/dot_local/bin/executable_groundwork-platform)"
[[ "$platform_result" == "wsl2" ]] || fail "groundwork-platform missed the WSL2-suffixed kernel release"
platform_result="$("${platform_cmd[@]}" FAKE_UNAME=Linux \
  GROUNDWORK_OSRELEASE_FILE="$platform_fixture/osrelease-wsl2-old" home/dot_local/bin/executable_groundwork-platform)"
[[ "$platform_result" == "wsl2" ]] \
  || fail "groundwork-platform misclassified an older microsoft-standard WSL2 kernel as '$platform_result'"
platform_result="$("${platform_cmd[@]}" FAKE_UNAME=Linux \
  GROUNDWORK_OSRELEASE_FILE="$platform_fixture/osrelease-wsl1" home/dot_local/bin/executable_groundwork-platform)"
[[ "$platform_result" == "wsl1" ]] || fail "groundwork-platform must report unsupported WSL1 distinctly, got '$platform_result'"
platform_result="$("${platform_cmd[@]}" FAKE_UNAME=Linux WSL_INTEROP=/run/WSL/1_interop \
  GROUNDWORK_OSRELEASE_FILE="$platform_fixture/osrelease-generic" home/dot_local/bin/executable_groundwork-platform)"
[[ "$platform_result" == "wsl-unknown" ]] \
  || fail "an interop variable without a recognizable kernel must be wsl-unknown, got '$platform_result'"
platform_result="$("${platform_cmd[@]}" FAKE_UNAME=Linux WSL_DISTRO_NAME=Ubuntu \
  GROUNDWORK_OSRELEASE_FILE="$platform_fixture/osrelease-generic" home/dot_local/bin/executable_groundwork-platform)"
[[ "$platform_result" == "wsl-unknown" ]] \
  || fail "WSL_DISTRO_NAME without a recognizable kernel must be wsl-unknown, got '$platform_result'"
platform_result="$("${platform_cmd[@]}" FAKE_UNAME=MINGW64_NT-10.0 home/dot_local/bin/executable_groundwork-platform)"
[[ "$platform_result" == "unsupported" ]] || fail "groundwork-platform must report Git Bash/native Windows as unsupported"

# groundwork-distro reports the distribution ID verbatim (a derivative is
# itself, not its parent) and --family reports the bootstrap-prerequisite
# family from ID/ID_LIKE; platform and distro are separate dimensions, and
# only bootstrap prerequisites may branch on the family.
test -x home/dot_local/bin/executable_groundwork-distro
for distro_case in 'ubuntu:ubuntu' 'debian:debian' 'linuxmint:linuxmint' 'gentoo:gentoo'; do
  distro_id="${distro_case%%:*}"
  distro_expected="${distro_case#*:}"
  printf 'ID=%s\nNAME="Fixture"\n' "$distro_id" >"$platform_fixture/os-release"
  distro_result="$(GROUNDWORK_OS_RELEASE_FILE="$platform_fixture/os-release" \
    /bin/bash home/dot_local/bin/executable_groundwork-distro)"
  [[ "$distro_result" == "$distro_expected" ]] \
    || fail "groundwork-distro reported '$distro_result' for ID=$distro_id (expected $distro_expected)"
done
for family_case in 'ubuntu::debian' 'debian::debian' 'linuxmint:ubuntu debian:debian' \
  'pop:ubuntu debian:debian' 'fedora::fedora' 'centos:rhel fedora:fedora' 'arch::arch' \
  'manjaro:arch:arch' 'opensuse-leap:suse opensuse:opensuse' 'gentoo::unknown'; do
  IFS=':' read -r family_id family_like family_expected <<<"$family_case"
  {
    printf 'ID=%s\n' "$family_id"
    [[ -n "$family_like" ]] && printf 'ID_LIKE="%s"\n' "$family_like"
  } >"$platform_fixture/os-release"
  distro_result="$(GROUNDWORK_OS_RELEASE_FILE="$platform_fixture/os-release" \
    /bin/bash home/dot_local/bin/executable_groundwork-distro --family)"
  [[ "$distro_result" == "$family_expected" ]] \
    || fail "groundwork-distro --family reported '$distro_result' for ID=$family_id ID_LIKE='$family_like' (expected $family_expected)"
done
for distro_mode in '' '--family'; do
  distro_result="$(GROUNDWORK_OS_RELEASE_FILE="$platform_fixture/missing-os-release" \
    /bin/bash home/dot_local/bin/executable_groundwork-distro $distro_mode)"
  [[ "$distro_result" == "unknown" ]] || fail "groundwork-distro $distro_mode must report unknown without /etc/os-release"
done

# Native Windows fails closed at the entry point with WSL2 guidance instead of
# rendering a partial configuration.
if chezmoi --config "$empty_config" --source "$PWD" --destination "$out_dir/home" \
  --override-data '{"chezmoi":{"os":"windows","arch":"amd64"}}' \
  execute-template --init < home/.chezmoi.toml.tmpl >"$out_dir/windows-init" 2>&1; then
  fail "chezmoi config template rendered on native Windows instead of failing closed"
fi
grep -qF 'requires macOS, Linux, or WSL2' "$out_dir/windows-init"
grep -qF 'install WSL2 with Ubuntu' "$out_dir/windows-init"

# WSL1 fails closed at the entry point with conversion instructions; a WSL2
# kernel renders past the guard.
if chezmoi --config "$empty_config" --source "$PWD" --destination "$out_dir/home" \
  --override-data '{"chezmoi":{"os":"linux","arch":"amd64","kernel":{"osrelease":"4.4.0-19041-Microsoft"}}}' \
  execute-template --init < home/.chezmoi.toml.tmpl >"$out_dir/wsl1-init" 2>&1; then
  fail "chezmoi config template rendered on WSL1 instead of failing closed"
fi
grep -qF 'supports WSL2, not WSL1' "$out_dir/wsl1-init"
grep -qF 'wsl --set-version' "$out_dir/wsl1-init"
chezmoi --config "$empty_config" --source "$PWD" --destination "$out_dir/home" \
  --override-data '{"chezmoi":{"os":"linux","arch":"amd64","kernel":{"osrelease":"5.15.167.4-microsoft-standard-WSL2"}}}' \
  execute-template --init \
  --promptBool work=false,headless=true,reset_existing_configs=false,game_dev=false,xcode=false \
  --promptString name=Test,email_personal=test@example.com,email_work=,code_dir=~/code,signingkey=,obsidian_vault_name= \
  --promptChoice password_manager=none \
  < home/.chezmoi.toml.tmpl >"$out_dir/wsl2-init" 2>&1 \
  || fail "chezmoi config template must render on a WSL2 kernel"
grep -qF 'sourceDir' "$out_dir/wsl2-init"
# Older WSL2 kernels carry microsoft-standard without any WSL2 suffix and are
# valid WSL2 installations; they must render, not fail as WSL1.
chezmoi --config "$empty_config" --source "$PWD" --destination "$out_dir/home" \
  --override-data '{"chezmoi":{"os":"linux","arch":"amd64","kernel":{"osrelease":"4.19.104-microsoft-standard"}}}' \
  execute-template --init \
  --promptBool work=false,headless=true,reset_existing_configs=false,game_dev=false,xcode=false \
  --promptString name=Test,email_personal=test@example.com,email_work=,code_dir=~/code,signingkey=,obsidian_vault_name= \
  --promptChoice password_manager=none \
  < home/.chezmoi.toml.tmpl >"$out_dir/wsl2-old-init" 2>&1 \
  || fail "chezmoi config template must render on an older microsoft-standard WSL2 kernel"
grep -qF 'sourceDir' "$out_dir/wsl2-old-init"

# On WSL2, new-project refuses Windows-mounted drives; repositories belong in
# the WSL Linux filesystem.
# new-project resolves the helper absolutely (a stripped PATH must not make the
# guard fail open), so the fixture supplies it through HOME.
wsl_home="$out_dir/wsl-home"
mkdir -p "$wsl_home/.local/bin"
cat >"$wsl_home/.local/bin/groundwork-platform" <<'SH'
#!/usr/bin/env bash
echo wsl2
SH
chmod +x "$wsl_home/.local/bin/groundwork-platform"
set +e
HOME="$wsl_home" PATH="/usr/bin:/bin" /bin/bash home/dot_local/bin/executable_new-project /mnt/c/demo \
  >"$out_dir/new-project-mnt" 2>&1
mnt_status=$?
set -e
[[ "$mnt_status" -ne 0 ]] || fail "new-project accepted a repository on a Windows-mounted drive under WSL"
grep -qF 'Windows-mounted drive' "$out_dir/new-project-mnt"
test ! -e /mnt/c/demo
# A relative path that traverses to the mount is canonicalized and rejected
# too — the guard is not purely lexical on the argument.
groundwork_repo_root="$PWD"
set +e
(cd /usr/bin && HOME="$wsl_home" PATH="/usr/bin:/bin" \
  /bin/bash "$groundwork_repo_root/home/dot_local/bin/executable_new-project" ../../mnt/c/demo) \
  >"$out_dir/new-project-mnt-relative" 2>&1
mnt_status=$?
set -e
[[ "$mnt_status" -ne 0 ]] || fail "new-project accepted a relative path traversing into /mnt under WSL"
grep -qF 'Windows-mounted drive' "$out_dir/new-project-mnt-relative"
# A normal Linux-filesystem project still scaffolds under WSL.
HOME="$wsl_home" PATH="/usr/bin:/bin" /bin/bash home/dot_local/bin/executable_new-project \
  "$wsl_home/wsl-ok-project" >"$out_dir/new-project-wsl-ok" 2>&1 \
  || fail "new-project refused a Linux-filesystem path under WSL"
test -f "$wsl_home/wsl-ok-project/AGENTS.md"

# The Linux/WSL2 runner never carries the macOS cask policy; casks are a
# macOS concern (the darwin render is asserted in the beta channel profile).
grep -qF 'HOMEBREW_NO_AUTO_UPDATE=1 brew upgrade' "$update_all_fixture/rendered-runner"
assert_not_contains 'HOMEBREW_NO_UPGRADE_AUTO_UPDATES_CASKS' "$update_all_fixture/rendered-runner" \
  "macOS cask upgrade policy leaked into the Linux update runner"
assert_not_contains '^[^#]*brew upgrade[^#]*--greedy' "$update_all_fixture/rendered-runner" \
  "a --greedy cask flag leaked into the Linux update runner"

check "setup prompt wording"
# chezmoi renders its own hint under every prompt ("> bool, default false") and
# appends its own "?" to the prompt text. So a hand-written [y/N] duplicates the
# type hint, and trailing punctuation renders as "??" or ".?".
assert_no_matches "setup prompts must not hand-write [y/N]; chezmoi already shows 'bool, default <x>'" \
  rg -n '\[y/N\]|\[Y/n\]' home/.chezmoi.toml.tmpl
prompt_texts="$(rg --no-config -o 'prompt(Bool|String|Choice)Once \. "[^"]+" "[^"]+"' home/.chezmoi.toml.tmpl \
  | sed -E 's/.*" "([^"]+)"$/\1/')"
while IFS= read -r prompt_text; do
  [[ -n "$prompt_text" ]] || continue
  case "$prompt_text" in
    *\?*)
      fail "setup prompt must not contain '?' anywhere (chezmoi appends the '?'; phrase it as one question with no internal question mark): $prompt_text"
      ;;
    *[.!])
      fail "setup prompt must not end with punctuation (chezmoi appends its own '?', giving '??' or '.?'): $prompt_text"
      ;;
  esac
done <<<"$prompt_texts"

# Every yes/no question carries its own affordance and names its default,
# because chezmoi's only hint is a dim 'bool, default false' placeholder that
# reads as "type true or false" — the exact confusion behind "do I hit yN or
# tF?". The named default must match the literal default argument, so the two
# can never drift apart (the Linux headless prompt is two literal prompts for
# exactly this reason).
# --no-config: a user ripgrep config with max-columns would silently truncate
# these long prompt lines and make the checks pass or fail on elided text.
bool_prompts="$(rg --no-config -o 'promptBoolOnce \. "[^"]+" "[^"]+" (true|false)' home/.chezmoi.toml.tmpl)"
[[ -n "$bool_prompts" ]] || fail "no promptBoolOnce prompts found to check in home/.chezmoi.toml.tmpl"
while IFS= read -r bool_prompt; do
  [[ -n "$bool_prompt" ]] || continue
  bool_default="${bool_prompt##* }"
  bool_text="$(sed -E 's/.*" "([^"]+)" (true|false)$/\1/' <<<"$bool_prompt")"
  bool_named="no"
  [[ "$bool_default" == "true" ]] && bool_named="yes"
  [[ "$bool_text" == *"Enter keeps the default: $bool_named)" ]] \
    || fail "every bool setup prompt must end by naming its real default ('... Enter keeps the default: $bool_named)'): $bool_prompt"
  [[ "$bool_text" == *"y/t"*"n/f"* ]] \
    || fail "every bool setup prompt must show the accepted answers (y/t ... n/f ...): $bool_prompt"
done <<<"$bool_prompts"

# The Chrome question follows the agreed shape: the checksum consequence as
# plain prose first, then one short question that carries the affordance.
grep -qF 'Install Google Chrome anyway (y/t installs, n/f skips; Enter keeps the default: no)' home/.chezmoi.toml.tmpl \
  || fail "the Chrome opt-in must end with the short affordance question: 'Install Google Chrome anyway (y/t installs, n/f skips; Enter keeps the default: no)'"
grep -qF "Google's Chrome cask ships without a checksum" home/.chezmoi.toml.tmpl \
  || fail "the Chrome opt-in must lead with the checksum consequence as plain prose"

# Regex over the template proves the source, not the UI. Drive a real
# `chezmoi init` in a real terminal and assert the rendered prompt: chezmoi
# appends its own "?" and its own "> bool, default false" hint, so a stray
# "[y/N]" or trailing punctuation shows up as "[y/N]?" / "??" only here.
if command -v tmux >/dev/null 2>&1; then
  prompt_socket="groundwork-prompt-$$"
  prompt_dir="$out_dir/prompt-render"
  mkdir -p "$prompt_dir/home" "$prompt_dir/src"
  cp home/.chezmoi.toml.tmpl "$prompt_dir/src/.chezmoi.toml.tmpl"
  tmux -L "$prompt_socket" new-session -d -x 120 -y 24 -c "$prompt_dir" /bin/sh
  # HOME alone does not isolate chezmoi: Groundwork exports XDG_CONFIG_HOME,
  # and chezmoi reads its config from there first, so the machine's real saved
  # answers would silently satisfy every promptOnce and no prompt would render
  # — and worse, `chezmoi init` would REGENERATE the real config pointing at
  # the scratch source (this happened; see the sentinel below). Every XDG dir
  # is scoped into the fixture home.
  real_chezmoi_config="${XDG_CONFIG_HOME:-$HOME/.config}/chezmoi/chezmoi.toml"
  real_config_before="none"
  [[ ! -f "$real_chezmoi_config" ]] || real_config_before="$(cksum <"$real_chezmoi_config")"
  tmux -L "$prompt_socket" send-keys \
    "HOME=$prompt_dir/home XDG_CONFIG_HOME=$prompt_dir/home/.config XDG_DATA_HOME=$prompt_dir/home/.local/share XDG_STATE_HOME=$prompt_dir/home/.local/state XDG_CACHE_HOME=$prompt_dir/home/.cache chezmoi init --source $prompt_dir/src" Enter
  prompt_rendered=""
  for _ in $(seq 1 50); do
    prompt_rendered="$(tmux -L "$prompt_socket" capture-pane -p 2>/dev/null || true)"
    grep -qF 'bool, default' <<<"$prompt_rendered" && break
    sleep 0.2
  done
  tmux -L "$prompt_socket" kill-server 2>/dev/null || true
  grep -qF 'bool, default' <<<"$prompt_rendered" \
    || fail "chezmoi init never rendered a prompt (cannot verify the setup UI)"
  grep -qF 'Is this a work machine (y/t = yes, n/f = no; Enter keeps the default: no)?' <<<"$prompt_rendered" \
    || fail "the first setup prompt did not render with its answer affordance and named default"
  if grep -qE '\?\?|\.\?|\[y/N\]|\[Y/n\]' <<<"$prompt_rendered"; then
    printf '%s\n' "$prompt_rendered" >&2
    fail "the rendered setup prompt has doubled punctuation or a hand-written [y/N] (chezmoi adds its own '?' and 'bool, default <x>' hint)"
  fi
  # Sentinel: validation must NEVER touch the machine's real chezmoi config.
  # An earlier version of this check leaked through XDG_CONFIG_HOME and
  # rewrote the real config to point at the scratch source; this assertion
  # makes that class of regression fail loudly instead of corrupting state.
  real_config_after="none"
  [[ ! -f "$real_chezmoi_config" ]] || real_config_after="$(cksum <"$real_chezmoi_config")"
  [[ "$real_config_before" == "$real_config_after" ]] \
    || fail "the setup-UI check MUTATED the real chezmoi config at $real_chezmoi_config — its isolation is broken"
fi

check "shell prompt convention (bootstrap and brew repair)"
# Groundwork's own shell prompts follow one convention: a bracketed affordance
# with the default capitalized, a blocking read on the controlling terminal
# even when stdin is a pipe (curl | bash), Enter takes the default, and a run
# with no terminal at all takes the default and says so. The seams
# (GROUNDWORK_BOOTSTRAP_SELFTEST, GROUNDWORK_PROMPT_TTY) let this drive the
# real helpers without a real terminal.
grep -qF '[KEEP/switch/login]' bootstrap-mac.sh \
  || fail "the bootstrap GitHub prompt must keep its bracketed affordance with the capitalized default"
prompt_fixture="$out_dir/prompt-fixture"
mkdir -p "$prompt_fixture/bin"
# 1. No terminal anywhere: the default is taken and announced, not silent.
printf '' | GROUNDWORK_BOOTSTRAP_SELFTEST=prompt GROUNDWORK_PROMPT_TTY=/nonexistent-groundwork-tty \
  /bin/bash bootstrap-mac.sh "GitHub account choice [KEEP/switch/login]: " keep \
  >"$prompt_fixture/no-tty-out" 2>"$prompt_fixture/no-tty-err" \
  || fail "the bootstrap prompt helper failed outright without a terminal"
grep -qxF 'keep' "$prompt_fixture/no-tty-out" \
  || fail "without any terminal the bootstrap prompt must return the default"
grep -qF 'no terminal' "$prompt_fixture/no-tty-err" \
  || fail "without any terminal the bootstrap prompt must say it has no terminal"
grep -qF 'defaulting to "keep"' "$prompt_fixture/no-tty-err" \
  || fail "without any terminal the bootstrap prompt must name the default it takes"
# 2. Enter takes the default (the controlling-terminal seam delivers a bare newline).
printf '\n' >"$prompt_fixture/tty-enter"
printf '' | GROUNDWORK_BOOTSTRAP_SELFTEST=prompt GROUNDWORK_PROMPT_TTY="$prompt_fixture/tty-enter" \
  /bin/bash bootstrap-mac.sh "GitHub account choice [KEEP/switch/login]: " keep \
  >"$prompt_fixture/enter-out" 2>/dev/null \
  || fail "the bootstrap prompt helper failed on a bare Enter"
grep -qxF 'keep' "$prompt_fixture/enter-out" \
  || fail "a bare Enter must take the prompt default"
# 3. A typed answer on the controlling terminal wins even when stdin is a pipe.
printf 'switch\n' >"$prompt_fixture/tty-switch"
printf '' | GROUNDWORK_BOOTSTRAP_SELFTEST=prompt GROUNDWORK_PROMPT_TTY="$prompt_fixture/tty-switch" \
  /bin/bash bootstrap-mac.sh "GitHub account choice [KEEP/switch/login]: " keep \
  >"$prompt_fixture/switch-out" 2>/dev/null \
  || fail "the bootstrap prompt helper failed reading the controlling terminal"
grep -qxF 'switch' "$prompt_fixture/switch-out" \
  || fail "an answer typed on the controlling terminal must win over the default"

# groundwork-brew-repair keeps the same convention around its [y/N] gate.
cat >"$prompt_fixture/bin/brew" <<'SH'
#!/usr/bin/env bash
if [[ "${1:-}" == "fetch" ]]; then
  printf 'brew %s conc=%s\n' "$*" "${HOMEBREW_DOWNLOAD_CONCURRENCY:-unset}" >>"$GROUNDWORK_TEST_LOG"
else
  printf 'brew %s\n' "$*" >>"$GROUNDWORK_TEST_LOG"
fi
exit "${GROUNDWORK_TEST_BREW_STATUS:-0}"
SH
chmod +x "$prompt_fixture/bin/brew"
repair_log="$prompt_fixture/bundle.log"
cat >"$repair_log" <<'EOF'
Error: some formula is in a known-broken state
Please run the following commands and try again:
  brew update
EOF
repair_cmd_log="$prompt_fixture/repair-commands.log"
# No terminal: default N (skip), said explicitly, exit nonzero, nothing runs.
: >"$repair_cmd_log"
set +e
printf '' | env PATH="$prompt_fixture/bin:/usr/bin:/bin" GROUNDWORK_TEST_LOG="$repair_cmd_log" \
  GROUNDWORK_PROMPT_TTY=/nonexistent-groundwork-tty \
  /bin/bash home/dot_local/bin/executable_groundwork-brew-repair "$repair_log" \
  >"$prompt_fixture/repair-no-tty" 2>&1
repair_status=$?
set -e
[[ "$repair_status" -eq 2 ]] \
  || fail "brew-repair without a terminal must exit 2 (declined), got $repair_status"
grep -qF 'no terminal; defaulting to N (skip)' "$prompt_fixture/repair-no-tty" \
  || fail "brew-repair must name the default it takes when no terminal exists"
test ! -s "$repair_cmd_log" || fail "brew-repair ran commands without consent"
# Enter takes the default: N (skip).
printf '\n' >"$prompt_fixture/tty-repair-enter"
: >"$repair_cmd_log"
set +e
printf '' | env PATH="$prompt_fixture/bin:/usr/bin:/bin" GROUNDWORK_TEST_LOG="$repair_cmd_log" \
  GROUNDWORK_PROMPT_TTY="$prompt_fixture/tty-repair-enter" \
  /bin/bash home/dot_local/bin/executable_groundwork-brew-repair "$repair_log" \
  >"$prompt_fixture/repair-enter" 2>&1
repair_status=$?
set -e
[[ "$repair_status" -eq 2 ]] \
  || fail "a bare Enter must take the [y/N] default and exit 2 (declined), got $repair_status"
grep -qF 'skipped' "$prompt_fixture/repair-enter"
test ! -s "$repair_cmd_log" || fail "brew-repair ran commands on a bare Enter"
# y on the controlling terminal runs exactly the suggested commands — and the
# log may carry ANSI color now that update-all forces brew color through the
# tee, so the colored variant must parse identically.
repair_esc="$(printf '\033')"
printf '%s[31mError:%s[0m some formula is in a known-broken state\nPlease run the following commands and try again:\n  brew update\n' \
  "$repair_esc" "$repair_esc" >"$prompt_fixture/bundle-colored.log"
printf 'y\n' >"$prompt_fixture/tty-repair-yes"
for repair_variant in "$repair_log" "$prompt_fixture/bundle-colored.log"; do
  : >"$repair_cmd_log"
  printf '' | env PATH="$prompt_fixture/bin:/usr/bin:/bin" GROUNDWORK_TEST_LOG="$repair_cmd_log" \
    GROUNDWORK_PROMPT_TTY="$prompt_fixture/tty-repair-yes" \
    /bin/bash home/dot_local/bin/executable_groundwork-brew-repair "$repair_variant" \
    >"$prompt_fixture/repair-yes" 2>&1 \
    || fail "brew-repair must succeed after consent on $repair_variant"
  grep -qxF 'brew update' "$repair_cmd_log" \
    || fail "brew-repair must run exactly the suggested command from $repair_variant"
done
# The per-cask "cannot be upgraded as-is" warning is the second remediation
# shape Homebrew prints. It does NOT fail the run, so unhandled it repeats on
# every refresh forever; repeated warnings must dedupe to one command.
cat >"$prompt_fixture/cask-warning.log" <<'EOF'
Warning: The cask 'dotnet-sdk' cannot be upgraded as-is. To fix this, run:
  brew reinstall --cask --force dotnet-sdk
==> Upgraded 3 outdated packages
Warning: The cask 'dotnet-sdk' cannot be upgraded as-is. To fix this, run:
  brew reinstall --cask --force dotnet-sdk
EOF
: >"$repair_cmd_log"
printf '' | env PATH="$prompt_fixture/bin:/usr/bin:/bin" GROUNDWORK_TEST_LOG="$repair_cmd_log" \
  GROUNDWORK_PROMPT_TTY="$prompt_fixture/tty-repair-yes" \
  /bin/bash home/dot_local/bin/executable_groundwork-brew-repair "$prompt_fixture/cask-warning.log" \
  >"$prompt_fixture/repair-cask" 2>&1 \
  || fail "brew-repair must handle the cask cannot-be-upgraded-as-is warning"
diff -u <(printf 'brew reinstall --cask --force dotnet-sdk\n') "$repair_cmd_log" \
  || fail "brew-repair must run the deduplicated cask fix exactly once"
# An APPROVED repair whose command fails must exit 3 — callers must be able
# to tell "the fix you consented to failed" apart from "nothing to do", or a
# broken machine gets reported as a successful update.
set +e
printf '' | env PATH="$prompt_fixture/bin:/usr/bin:/bin" GROUNDWORK_TEST_LOG="$repair_cmd_log" \
  GROUNDWORK_TEST_BREW_STATUS=1 GROUNDWORK_PROMPT_TTY="$prompt_fixture/tty-repair-yes" \
  /bin/bash home/dot_local/bin/executable_groundwork-brew-repair "$repair_log" \
  >"$prompt_fixture/repair-failed" 2>&1
repair_status=$?
set -e
[[ "$repair_status" -eq 3 ]] \
  || fail "an approved repair that failed must exit 3 (attempted and failed), got $repair_status"
grep -qF 'FAILED at' "$prompt_fixture/repair-failed" \
  || fail "a failed approved repair must say which command failed"
# A recognized marker whose suggested command is not a plain brew invocation
# must exit 4 and run NOTHING.
cat >"$prompt_fixture/malformed.log" <<'EOF'
Please run the following commands and try again:
  rm -rf /somewhere
EOF
: >"$repair_cmd_log"
set +e
printf '' | env PATH="$prompt_fixture/bin:/usr/bin:/bin" GROUNDWORK_TEST_LOG="$repair_cmd_log" \
  GROUNDWORK_PROMPT_TTY="$prompt_fixture/tty-repair-yes" \
  /bin/bash home/dot_local/bin/executable_groundwork-brew-repair "$prompt_fixture/malformed.log" \
  >/dev/null 2>&1
repair_status=$?
set -e
[[ "$repair_status" -eq 4 ]] \
  || fail "a non-brew suggestion must exit 4 (malformed), got $repair_status"
test ! -s "$repair_cmd_log" || fail "brew-repair ran a command from a malformed suggestion"

# groundwork-brew-refetch: curl's ordinary --retry does not cover the
# curl-92 stream errors from the field transcript, so failed downloads get a
# targeted, serial re-fetch — and ONLY the failed ones.
cat >"$prompt_fixture/refetch.log" <<'EOF'
✘ Cask chatgpt (26.715.31925)
Error: Download failed on Cask 'chatgpt' with message: curl: (92) HTTP/2 stream 1 was not closed cleanly: PROTOCOL_ERROR (err 1)
✔︎ Cask zed (1.11.3)
✘ Cask whatsapp (26.28.22)
✘ Bottle atuin (18.17.1)
EOF
: >"$repair_cmd_log"
env PATH="$prompt_fixture/bin:/usr/bin:/bin" GROUNDWORK_TEST_LOG="$repair_cmd_log" \
  /bin/bash home/dot_local/bin/executable_groundwork-brew-refetch "$prompt_fixture/refetch.log" \
  >/dev/null 2>&1 \
  || fail "brew-refetch must exit 0 when every failed download re-fetches"
diff -u <(printf 'brew fetch --retry --cask chatgpt conc=1\nbrew fetch --retry --cask whatsapp conc=1\nbrew fetch --retry --formula atuin conc=1\n') "$repair_cmd_log" \
  || fail "brew-refetch must re-fetch exactly the failed artifacts, serially (concurrency 1)"
printf 'everything succeeded\n' >"$prompt_fixture/refetch-clean.log"
set +e
env PATH="$prompt_fixture/bin:/usr/bin:/bin" GROUNDWORK_TEST_LOG="$repair_cmd_log" \
  /bin/bash home/dot_local/bin/executable_groundwork-brew-refetch "$prompt_fixture/refetch-clean.log" \
  >/dev/null 2>&1
repair_status=$?
set -e
[[ "$repair_status" -eq 1 ]] \
  || fail "brew-refetch with no failed downloads must exit 1, got $repair_status"
set +e
env PATH="$prompt_fixture/bin:/usr/bin:/bin" GROUNDWORK_TEST_LOG="$repair_cmd_log" \
  GROUNDWORK_TEST_BREW_STATUS=1 \
  /bin/bash home/dot_local/bin/executable_groundwork-brew-refetch "$prompt_fixture/refetch.log" \
  >/dev/null 2>&1
repair_status=$?
set -e
[[ "$repair_status" -eq 2 ]] \
  || fail "brew-refetch must exit 2 when a re-fetch still fails, got $repair_status"
# Both brew stages feed the repair helper their logs and retry curl on
# transient CDN stream errors; losing either wiring brings back the
# repeats-forever cask warning and the one-shot download failures.
grep -qF 'HOMEBREW_CURL_RETRIES=3' home/run_onchange_after_10-brew-bundle.sh.tmpl \
  || fail "the brew bundle hook must export HOMEBREW_CURL_RETRIES"
grep -qF 'HOMEBREW_CURL_RETRIES=3' home/dot_local/bin/executable_groundwork-update-run.tmpl \
  || fail "the update runner must export HOMEBREW_CURL_RETRIES"
grep -qF "groundwork-brew-repair\" \"\$upgrade_log\"" home/dot_local/bin/executable_groundwork-update-run.tmpl \
  || fail "the update runner must feed the brew upgrade log to groundwork-brew-repair"
grep -qF "groundwork-brew-repair\" \"\$bundle_log\"" home/run_onchange_after_10-brew-bundle.sh.tmpl \
  || fail "the brew bundle hook must feed the bundle log to groundwork-brew-repair"
grep -qF "groundwork-brew-refetch\" \"\$upgrade_log\"" home/dot_local/bin/executable_groundwork-update-run.tmpl \
  || fail "the update runner must feed failed downloads to groundwork-brew-refetch"
grep -qF "groundwork-brew-refetch\" \"\$bundle_log\"" home/run_onchange_after_10-brew-bundle.sh.tmpl \
  || fail "the brew bundle hook must feed failed downloads to groundwork-brew-refetch"
# Both callers must treat repair exit 3 (approved but FAILED) as a failure —
# never fold it into "nothing to do".
grep -qF "\"\$repair_status\" -eq 3" home/dot_local/bin/executable_groundwork-update-run.tmpl \
  || fail "the update runner must handle repair exit 3 (approved repair failed)"
grep -qF "\"\$repair_status\" -eq 3" home/run_onchange_after_10-brew-bundle.sh.tmpl \
  || fail "the brew bundle hook must handle repair exit 3 (approved repair failed)"

check "Homebrew cask policy (rendered installer behavior)"
# The NETWORK audit (scripts/audit-brew-casks) owns upstream cask metadata.
# THIS owns Groundwork's own installer behavior, offline and deterministically —
# a substring grep for "install_chrome" would pass on a comment.
chrome_off="$out_dir/brew-bundle-chrome-off"
chrome_on="$out_dir/brew-bundle-chrome-on"
render_chrome() {
  chezmoi --config "$empty_config" --source "$PWD" --destination "$out_dir/home" \
    --override-data "{${base_data},\"work\":false,\"headless\":false,\"xcode\":false,\"beta\":false,\"install_chrome\":$1,\"chezmoi\":{\"os\":\"darwin\",\"arch\":\"arm64\"}}" \
    execute-template <home/run_onchange_after_10-brew-bundle.sh.tmpl >"$2"
}
render_chrome false "$chrome_off"
render_chrome true "$chrome_on"
/bin/bash -n "$chrome_on"
# Consent: no approval, no unchecked install. Anywhere.
assert_not_contains 'brew install --cask google-chrome' "$chrome_off" \
  "google-chrome is installed without the setup consent that gates it"
# Approved: exactly one install, and the safe lane's checksum policy is applied.
[[ "$(grep -c 'brew install --cask google-chrome' "$chrome_on")" -eq 1 ]] \
  || fail "the approved Chrome path must contain exactly one install command"
grep -qF "HOMEBREW_CASK_OPTS=\"\$safe_cask_opts\"" "$chrome_on" \
  || fail "brew bundle must run under the --require-sha cask policy"
grep -qF -- '--require-sha' "$chrome_on"
# The tee to the bundle log makes brew see a pipe; color must key on the
# run-wide GROUNDWORK_COLOR signal (with a TTY fallback for a direct apply)
# and force Homebrew's documented HOMEBREW_COLOR when it is on.
grep -qF 'GROUNDWORK_COLOR' "$chrome_on" \
  || fail "the brew bundle stage must key color on the run-wide GROUNDWORK_COLOR signal, not its own piped stdout"
grep -qF 'export HOMEBREW_COLOR=1' "$chrome_on" \
  || fail "the brew bundle stage must force HOMEBREW_COLOR through the tee when the color signal is on"
# The user's own cask options are preserved, never replaced.
grep -qF "user_cask_opts=\"\${HOMEBREW_CASK_OPTS-}\"" "$chrome_on" \
  || fail "the user's HOMEBREW_CASK_OPTS must be preserved, not overwritten"
grep -qF "HOMEBREW_CASK_OPTS=\"\$user_cask_opts\" brew install --cask google-chrome" "$chrome_on" \
  || fail "the Chrome exception must run under the USER's cask options"
# Ordering: a failed safe lane must never reach the unsafe exception lane.
chrome_exit_line="$(grep -n "exit \"\$bundle_status\"" "$chrome_on" | head -n 1 | cut -d: -f1)"
chrome_install_line="$(grep -n 'brew install --cask google-chrome' "$chrome_on" | head -n 1 | cut -d: -f1)"
((chrome_exit_line < chrome_install_line)) \
  || fail "google-chrome is installed BEFORE the bundle-failure exit — a failed safe lane must not trigger the unsafe lane"
# A conflicting user policy is a real failure, not a silent skip that never retries.
grep -qF 'exit 1' "$chrome_on"
grep -qF 'this apply is incomplete' "$chrome_on" \
  || fail "a user --require-sha policy vs install_chrome=true must fail explicitly, not disappear"
# Chrome must never be in the Brewfile itself: it would fail the --require-sha
# bundle, and admitting it would hand every new machine an unverified artifact.
for chrome_profile in 'false false' 'true false' 'false true'; do
  read -r chrome_work chrome_game <<<"$chrome_profile"
  render darwin false arm64 home/dot_config/homebrew/Brewfile.tmpl \
    "$out_dir/brewfile-chrome-$chrome_work-$chrome_game" "$chrome_work"
  assert_not_contains '^cask "google-chrome"' "$out_dir/brewfile-chrome-$chrome_work-$chrome_game" \
    "google-chrome is in the Brewfile (work=$chrome_work) — it ships no checksum and would fail the --require-sha bundle"
done

check "runtime release-age reporting"
# A cooldown filters what you ACQUIRE; it never rolls back what is already
# installed. Nothing else surfaces a runtime adopted inside the floor, so this
# check must actually fire — and it must read the release date from the tool's
# backend, NOT from mise's upgrade warning, which only appears when mise's
# version cache happens to be cold (a check that passes by luck is not a check).
grep -qF 'GROUNDWORK_RELEASE_FLOOR' home/dot_local/bin/executable_groundwork-doctor
assert_no_matches "the runtime age check must not depend on mise's cache-dependent upgrade warning" \
  rg -n 'minimum_release_age' home/dot_local/bin/executable_groundwork-doctor
# The doctor's floor and the floor update-all enforces must agree.
grep -qF -- '--minimum-release-age 5d' home/dot_local/bin/executable_groundwork-update-run.tmpl
grep -qF 'GROUNDWORK_RELEASE_FLOOR:-5d' home/dot_local/bin/executable_groundwork-doctor \
  || fail "groundwork-doctor's release floor must match the 5d floor update-all enforces"

runtime_fixture="$out_dir/runtime-fixture"
mkdir -p "$runtime_fixture/bin"
cat >"$runtime_fixture/bin/mise" <<'SH'
#!/usr/bin/env bash
if [[ "$1" == "upgrade" && "$2" == "--help" ]]; then
  echo "      --minimum-release-age <MINIMUM_RELEASE_AGE>"
  exit 0
fi
if [[ "$1" == "ls" ]]; then
  printf '%s\n' "$GROUNDWORK_TEST_MISE_JSON"
fi
SH
chmod +x "$runtime_fixture/bin/mise"
# A version released two days ago must be flagged, with the remedy named.
runtime_recent="$(jq -rn '(now - (2 * 86400)) | todateiso8601')"
cat >"$runtime_fixture/bin/curl" <<SH
#!/usr/bin/env bash
printf '{"time":{"9.9.9":"%s"}}\n' "$runtime_recent"
SH
chmod +x "$runtime_fixture/bin/curl"
PATH="$runtime_fixture/bin:$PATH" \
  GROUNDWORK_TEST_MISE_JSON='{"pnpm":[{"version":"9.9.9","active":true}]}' \
  /bin/bash home/dot_local/bin/executable_groundwork-doctor --runtimes \
  >"$out_dir/doctor-runtimes-young" 2>&1
grep -qF 'younger than the 5d release floor' "$out_dir/doctor-runtimes-young" \
  || fail "the doctor did not flag a runtime adopted inside the release floor"
grep -qF 'mise use -g pnpm@' "$out_dir/doctor-runtimes-young" \
  || fail "the doctor must name the command that pins a vetted version"
grep -qF 'never rolls back what you already have' "$out_dir/doctor-runtimes-young" \
  || fail "the doctor must explain WHY the floor did not fix this by itself"
# A version past the floor must NOT be flagged.
runtime_old="$(jq -rn '(now - (30 * 86400)) | todateiso8601')"
cat >"$runtime_fixture/bin/curl" <<SH
#!/usr/bin/env bash
printf '{"time":{"9.9.9":"%s"}}\n' "$runtime_old"
SH
chmod +x "$runtime_fixture/bin/curl"
PATH="$runtime_fixture/bin:$PATH" \
  GROUNDWORK_TEST_MISE_JSON='{"pnpm":[{"version":"9.9.9","active":true}]}' \
  /bin/bash home/dot_local/bin/executable_groundwork-doctor --runtimes \
  >"$out_dir/doctor-runtimes-old" 2>&1
assert_not_contains 'younger than' "$out_dir/doctor-runtimes-old" \
  "the doctor flagged a runtime that is past the release floor"
grep -qF 'past the 5d floor' "$out_dir/doctor-runtimes-old"

check "shell runtime ownership"
# Groundwork owns the interactive zsh runtime: Homebrew installs it, update-all
# upgrades it, and adoption is an explicit step that never touches the OS shell.
grep -qF 'brew "zsh"' home/dot_config/homebrew/Brewfile.tmpl
test -x home/dot_local/bin/executable_groundwork-shell-adopt
# Never hard-code a Homebrew prefix: it differs on Apple Silicon, Intel, and
# Linuxbrew. Resolve it with brew --prefix.
# Fact-gathering lives in ONE shared read-only library. Three private copies had
# already drifted into security-relevant differences (one executed the candidate
# zsh before proving Homebrew owned it; another consumed its one-shot state
# without checking ownership at all), so the duplication is guarded against.
shell_lib=home/dot_local/share/groundwork/lib/shell-runtime.sh
test -f "$shell_lib"
for shell_consumer in home/dot_local/bin/executable_groundwork-shell-adopt \
  home/dot_local/bin/executable_groundwork-doctor \
  home/run_after_99-shell-adopt-notice.sh; do
  grep -qF 'lib/shell-runtime.sh' "$shell_consumer" \
    || fail "$shell_consumer must use the shared shell-runtime probe, not its own copy"
  assert_no_matches "shell-runtime facts must come from the shared probe, not a private reimplementation ($shell_consumer)" \
    rg -n 'dscl \. -read|brew --prefix zsh' "$shell_consumer"
done
grep -qF 'brew --prefix' "$shell_lib"
# The probe must never run the candidate binary to identify it — that is exactly
# what a replaced binary wants. Only gw_managed_zsh_version (gated on proven
# ownership) may execute it.
grep -qF 'gw_managed_zsh_version' "$shell_lib"
grep -qF 'GW_OWNERSHIP' "$shell_lib"
assert_no_matches "Homebrew prefix must be resolved, not hard-coded (Intel and Linuxbrew differ)" \
  rg -n '/opt/homebrew|/home/linuxbrew' home/dot_local/bin/executable_groundwork-shell-adopt "$shell_lib"
assert_no_matches "Groundwork must never modify or remove the OS fallback shell" \
  rg -n 'rm .*(/bin/zsh|/bin/sh)|mv .*/bin/zsh' home/dot_local/bin/executable_groundwork-shell-adopt
# An installer must never re-exec the shell the user is sitting in.
assert_no_matches "shell adoption must not exec over the user's running shell" \
  rg -n '^[[:space:]]*exec[[:space:]]+[$"/]' home/dot_local/bin/executable_groundwork-shell-adopt

adopt_fixture="$out_dir/shell-adopt"
mkdir -p "$adopt_fixture/bin" "$adopt_fixture/brew-prefix/bin" "$adopt_fixture/state" \
  "$adopt_fixture/nobrew-bin"
# Fake managed zsh, OS fallback, and the account-record + chsh + sudo surface.
# The managed path is a SYMLINK into the Cellar, exactly as Homebrew installs it:
# adoption must prove the stable path resolves into Homebrew's zsh formula, not
# merely that something executable sits there.
mkdir -p "$adopt_fixture/brew-prefix/Cellar/zsh/5.9.2/bin"
printf '#!/bin/sh\necho "zsh 5.9.2 (fixture)"\n' >"$adopt_fixture/brew-prefix/Cellar/zsh/5.9.2/bin/zsh"
chmod +x "$adopt_fixture/brew-prefix/Cellar/zsh/5.9.2/bin/zsh"
ln -sf "$adopt_fixture/brew-prefix/Cellar/zsh/5.9.2/bin/zsh" "$adopt_fixture/brew-prefix/bin/zsh"
# A stray, non-Homebrew binary at the same stable path — must NOT be adopted.
printf '#!/bin/sh\necho "zsh 9.9 (impostor)"\n' >"$adopt_fixture/impostor-zsh"
printf '#!/bin/sh\necho "zsh 5.9 (os-fixture)"\n' >"$adopt_fixture/os-zsh"
chmod +x "$adopt_fixture/impostor-zsh" "$adopt_fixture/os-zsh"
cat >"$adopt_fixture/bin/brew" <<SH
#!/usr/bin/env bash
# Models Homebrew's ownership surface: --prefix, --prefix zsh, list --versions.
case "\${1:-}" in
  --prefix)
    if [[ "\${2:-}" == "zsh" ]]; then
      [[ "\${BREW_OWNS_ZSH:-1}" == "1" ]] || exit 1
      echo "$adopt_fixture/brew-prefix/Cellar/zsh/5.9.2"
    else
      echo "$adopt_fixture/brew-prefix"
    fi
    ;;
  list)
    [[ "\${BREW_OWNS_ZSH:-1}" == "1" ]] || exit 1
    echo "zsh 5.9.2"
    ;;
esac
SH
cat >"$adopt_fixture/bin/chsh" <<SH
#!/usr/bin/env bash
printf 'chsh %s\n' "\$*" >>"$adopt_fixture/state/log"
[[ "\${CHSH_STATUS:-0}" == "0" ]] || exit "\$CHSH_STATUS"
# CHSH_NOOP models the nasty case: chsh exits 0 but the account never changes.
[[ "\${CHSH_NOOP:-0}" == "1" ]] && exit 0
# A real chsh updates the account record; the fixture records it the same way.
printf '%s\n' "\$2" >"$adopt_fixture/state/login-shell"
SH
# dscl is the macOS account-record reader; the fixture answers from state.
cat >"$adopt_fixture/bin/dscl" <<SH
#!/usr/bin/env bash
printf 'UserShell: %s\n' "\$(cat "$adopt_fixture/state/login-shell" 2>/dev/null)"
SH
cat >"$adopt_fixture/bin/sudo" <<'SH'
#!/usr/bin/env bash
"$@"
SH
chmod +x "$adopt_fixture/bin/brew" "$adopt_fixture/bin/chsh" "$adopt_fixture/bin/dscl" "$adopt_fixture/bin/sudo"
# The "Homebrew is gone" PATH keeps the account-record surface (chsh/dscl/sudo)
# and drops only brew — otherwise the test would exercise the real chsh.
for adopt_tool in chsh dscl sudo; do
  ln -sf "$adopt_fixture/bin/$adopt_tool" "$adopt_fixture/nobrew-bin/$adopt_tool"
done
adopt_zsh="$adopt_fixture/brew-prefix/bin/zsh"
adopt_shells="$adopt_fixture/state/shells"
adopt_state="$adopt_fixture/state/groundwork"
adopt_previous="$adopt_state/previous-login-shell"
# The user's real previous shell — deliberately NOT zsh, because on Linux and
# WSL2 it is usually bash. Reverting must restore this exact shell, not a
# guessed platform default.
adopt_prev_shell="$adopt_fixture/os-bash"
printf '#!/bin/sh\necho "GNU bash, version 5.2 (os-fixture)"\n' >"$adopt_prev_shell"
chmod +x "$adopt_prev_shell"
adopt_env=(
  PATH="$adopt_fixture/bin:/usr/bin:/bin"
  GROUNDWORK_SHELL_LIB="$PWD/home/dot_local/share/groundwork/lib/shell-runtime.sh"
  GROUNDWORK_LOGIN_SHELL_FILE="$adopt_fixture/state/login-shell"
  GROUNDWORK_SHELLS_FILE="$adopt_shells"
  GROUNDWORK_STATE_DIR="$adopt_state"
)
adopt_reset() {
  rm -rf "$adopt_state"
  # A real login shell is registered in the shells file — chsh requires it —
  # so the fixture models that.
  printf '/bin/sh\n%s\n' "$adopt_prev_shell" >"$adopt_shells"
  printf '%s\n' "$adopt_prev_shell" >"$adopt_fixture/state/login-shell"
  : >"$adopt_fixture/state/log"
}

# The intermediate tmux copy must never touch the clipboard or the buffer stack:
# without -C -P, tmux pushes the RAW selection (uncapped, unheadered) to the
# system clipboard before any of the safety logic runs.
grep -qF 'copy-pipe-and-cancel -C -P' home/dot_local/bin/executable_tmux-copy-last \
  || fail "the intermediate copy must use -C -P (no clipboard, no paste buffer)"
# The final buffer must target the invoking client, or tmux guesses which
# terminal gets the clipboard.
grep -qF "load_args+=(-t \"\$client\")" home/dot_local/bin/executable_tmux-copy-last \
  || fail "the final load-buffer must target the invoking client"
# Byte accounting must use wc -c, never ${#var} (which counts characters under a
# UTF-8 locale and would blow the byte cap on emoji/CJK paths).
assert_no_matches "byte accounting must use wc -c, not character counts" \
  rg -n '\$\{#(header|notice|head_part)\}' home/dot_local/bin/executable_tmux-copy-last
grep -qF 'LC_ALL=C awk' home/dot_local/bin/executable_tmux-copy-last \
  || fail "the tail budget must run under LC_ALL=C so awk length() counts bytes"

# Migration from the user's own shell: records it, registers the managed zsh,
# chsh's, verifies the account record, and says how to switch this terminal.
adopt_reset
env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  >"$out_dir/shell-adopt-migrate" 2>&1 \
  || {
    sed 's/^/    /' "$out_dir/shell-adopt-migrate" >&2
    fail "groundwork-shell-adopt failed to migrate from the user's shell"
  }
grep -qF "chsh -s $adopt_zsh" "$adopt_fixture/state/log" \
  || fail "groundwork-shell-adopt did not chsh to the managed zsh"
grep -qxF "$adopt_zsh" "$adopt_shells" \
  || fail "groundwork-shell-adopt did not register the managed zsh in the shells file"
grep -qxF "$adopt_prev_shell" "$adopt_previous" \
  || fail "groundwork-shell-adopt did not record the previous login shell"
grep -qF 'exec' "$out_dir/shell-adopt-migrate" \
  || fail "groundwork-shell-adopt must tell the user how to switch the current terminal"
grep -qF 'revert' "$out_dir/shell-adopt-migrate" \
  || fail "groundwork-shell-adopt must state the undo path"
test -x "$adopt_prev_shell" || fail "the user's previous shell must never be modified"

# Idempotent: a second run neither duplicates the shells entry, re-chsh's, nor
# overwrites the recorded previous shell with the managed zsh.
: >"$adopt_fixture/state/log"
env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  >"$out_dir/shell-adopt-again" 2>&1
[[ "$(grep -cxF "$adopt_zsh" "$adopt_shells")" -eq 1 ]] \
  || fail "groundwork-shell-adopt duplicated the shells-file entry"
test ! -s "$adopt_fixture/state/log" \
  || fail "groundwork-shell-adopt ran chsh again when the shell was already adopted"
grep -qxF "$adopt_prev_shell" "$adopt_previous" \
  || fail "a rerun overwrote the recorded previous login shell"
grep -qF 'already' "$out_dir/shell-adopt-again"

# Already adopted but the managed zsh's registration was lost (a system update
# can rewrite the shells file): repair it instead of reporting all-clear.
printf '/bin/sh\n%s\n' "$adopt_prev_shell" >"$adopt_shells"
: >"$adopt_fixture/state/log"
env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  >"$out_dir/shell-adopt-repair" 2>&1
grep -qxF "$adopt_zsh" "$adopt_shells" \
  || fail "groundwork-shell-adopt did not repair a lost shells-file registration"

# --status changes nothing, and never calls $SHELL "this process".
: >"$adopt_fixture/state/log"
env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt --status \
  >"$out_dir/shell-adopt-status" 2>&1
test ! -s "$adopt_fixture/state/log" || fail "groundwork-shell-adopt --status changed the login shell"
grep -qF "$adopt_zsh" "$out_dir/shell-adopt-status"
grep -qF 'login shell' "$out_dir/shell-adopt-status"

# --revert restores the recorded previous shell (bash here), not a guessed zsh,
# and verifies the account record afterwards.
: >"$adopt_fixture/state/log"
env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt --revert \
  >"$out_dir/shell-adopt-revert" 2>&1 \
  || fail "groundwork-shell-adopt --revert failed"
grep -qF "chsh -s $adopt_prev_shell" "$adopt_fixture/state/log" \
  || fail "--revert did not restore the recorded previous shell"

# Recovery must not need Homebrew — that is the incident it exists for.
printf '%s\n' "$adopt_zsh" >"$adopt_fixture/state/login-shell"
: >"$adopt_fixture/state/log"
env PATH="$adopt_fixture/nobrew-bin:/usr/bin:/bin" \
  GROUNDWORK_SHELL_LIB="$PWD/home/dot_local/share/groundwork/lib/shell-runtime.sh" \
  GROUNDWORK_LOGIN_SHELL_FILE="$adopt_fixture/state/login-shell" \
  GROUNDWORK_SHELLS_FILE="$adopt_shells" GROUNDWORK_STATE_DIR="$adopt_state" \
  /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt --revert \
  >"$out_dir/shell-revert-nobrew" 2>&1 \
  || fail "groundwork-shell-adopt --revert failed without Homebrew — the escape hatch must work when brew is gone"
grep -qF "chsh -s $adopt_prev_shell" "$adopt_fixture/state/log" \
  || fail "--revert without Homebrew did not restore the previous shell"
# --status must survive a missing Homebrew too.
env PATH="$adopt_fixture/nobrew-bin:/usr/bin:/bin" \
  GROUNDWORK_SHELL_LIB="$PWD/home/dot_local/share/groundwork/lib/shell-runtime.sh" \
  GROUNDWORK_LOGIN_SHELL_FILE="$adopt_fixture/state/login-shell" \
  GROUNDWORK_SHELLS_FILE="$adopt_shells" GROUNDWORK_STATE_DIR="$adopt_state" \
  /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt --status \
  >"$out_dir/shell-status-nobrew" 2>&1 \
  || fail "groundwork-shell-adopt --status failed without Homebrew"

# No recorded previous shell: refuse to guess, and name the explicit escape.
adopt_reset
printf '%s\n' "$adopt_zsh" >"$adopt_fixture/state/login-shell"
if env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt --revert \
  >"$out_dir/shell-revert-norecord" 2>&1; then
  fail "--revert guessed a shell when no previous one was recorded"
fi
grep -qF -- '--revert-to' "$out_dir/shell-revert-norecord" \
  || fail "--revert must point at --revert-to when it has nothing recorded"
# --revert-to restores an explicit shell.
: >"$adopt_fixture/state/log"
env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  --revert-to "$adopt_prev_shell" >"$out_dir/shell-revert-to" 2>&1 \
  || fail "--revert-to failed"
grep -qF "chsh -s $adopt_prev_shell" "$adopt_fixture/state/log"

# chsh succeeds but the account record does not change: never claim success.
adopt_reset
if env "${adopt_env[@]}" CHSH_NOOP=1 /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  >"$out_dir/shell-adopt-noop" 2>&1; then
  fail "groundwork-shell-adopt reported success although the account record never changed"
fi
grep -qF 'still' "$out_dir/shell-adopt-noop"

# A failed/interrupted chsh must not claim success and must not move the shell.
adopt_reset
if env "${adopt_env[@]}" CHSH_STATUS=1 /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  >"$out_dir/shell-adopt-chsh-fail" 2>&1; then
  fail "groundwork-shell-adopt reported success after chsh failed"
fi
grep -qxF "$adopt_prev_shell" "$adopt_fixture/state/login-shell" \
  || fail "a failed chsh must leave the login shell unchanged"

# Ownership, not mere existence: a binary at the managed path that Homebrew does
# not own must never be adopted as "Groundwork-managed".
adopt_reset
if env "${adopt_env[@]}" BREW_OWNS_ZSH=0 /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  >"$out_dir/shell-adopt-unowned" 2>&1; then
  fail "groundwork-shell-adopt adopted a zsh that Homebrew does not own"
fi
grep -qF 'not Homebrew' "$out_dir/shell-adopt-unowned"
test ! -s "$adopt_fixture/state/log" || fail "an unowned zsh still reached chsh"

# The recovery invariant: never change the login shell without a durable,
# readable rollback record. An unusable current shell must refuse adoption.
adopt_reset
printf '\n' >"$adopt_fixture/state/login-shell"
if env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  >"$out_dir/shell-adopt-noprev" 2>&1; then
  fail "groundwork-shell-adopt adopted without a usable previous shell to record"
fi
grep -qF 'No account change was attempted' "$out_dir/shell-adopt-noprev"
test ! -s "$adopt_fixture/state/log" || fail "adoption ran chsh with no rollback recorded"
# A state directory that cannot be written must also refuse.
adopt_reset
if env PATH="$adopt_fixture/bin:/usr/bin:/bin" GROUNDWORK_SHELLS_FILE="$adopt_shells" \
  GROUNDWORK_SHELL_LIB="$PWD/home/dot_local/share/groundwork/lib/shell-runtime.sh" \
  GROUNDWORK_LOGIN_SHELL_FILE="$adopt_fixture/state/login-shell" \
  GROUNDWORK_STATE_DIR=/proc/nonexistent-groundwork-state \
  /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  >"$out_dir/shell-adopt-nostate" 2>&1; then
  fail "groundwork-shell-adopt adopted although the rollback record could not be written"
fi
grep -qF 'Refusing to adopt' "$out_dir/shell-adopt-nostate"

# A failing account-directory lookup (dscl/getent down) must not kill the
# command silently under set -e: status still reports, revert and adopt refuse
# with an explanation rather than vanishing.
adopt_reset
cat >"$adopt_fixture/bin/dscl" <<SH
#!/usr/bin/env bash
printf 'UserShell: %s\n' "\$(cat "$adopt_fixture/state/login-shell" 2>/dev/null)"
SH
chmod +x "$adopt_fixture/bin/dscl"
env "${adopt_env[@]}" GROUNDWORK_LOGIN_SHELL_FILE="$adopt_fixture/state/no-such-record" \
  /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt --status \
  >"$out_dir/shell-status-brokendir" 2>&1 \
  || fail "--status died silently when the account directory was unreadable"
test -s "$out_dir/shell-status-brokendir" \
  || fail "--status printed nothing when the account directory was unreadable"
if env "${adopt_env[@]}" GROUNDWORK_LOGIN_SHELL_FILE="$adopt_fixture/state/no-such-record" \
  /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt --revert \
  >"$out_dir/shell-revert-brokendir" 2>&1; then
  fail "--revert proceeded although the account's current login shell was unreadable"
fi
grep -qF 'No account change was attempted' "$out_dir/shell-revert-brokendir"
# --revert-to routes through the same guard, so it must NOT be offered as the
# way out of an unreadable account record — every change is verified against
# that record, which is precisely what is broken.
assert_not_contains 'revert-to <shell>' "$out_dir/shell-revert-brokendir" \
  "a broken account lookup must not recommend --revert-to, which hits the same guard"
if env "${adopt_env[@]}" GROUNDWORK_LOGIN_SHELL_FILE="$adopt_fixture/state/no-such-record" \
  /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  --revert-to "$adopt_prev_shell" >"$out_dir/shell-revertto-brokendir" 2>&1; then
  fail "--revert-to proceeded although the account record was unreadable (the result could not be verified)"
fi
test ! -s "$adopt_fixture/state/log" || fail "--revert-to ran chsh with an unverifiable account record"

# An unreadable shells file must fail closed, not skip the membership check and
# call chsh anyway.
adopt_reset
printf '%s\n' "$adopt_zsh" >"$adopt_fixture/state/login-shell"
if env "${adopt_env[@]}" GROUNDWORK_SHELLS_FILE="$adopt_fixture/state/missing-shells" \
  /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt --revert-to "$adopt_prev_shell" \
  >"$out_dir/shell-revertto-noshells" 2>&1; then
  fail "--revert-to proceeded although the shells file was unreadable"
fi
grep -qF 'unreadable' "$out_dir/shell-revertto-noshells"
test ! -s "$adopt_fixture/state/log" || fail "--revert-to ran chsh without verifying shells-file membership"
if env "${adopt_env[@]}" GROUNDWORK_LOGIN_SHELL_FILE="$adopt_fixture/state/no-such-record" \
  /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  >"$out_dir/shell-adopt-brokendir" 2>&1; then
  fail "adoption proceeded although the account's current login shell was unreadable"
fi
grep -qF 'No account change was attempted' "$out_dir/shell-adopt-brokendir"
test ! -s "$adopt_fixture/state/log" || fail "a broken account lookup still reached chsh"

# Conflicting or malformed options are errors, not last-flag-wins.
adopt_reset
if env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  --status --revert >"$out_dir/shell-adopt-conflict" 2>&1; then
  fail "groundwork-shell-adopt accepted conflicting modes"
fi
grep -qF 'mutually exclusive' "$out_dir/shell-adopt-conflict"
if env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  --revert-to 'relative/zsh' >"$out_dir/shell-adopt-relative" 2>&1; then
  fail "--revert-to accepted a relative path"
fi
grep -qF 'absolute path' "$out_dir/shell-adopt-relative"
# EVERY control character, including the newline — grep would never match that
# one, because it splits its input on newlines in the first place.
for ctrl_case in newline:$'/bin/ba\nsh' cr:$'/bin/ba\rsh' tab:$'/bin/ba\tsh' \
  esc:$'/bin/ba\x1bsh' del:$'/bin/ba\x7fsh'; do
  ctrl_name="${ctrl_case%%:*}"
  ctrl_value="${ctrl_case#*:}"
  if env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
    --revert-to "$ctrl_value" >"$out_dir/shell-adopt-ctrl-$ctrl_name" 2>&1; then
    fail "--revert-to accepted a shell path containing an embedded $ctrl_name"
  fi
  grep -qF 'control characters' "$out_dir/shell-adopt-ctrl-$ctrl_name"
done
# --revert and --revert-to both mean "revert", so exclusivity must key on the
# OPTION the user typed, not the resulting mode.
if env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  --revert --revert-to /bin/sh >"$out_dir/shell-adopt-bothrevert" 2>&1; then
  fail "--revert and --revert-to were accepted together"
fi
grep -qF 'mutually exclusive' "$out_dir/shell-adopt-bothrevert"

# A missing shared probe must be an explained failure for adoption, and must NOT
# take out the doctor's unrelated Docker diagnostics.
if env "${adopt_env[@]}" GROUNDWORK_SHELL_LIB=/nonexistent-groundwork-lib \
  /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt --status \
  >"$out_dir/shell-adopt-nolib" 2>&1; then
  fail "groundwork-shell-adopt ran without its shell-runtime probe"
fi
grep -qF 'shell-runtime probe is missing' "$out_dir/shell-adopt-nolib"
env GROUNDWORK_SHELL_LIB=/nonexistent-groundwork-lib \
  GROUNDWORK_LOGIN_SHELL_FILE="$adopt_fixture/state/login-shell" \
  /bin/bash home/dot_local/bin/executable_groundwork-doctor --shell \
  >"$out_dir/doctor-nolib" 2>&1 \
  || fail "groundwork-doctor --shell crashed instead of reporting the missing probe"
grep -qF 'shell-runtime probe is missing' "$out_dir/doctor-nolib"
env GROUNDWORK_SHELL_LIB=/nonexistent-groundwork-lib \
  /bin/bash home/dot_local/bin/executable_groundwork-doctor --docker \
  >"$out_dir/doctor-nolib-docker" 2>&1 \
  || fail "a missing shell probe broke the doctor's unrelated Docker section"

# An unowned binary at the stable path must never be summarized as "Groundwork's
# zsh is your login shell" — path equality is not ownership.
adopt_reset
printf '%s\n' "$adopt_zsh" >"$adopt_fixture/state/login-shell"
env "${adopt_env[@]}" BREW_OWNS_ZSH=0 /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  --status >"$out_dir/shell-status-unowned" 2>&1
assert_not_contains "Groundwork's verified Homebrew zsh is your login shell" "$out_dir/shell-status-unowned" \
  "--status called an unowned binary Groundwork's zsh"
grep -qF 'NOT a verified Homebrew zsh' "$out_dir/shell-status-unowned" \
  || fail "--status must say the login shell's binary is unverified"

# Adoption itself does need Homebrew: refuse clearly, change nothing.
adopt_reset
if env PATH="$adopt_fixture/nobrew-bin:/usr/bin:/bin" GROUNDWORK_SHELLS_FILE="$adopt_shells" \
  GROUNDWORK_SHELL_LIB="$PWD/home/dot_local/share/groundwork/lib/shell-runtime.sh" \
  GROUNDWORK_LOGIN_SHELL_FILE="$adopt_fixture/state/login-shell" \
  GROUNDWORK_STATE_DIR="$adopt_state" \
  /bin/bash home/dot_local/bin/executable_groundwork-shell-adopt \
  >"$out_dir/shell-adopt-nobrew" 2>&1; then
  fail "groundwork-shell-adopt proceeded without Homebrew"
fi
grep -qF 'Homebrew is not available' "$out_dir/shell-adopt-nobrew"
test ! -s "$adopt_fixture/state/log" || fail "a Homebrew-less adopt still ran chsh"

# The doctor reports the runtime read-only, distinguishes failure states, and
# never labels $SHELL as the running process.
grep -qF 'shell_section' home/dot_local/bin/executable_groundwork-doctor
assert_no_matches "groundwork-doctor must not present \$SHELL as the invoking process" \
  rg -n 'this process:.*SHELL' home/dot_local/bin/executable_groundwork-doctor
adopt_reset
env "${adopt_env[@]}" /bin/bash home/dot_local/bin/executable_groundwork-doctor --shell \
  >"$out_dir/doctor-shell" 2>&1
grep -qF 'Shell runtime' "$out_dir/doctor-shell"
# The green "managed zsh" line may only appear AFTER ownership is proven — and
# the candidate must never be executed before that, or a replaced binary gets
# run by the very command meant to identify it.
grep -qF 'managed zsh: Homebrew owns it' "$out_dir/doctor-shell" \
  || fail "the doctor must confirm Homebrew ownership, not just that a zsh exists"
# A zsh at the stable path that Homebrew does NOT own must never be called
# "managed", and must not be executed.
adopt_reset
if env "${adopt_env[@]}" BREW_OWNS_ZSH=0 /bin/bash home/dot_local/bin/executable_groundwork-doctor --shell \
  >"$out_dir/doctor-unowned" 2>&1; then :; fi
assert_not_contains 'ok +managed zsh' "$out_dir/doctor-unowned" \
  "the doctor called an unowned binary 'managed zsh'"
grep -qF 'ownership is not established' "$out_dir/doctor-unowned" \
  || fail "the doctor must say ownership is not established for an unowned zsh"
grep -qF 'login shell (account)' "$out_dir/doctor-shell"
grep -qF 'invoking process' "$out_dir/doctor-shell"
grep -qF 'groundwork-shell-adopt' "$out_dir/doctor-shell" \
  || fail "groundwork-doctor must name the adoption command when the login shell is not the managed zsh"
# A damaged Homebrew is something a diagnostic reports, not something it dies on.
mkdir -p "$adopt_fixture/badbrew-bin"
printf '#!/bin/sh\nexit 1\n' >"$adopt_fixture/badbrew-bin/brew"
chmod +x "$adopt_fixture/badbrew-bin/brew"
env PATH="$adopt_fixture/badbrew-bin:/usr/bin:/bin" GROUNDWORK_SHELLS_FILE="$adopt_shells" \
  GROUNDWORK_SHELL_LIB="$PWD/home/dot_local/share/groundwork/lib/shell-runtime.sh" \
  GROUNDWORK_LOGIN_SHELL_FILE="$adopt_fixture/state/login-shell" \
  GROUNDWORK_STATE_DIR="$adopt_state" \
  /bin/bash home/dot_local/bin/executable_groundwork-doctor --shell \
  >"$out_dir/doctor-shell-badbrew" 2>&1 \
  || fail "groundwork-doctor crashed on a damaged Homebrew instead of reporting it"
grep -qF 'damaged' "$out_dir/doctor-shell-badbrew"

# The one-time adoption notice: shown once interactively, never again, and
# never when the shell is already adopted.
notice_state="$adopt_fixture/notice-state"
printf '%s\n' "$adopt_prev_shell" >"$adopt_fixture/state/login-shell"
env "${adopt_env[@]}" GROUNDWORK_STATE_DIR="$notice_state" GROUNDWORK_REMINDER_ASSUME_TTY=1 \
  /bin/bash home/run_after_99-shell-adopt-notice.sh >"$out_dir/adopt-notice" 2>&1
grep -qF 'groundwork-shell-adopt' "$out_dir/adopt-notice" \
  || fail "the adoption notice must name the command"
env "${adopt_env[@]}" GROUNDWORK_STATE_DIR="$notice_state" GROUNDWORK_REMINDER_ASSUME_TTY=1 \
  /bin/bash home/run_after_99-shell-adopt-notice.sh >"$out_dir/adopt-notice-2" 2>&1
test ! -s "$out_dir/adopt-notice-2" || fail "the adoption notice repeated after being shown"
# Noninteractive: say nothing and stay pending.
rm -rf "$notice_state"
env "${adopt_env[@]}" GROUNDWORK_STATE_DIR="$notice_state" \
  /bin/bash home/run_after_99-shell-adopt-notice.sh >"$out_dir/adopt-notice-tty" 2>&1
test ! -s "$out_dir/adopt-notice-tty" || fail "the adoption notice printed to a non-terminal"
test ! -e "$notice_state/shell-adopt-notice-shown" \
  || fail "a noninteractive run consumed the adoption notice"

check "annotation escaping"
# Toolkit-exact, and byte-for-byte what @roost/ci-diagnostics renders for the
# same inputs (its src/vectors.json is the shared case list). % escapes first,
# so the % introduced by the CR/LF escapes is not escaped again; CR/LF become
# %0D/%0A rather than spaces, which keeps the annotation multi-line-faithful.
[[ "$(annotation_escape_message $'50% done\r\n::error fake::injected')" == '50%25 done%0D%0A::error fake::injected' ]] \
  || fail "annotation message escaping changed for %, CR, LF, or embedded workflow-command text"
[[ "$(annotation_escape_title $'rendered zsh: a,b\r\nc % ::set-output')" == 'rendered zsh%3A a%2Cb%0D%0Ac %25 %3A%3Aset-output' ]] \
  || fail "annotation title escaping changed for colon, comma, %, or control characters"
# A pre-escaped sequence must not be double-unescaped back into a real newline.
[[ "$(annotation_escape_message '%0A is a literal, not a newline')" == '%250A is a literal, not a newline' ]] \
  || fail "annotation escaping must not let a literal %0A survive as a real escape"
# U+2028/U+2029 end a line for the runner's command parser exactly like LF.
[[ "$(annotation_escape_message $'before\342\200\250::error title=x::y\342\200\251after')" == 'before%0A::error title=x::y%0Aafter' ]] \
  || fail "U+2028/U+2029 must escape to %0A, or content could open a new line"
# The property that makes the escaping injection-safe, asserted directly rather
# than inferred from the strings above: a workflow command is only recognized at
# the start of a line, and no escaped output can contain a line break at all.
ann_hostile="$(annotation_escape_title $'x\r\n::error fake::injected\342\200\250::notice a::b')"
[[ "$ann_hostile" != *$'\n'* && "$ann_hostile" != *$'\r'* && "$ann_hostile" != *$'\342\200\250'* ]] \
  || fail "escaped annotation content kept a line break, so an injected ::error could start its own line"

# The 500-code-point display cap, matching @roost/ci-diagnostics'
# WORKFLOW_COMMAND_MAX_LENGTH: at the cap, unchanged; over it, 499 kept plus an
# ellipsis marker.
ann_a500="$(printf '%500s' '' | tr ' ' a)"
ann_a499="${ann_a500:0:499}"
ann_a498="${ann_a500:0:498}"
[[ "$(annotation_escape_message "$ann_a500")" == "$ann_a500" ]] \
  || fail "an annotation message exactly at the 500-code-point cap must not be truncated"
[[ "$(annotation_escape_message "${ann_a500}x")" == "${ann_a499}…" ]] \
  || fail "an over-long annotation message must truncate to 499 code points plus an ellipsis"
[[ "$(annotation_escape_title "${ann_a500}x")" == "${ann_a499}…" ]] \
  || fail "an over-long annotation title must truncate to 499 code points plus an ellipsis"
# CODE POINTS, not bytes. The rocket sits at code point 499 — the last character
# the cap keeps — but at BYTE 499 of the payload, so a byte-wise cut would slice
# it in half and emit a broken character. bash only counts code points under a
# UTF-8 locale, which is why annotation_cap resolves one.
ann_rocket=$'\360\237\232\200'
[[ "$(annotation_escape_message "${ann_a498}${ann_rocket}zz")" == "${ann_a498}${ann_rocket}…" ]] \
  || fail "the annotation cap split a multibyte character (it must count code points, not bytes)"
# And with no UTF-8 locale on the machine at all, bash counts bytes: the cap then
# backs off the partial character rather than emitting half of it. Stricter than
# the contract (the whole rocket is dropped), never broken output.
ann_no_utf8="$(annotation_utf8_locale=""; annotation_escape_message "${ann_a498}${ann_rocket}zz")"
[[ "$ann_no_utf8" == "${ann_a498}…" ]] \
  || fail "without a UTF-8 locale the annotation cap must drop the partial character, not split it"

check "tmux-copy-last helper"
test -x home/dot_local/bin/executable_tmux-copy-last
# The OSC 133 prompt mark must be part of PROMPT, not emitted from a precmd
# hook: zle redraws the prompt line and wipes a mark written before the
# redraw, so a precmd version silently records no marks at all.
grep -qF '133;A' home/dot_zshrc.tmpl
grep -qF "PROMPT=\"%{\${_groundwork_osc133_mark}%}\${PROMPT}\"" home/dot_zshrc.tmpl
# Idempotency must be by inspecting PROMPT, not a "already ran" flag: starship's
# init replaces PROMPT on every source, so a flag would skip the re-add and
# leave the shell with no marks at all.
grep -qF "\"\$PROMPT\" != *\"\$_groundwork_osc133_mark\"*" home/dot_zshrc.tmpl
assert_no_matches "OSC 133 prompt marks must live in PROMPT, not a precmd hook (zle's redraw wipes them)" \
  rg -n 'add-zsh-hook precmd .*osc133' home/dot_zshrc.tmpl
# Outside tmux, with no target pane, it refuses — no server needed.
if TMUX='' /bin/bash home/dot_local/bin/executable_tmux-copy-last >"$out_dir/copylast-notmux" 2>&1; then
  fail "tmux-copy-last ran outside tmux"
fi
grep -qF 'not inside tmux' "$out_dir/copylast-notmux"
# The suite needs tmux 3.6+ — the version tmux-copy-last itself requires, since
# the -C/-P copy flags are what keep the raw selection off the clipboard. An
# older tmux cannot exercise the real contract. A skip must never be invisible:
# GROUNDWORK_REQUIRE_TMUX=1 (set on the macOS CI job, which supplies a current
# tmux) turns "cannot test" into a failure.
tmux_suite_version=""
tmux_suite_ok=0
if command -v tmux >/dev/null 2>&1; then
  tmux_suite_version="$(tmux -V 2>/dev/null | awk '{print $2}')"
  suite_major="${tmux_suite_version%%.*}"
  suite_minor="${tmux_suite_version#*.}"
  suite_minor="${suite_minor%%[!0-9]*}"
  if [[ "$suite_major" =~ ^[0-9]+$ && "$suite_minor" =~ ^[0-9]+$ ]] \
    && ((suite_major > 3 || (suite_major == 3 && suite_minor >= 6))); then
    tmux_suite_ok=1
  fi
fi
if ((tmux_suite_ok == 0)); then
  if [[ "${GROUNDWORK_REQUIRE_TMUX:-0}" == "1" ]]; then
    fail "the tmux-copy-last behavior suite requires tmux 3.6+ (found: ${tmux_suite_version:-none}). A skipped clipboard/buffer suite must not pass as green."
  fi
  echo "tmux ${tmux_suite_version:-not installed} is below the 3.6 the copy suite needs; skipping those behavior tests (the macOS CI job runs them with GROUNDWORK_REQUIRE_TMUX=1)"
else
  copylast_socket="groundwork-validate-$$"
  copylast_dir="$out_dir/copylast"
  # CI runners leave LANG unset. Without a UTF-8 locale tmux can mangle multibyte
  # pane content before the helper ever sees it, which would make the multibyte
  # test assert the runner's locale instead of our truncation. Pick one if the
  # machine has it.
  copylast_locale=""
  for candidate_locale in en_US.UTF-8 C.UTF-8; do
    if locale -a 2>/dev/null | grep -qix "$candidate_locale"; then
      copylast_locale="$candidate_locale"
      break
    fi
  done
  mkdir -p "$copylast_dir/bin"
  printf 'set -g history-limit 20000\nset -g escape-time 0\n' >"$copylast_dir/tmux.conf"
  # The helper calls plain `tmux`; this PATH shim pins every call to the
  # private test server so the tests never touch a user's real session.
  real_tmux="$(command -v tmux)"
  cat >"$copylast_dir/bin/tmux" <<SH
#!/bin/sh
exec "$real_tmux" -L "$copylast_socket" "\$@"
SH
  chmod +x "$copylast_dir/bin/tmux"
  run_copylast() {
    TMUX='validate,0,0' PATH="$copylast_dir/bin:/usr/bin:/bin" \
      /bin/bash home/dot_local/bin/executable_tmux-copy-last "$1"
  }
  copylast_wait() { # poll until the scenario pane finished rendering
    # 30s, not 5: the 6,000-line scenario can take a while to render on a loaded
    # machine or a CI runner, and a required lane must not fail by timing.
    local pane="$1" sentinel="$2"
    for _ in $(seq 1 300); do
      if tmux -L "$copylast_socket" capture-pane -p -S - -t "$pane" | grep -qF "$sentinel"; then
        return 0
      fi
      sleep 0.1
    done
    fail "tmux fixture pane never printed $sentinel"
  }
  copylast_window() { # start a scenario script as a pane's only process
    tmux -L "$copylast_socket" new-window -c "$copylast_dir" "$copylast_dir/$1"
    tmux -L "$copylast_socket" display-message -p '#{pane_id}'
  }
  # Each scenario script is the pane's only process and prints OSC 133 prompt
  # marks exactly where a shell with integration would, so no interactive
  # shell noise pollutes the history. A trailing sleep keeps the pane alive.
  cat >"$copylast_dir/scenario-completed.sh" <<'SH'
#!/bin/sh
mark() { printf '\033]133;A\033\\'; }
mark; printf '~/demo $ echo hello\n'; printf 'hello\n'
mark; printf '~/demo $ cat trap.txt\n'
printf ' 󰀵  …/groundwork ❯ rm -rf fake-prompt-in-output\n'
printf 'badge 󰀵 in output text\n'
printf 'READY-A\n'
mark; printf '~/demo $ '
sleep 300
SH
  # Same history, but the newest mark is a command still producing output —
  # an open block with no closing mark.
  cat >"$copylast_dir/scenario-running.sh" <<'SH'
#!/bin/sh
mark() { printf '\033]133;A\033\\'; }
mark; printf '~/demo $ echo hello\n'; printf 'hello\n'
mark; printf '~/demo $ cat trap.txt\n'
printf ' 󰀵  …/groundwork ❯ rm -rf fake-prompt-in-output\n'
printf 'badge 󰀵 in output text\n'
printf 'READY-A\n'
mark; printf '~/demo $ ./long-task\n'
printf 'partial output 1\npartial output 2\n'
printf 'READY-B\n'
sleep 300
SH
  cat >"$copylast_dir/scenario-fresh.sh" <<'SH'
#!/bin/sh
printf 'READY-C\n'
printf '\033]133;A\033\\'; printf '~/demo $ '
sleep 300
SH
  cat >"$copylast_dir/scenario-nomarks.sh" <<'SH'
#!/bin/sh
printf 'plain output, no prompt marks\n'
printf 'READY-D\n'
sleep 300
SH
  # Output with NO trailing newline: the closing prompt begins on the SAME row,
  # so a naive "step up a row" would swallow the last output.
  cat >"$copylast_dir/scenario-nonewline.sh" <<'SH'
#!/bin/sh
mark() { printf '\033]133;A\033\\'; }
mark; printf '\n~/demo $ printf tail-value\n'
printf 'tail-value'
mark; printf '\n~/demo $ READY-F\n'
sleep 300
SH
  # A realistic multi-line prompt: the mark lands at the START of the prompt,
  # which for starship (add_newline + line_break) is a blank row above the row
  # carrying the typed command. Truncation must still keep that command.
  cat >"$copylast_dir/scenario-huge.sh" <<'SH'
#!/bin/sh
printf '\033]133;A\033\\'; printf '\n'
printf '~/demo $ seq 1 6000\n'
seq 1 6000
printf 'READY-E\n'
printf '\033]133;A\033\\'; printf '\n~/demo $ '
sleep 300
SH
  chmod +x "$copylast_dir"/scenario-*.sh
  cat >"$copylast_dir/expected-block" <<'EOF'
~/demo $ cat trap.txt
 󰀵  …/groundwork ❯ rm -rf fake-prompt-in-output
badge 󰀵 in output text
READY-A
EOF
  # shellcheck disable=SC2097,SC2098
  LC_ALL="${copylast_locale:-${LC_ALL:-}}" LANG="${copylast_locale:-${LANG:-}}" \
    tmux -L "$copylast_socket" -f "$copylast_dir/tmux.conf" new-session -d -x 200 -y 50 \
    -c "$copylast_dir" "$copylast_dir/scenario-completed.sh"
  # The last completed command is selected even though the newest block is an
  # idle prompt; hostile prompt-looking text and OS badge glyphs inside the
  # output are copied through, never treated as block boundaries.
  completed_pane="$(tmux -L "$copylast_socket" display-message -p '#{pane_id}')"
  copylast_wait "$completed_pane" 'READY-A'
  # Pre-existing paste buffers must survive: the helper reads and deletes its
  # own selection buffer, never one the user put there.
  tmux -L "$copylast_socket" set-buffer 'USER-BUFFER-ONE'
  tmux -L "$copylast_socket" set-buffer 'USER-BUFFER-TWO'
  run_copylast "$completed_pane" >"$copylast_dir/msg-a" 2>&1 \
    || fail "tmux-copy-last failed on a pane with a completed command"
  copylast_all="$(tmux -L "$copylast_socket" list-buffers -F '#{buffer_sample}')"
  grep -qF 'USER-BUFFER-ONE' <<<"$copylast_all" \
    || fail "tmux-copy-last destroyed a pre-existing user paste buffer"
  grep -qF 'USER-BUFFER-TWO' <<<"$copylast_all" \
    || fail "tmux-copy-last destroyed a pre-existing user paste buffer"
  tmux -L "$copylast_socket" save-buffer -b groundwork-copy-last - >"$copylast_dir/buffer-a"
  head -n 1 "$copylast_dir/buffer-a" | grep -Eq '^\[tmux-copy-last · [a-z0-9-]+ · /' \
    || fail "tmux-copy-last did not prepend the platform + directory context line"
  diff -u "$copylast_dir/expected-block" <(tail -n +2 "$copylast_dir/buffer-a")
  # Buffer hygiene: the automatic selection buffer is cleaned up, so the helper
  # adds exactly one buffer of its own on top of the two the user already had.
  copylast_buffers="$(tmux -L "$copylast_socket" list-buffers | wc -l | tr -d ' ')"
  [[ "$copylast_buffers" -eq 3 ]] \
    || fail "tmux-copy-last left $copylast_buffers buffers (expected 3: two user buffers + one headered copy)"
  tmux -L "$copylast_socket" list-buffers -F '#{buffer_name}' | grep -qxF 'groundwork-copy-last' \
    || fail "tmux-copy-last did not write its stable named buffer"
  # A running command — newest mark with output below and no closing mark —
  # is never selected; the previous completed block is copied instead.
  running_pane="$(copylast_window scenario-running.sh)"
  copylast_wait "$running_pane" 'READY-B'
  run_copylast "$running_pane" >"$copylast_dir/msg-b" 2>&1 \
    || fail "tmux-copy-last failed on a pane with a running command"
  tmux -L "$copylast_socket" save-buffer -b groundwork-copy-last - >"$copylast_dir/buffer-b"
  diff -u "$copylast_dir/expected-block" <(tail -n +2 "$copylast_dir/buffer-b")
  # A pane whose only mark is the idle prompt has no completed command.
  fresh_pane="$(copylast_window scenario-fresh.sh)"
  copylast_wait "$fresh_pane" 'READY-C'
  if run_copylast "$fresh_pane" >"$copylast_dir/msg-c" 2>&1; then
    fail "tmux-copy-last selected something in a pane with no completed command"
  fi
  grep -qF 'no completed command' "$copylast_dir/msg-c"
  # A pane with no marks at all fails with copy-mode guidance, never a guess.
  nomarks_pane="$(copylast_window scenario-nomarks.sh)"
  copylast_wait "$nomarks_pane" 'READY-D'
  if run_copylast "$nomarks_pane" >"$copylast_dir/msg-d" 2>&1; then
    fail "tmux-copy-last selected something in a pane without prompt marks"
  fi
  grep -qF 'prompt marks' "$copylast_dir/msg-d"
  grep -qF 'copy-mode' "$copylast_dir/msg-d"
  # Oversized output is truncated visibly, never silently.
  huge_pane="$(copylast_window scenario-huge.sh)"
  copylast_wait "$huge_pane" 'READY-E'
  run_copylast "$huge_pane" >"$copylast_dir/msg-e" 2>&1 \
    || fail "tmux-copy-last failed on oversized output"
  tmux -L "$copylast_socket" save-buffer -b groundwork-copy-last - >"$copylast_dir/buffer-e"
  grep -qF '[tmux-copy-last: truncated' "$copylast_dir/buffer-e"
  # The cap covers the FINAL payload — header and truncation notice included —
  # not just the copied block. 5,000 means 5,000.
  huge_lines="$(wc -l <"$copylast_dir/buffer-e" | tr -d ' ')"
  ((huge_lines <= 5000)) || fail "tmux-copy-last exceeded its documented line cap ($huge_lines lines)"
  grep -qF 'truncated' "$copylast_dir/msg-e"
  # Truncation must never drop the command itself — without it, pasted output
  # tells nobody (and no agent) what produced it.
  grep -qF 'seq 1 6000' "$copylast_dir/buffer-e" \
    || fail "tmux-copy-last truncation discarded the command line it claims to keep"
  tail -n 1 "$copylast_dir/buffer-e" | grep -qxF 'READY-E' \
    || fail "tmux-copy-last truncation did not keep the tail (end) of the output"
  grep -qxF '6000' "$copylast_dir/buffer-e" \
    || fail "tmux-copy-last truncation dropped the most recent output lines"
  # The cap applies to the FINAL payload (header + head + notice + tail), not
  # just the tail slice.
  huge_bytes="$(wc -c <"$copylast_dir/buffer-e" | tr -d ' ')"
  ((huge_bytes <= 512 * 1024)) \
    || fail "tmux-copy-last exceeded its documented byte cap ($huge_bytes bytes)"
  # A tight byte budget must still keep whole lines (never split a multibyte
  # character) and still keep the command.
  # 8192, not a hair above the header: a CI checkout path is long, and a cap the
  # header alone cannot fit is a correct REFUSAL, not a bug — testing that here
  # would only assert the runner's path length.
  GROUNDWORK_COPY_MAX_BYTES=8192 run_copylast "$huge_pane" >/dev/null 2>&1 \
    || fail "tmux-copy-last failed under a tight byte budget"
  tmux -L "$copylast_socket" save-buffer -b groundwork-copy-last - >"$copylast_dir/buffer-tiny"
  tiny_bytes="$(wc -c <"$copylast_dir/buffer-tiny" | tr -d ' ')"
  ((tiny_bytes <= 8192)) || fail "tmux-copy-last ignored a tight byte cap ($tiny_bytes bytes)"
  grep -qF 'seq 1 6000' "$copylast_dir/buffer-tiny" \
    || fail "a tight byte cap dropped the command line"
  iconv -f UTF-8 -t UTF-8 "$copylast_dir/buffer-tiny" >/dev/null 2>&1 \
    || fail "tmux-copy-last truncation split a multibyte character"

  # Multibyte output AND a multibyte working directory: byte accounting that
  # counts characters would sail past the cap here while passing on ASCII.
  mkdir -p "$copylast_dir/ünïcode 🚀"
  cat >"$copylast_dir/scenario-utf8.sh" <<'SH'
#!/bin/sh
printf '\033]133;A\033\\'; printf '\n~/demo $ emit-unicode\n'
i=0
while [ "$i" -lt 400 ]; do
  printf 'тест 日本語 🎉 ünïcode line %s\n' "$i"
  i=$((i + 1))
done
printf 'READY-U\n'
printf '\033]133;A\033\\'; printf '\n~/demo $ '
sleep 300
SH
  chmod +x "$copylast_dir/scenario-utf8.sh"
  tmux -L "$copylast_socket" new-window -c "$copylast_dir/ünïcode 🚀" \
    "$copylast_dir/scenario-utf8.sh"
  utf8_pane="$(tmux -L "$copylast_socket" display-message -p '#{pane_id}')"
  copylast_wait "$utf8_pane" 'READY-U'
  GROUNDWORK_COPY_MAX_BYTES=4096 run_copylast "$utf8_pane" >/dev/null 2>&1 \
    || fail "tmux-copy-last failed on multibyte output"
  tmux -L "$copylast_socket" save-buffer -b groundwork-copy-last - >"$copylast_dir/buffer-utf8"
  utf8_bytes="$(wc -c <"$copylast_dir/buffer-utf8" | tr -d ' ')"
  ((utf8_bytes <= 4096)) \
    || fail "tmux-copy-last blew the byte cap on multibyte content ($utf8_bytes bytes) — is it counting characters?"
  # Judge the helper, not the environment: if tmux itself could not render the
  # multibyte pane (no UTF-8 locale on this machine), there is no valid input to
  # preserve. When the capture IS valid, our output must be too — that is the
  # truncation-boundary contract.
  tmux -L "$copylast_socket" capture-pane -p -S - -t "$utf8_pane" >"$copylast_dir/utf8-capture"
  if iconv -f UTF-8 -t UTF-8 "$copylast_dir/utf8-capture" >/dev/null 2>&1; then
    iconv -f UTF-8 -t UTF-8 "$copylast_dir/buffer-utf8" >/dev/null 2>&1 \
      || fail "tmux-copy-last split a multibyte character at the truncation boundary"
  else
    echo "  (this machine has no UTF-8 locale, so tmux could not render the multibyte pane; the byte cap is still asserted)"
  fi
  head -n 1 "$copylast_dir/buffer-utf8" | grep -qF '🚀' \
    || fail "the context header lost the multibyte working directory"
  # The header stays one line even when the path carries control characters.
  [[ "$(head -n 1 "$copylast_dir/buffer-utf8" | wc -l | tr -d ' ')" -eq 1 ]]

  # A hostile TMPDIR must not break or inject: the scratch path is interpolated
  # into a command string that tmux hands to a SHELL.
  hostile_tmp="$copylast_dir/tmp dir 'quote'; \$(touch $copylast_dir/PWNED) #"
  mkdir -p "$hostile_tmp"
  TMPDIR="$hostile_tmp" run_copylast "$completed_pane" >"$copylast_dir/msg-hostile" 2>&1 \
    || fail "tmux-copy-last failed with spaces/quotes/metacharacters in TMPDIR"
  test ! -e "$copylast_dir/PWNED" \
    || fail "tmux-copy-last executed injected shell code from TMPDIR"
  tmux -L "$copylast_socket" save-buffer -b groundwork-copy-last - >"$copylast_dir/buffer-hostile"
  diff -u "$copylast_dir/expected-block" <(tail -n +2 "$copylast_dir/buffer-hostile")

  # Malformed or impossibly small limits are refused up front, not discovered
  # halfway through (and never silently exceeded).
  for bad_limit in 0 abc -5; do
    if GROUNDWORK_COPY_MAX_LINES="$bad_limit" run_copylast "$completed_pane" \
      >"$copylast_dir/msg-badlimit" 2>&1; then
      fail "tmux-copy-last accepted an invalid line limit: $bad_limit"
    fi
  done
  if GROUNDWORK_COPY_MAX_BYTES=100 run_copylast "$completed_pane" \
    >"$copylast_dir/msg-smallcap" 2>&1; then
    fail "tmux-copy-last accepted a byte cap too small to honor"
  fi
  grep -qF 'between 1024 and' "$copylast_dir/msg-smallcap"
  # Bounded above too: a huge value overflows bash arithmetic.
  if GROUNDWORK_COPY_MAX_BYTES=999999999999999999999 run_copylast "$completed_pane" \
    >"$copylast_dir/msg-hugecap" 2>&1; then
    fail "tmux-copy-last accepted an unbounded byte cap"
  fi
  # The cap is absolute: when the header and command alone cannot fit, copy
  # NOTHING rather than publish an oversized payload while promising a maximum.
  if GROUNDWORK_COPY_MAX_BYTES=1024 GROUNDWORK_COPY_MAX_LINES=5 \
    run_copylast "$huge_pane" >"$copylast_dir/msg-cap-absolute" 2>&1; then
    tmux -L "$copylast_socket" save-buffer -b groundwork-copy-last - >"$copylast_dir/buffer-cap" 2>/dev/null || true
    cap_bytes="$(wc -c <"$copylast_dir/buffer-cap" | tr -d ' ')"
    ((cap_bytes <= 1024)) \
      || fail "tmux-copy-last published $cap_bytes bytes against a 1024-byte cap"
  else
    grep -qF 'nothing was copied' "$copylast_dir/msg-cap-absolute" \
      || fail "when the cap cannot be honored, tmux-copy-last must refuse and say so"
  fi

  # Client targeting, proven behaviorally rather than by grep. Two clients are
  # attached; the buffer must be delivered for the INVOKING one. Without -t,
  # a backgrounded run-shell leaves tmux to infer a client and it can pick the
  # wrong terminal's clipboard.
  copylast_client_log="$copylast_dir/client.log"
  : >"$copylast_client_log"
  # A fake tmux that records the load-buffer invocation, then delegates.
  mkdir -p "$copylast_dir/spy"
  cat >"$copylast_dir/spy/tmux" <<SPY
#!/bin/sh
if [ "\$1" = "load-buffer" ]; then
  printf '%s\n' "\$*" >>"$copylast_client_log"
fi
exec "$real_tmux" -L "$copylast_socket" "\$@"
SPY
  chmod +x "$copylast_dir/spy/tmux"
  # TWO genuinely attached clients, so "which client?" is a real question: a
  # detached server is not a client, and targeting the only client would pass
  # even if the code ignored the argument. Control-mode clients (-C) attach
  # without a pty, which is what makes this receipt runnable on a CI runner
  # instead of quietly skipping there. `sleep | ...` keeps stdin open so the
  # client stays attached.
  for _ in 1 2; do
    (sleep 120 | "$real_tmux" -L "$copylast_socket" -C attach -t 0 >/dev/null 2>&1 &) || true
  done
  for _ in $(seq 1 30); do
    copylast_client_count="$(tmux -L "$copylast_socket" list-clients -F '#{client_name}' 2>/dev/null | wc -l | tr -d ' ')"
    [[ "$copylast_client_count" -ge 2 ]] && break
    sleep 0.2
  done
  if [[ "${copylast_client_count:-0}" -lt 2 ]]; then
    # A required receipt must not evaporate: on the CI lane that owns this
    # property, "could not attach two clients" is a failure, not a skip.
    if [[ "${GROUNDWORK_REQUIRE_TMUX:-0}" == "1" ]]; then
      fail "could not attach two tmux clients, so the clipboard client-targeting receipt could not run (it must not silently skip on the lane that owns it)"
    fi
    echo "  (could not attach two clients here; the client-targeting receipt runs on the macOS CI job)"
  else
    # Target the SECOND client, not whichever happens to be first: picking the
    # only/first client would pass even if the code ignored the argument.
    copylast_other="$(tmux -L "$copylast_socket" list-clients -F '#{client_name}' | head -n 1)"
    copylast_target="$(tmux -L "$copylast_socket" list-clients -F '#{client_name}' | sed -n '2p')"
    : >"$copylast_client_log"
    TMUX='validate,0,0' PATH="$copylast_dir/spy:/usr/bin:/bin" \
      /bin/bash home/dot_local/bin/executable_tmux-copy-last "$completed_pane" "$copylast_target" \
      >/dev/null 2>&1 || fail "tmux-copy-last failed when given an explicit client"
    grep -qF -- "-t $copylast_target" "$copylast_client_log" \
      || fail "the final load-buffer did not target the invoking client (the clipboard could land on the wrong terminal)"
    assert_not_contains "\-t $copylast_other" "$copylast_client_log" \
      "the final load-buffer targeted the WRONG client"
  fi

  # Fault injection: once copy-mode is entered and a scratch dir exists, EVERY
  # later tmux call can fail. Each failure must leave copy-mode and remove the
  # scratch directory — no stranded pane, no leaked selection on disk.
  mkdir -p "$copylast_dir/faulty"
  for fault in previous-prompt next-prompt copy-pipe-and-cancel load-buffer; do
    cat >"$copylast_dir/faulty/tmux" <<FAULT
#!/bin/sh
for arg in "\$@"; do
  if [ "\$arg" = "$fault" ]; then
    echo "injected failure: $fault" >&2
    exit 1
  fi
done
exec "$real_tmux" -L "$copylast_socket" "\$@"
FAULT
    chmod +x "$copylast_dir/faulty/tmux"
    scratch_before="$(find "${TMPDIR:-/tmp}" -maxdepth 1 -name 'tmux-copy-last.*' 2>/dev/null | wc -l | tr -d ' ')"
    set +e
    TMUX='validate,0,0' PATH="$copylast_dir/faulty:/usr/bin:/bin" \
      /bin/bash home/dot_local/bin/executable_tmux-copy-last "$completed_pane" \
      >"$copylast_dir/fault-$fault" 2>&1
    fault_status=$?
    set -e
    [[ "$fault_status" -ne 0 ]] \
      || fail "tmux-copy-last reported success although '$fault' failed"
    # The pane must not be stranded in copy-mode.
    in_mode="$(tmux -L "$copylast_socket" display-message -p -t "$completed_pane" '#{pane_in_mode}' 2>/dev/null || echo 0)"
    [[ "$in_mode" == "0" ]] \
      || fail "a failure at '$fault' left the pane stuck in copy-mode"
    # And it must not leave its scratch directory (the raw selection) behind.
    scratch_after="$(find "${TMPDIR:-/tmp}" -maxdepth 1 -name 'tmux-copy-last.*' 2>/dev/null | wc -l | tr -d ' ')"
    [[ "$scratch_after" -le "$scratch_before" ]] \
      || fail "a failure at '$fault' leaked a scratch directory holding the raw selection"
  done

  # A command whose output has no trailing newline: the closing prompt shares
  # the last output row, so the output must survive and the prompt must not
  # leak into the copy.
  nonewline_pane="$(copylast_window scenario-nonewline.sh)"
  copylast_wait "$nonewline_pane" 'READY-F'
  run_copylast "$nonewline_pane" >"$copylast_dir/msg-f" 2>&1 \
    || fail "tmux-copy-last failed on output with no trailing newline"
  tmux -L "$copylast_socket" save-buffer -b groundwork-copy-last - >"$copylast_dir/buffer-f"
  grep -qF 'tail-value' "$copylast_dir/buffer-f" \
    || fail "tmux-copy-last dropped output that had no trailing newline"
  grep -qF 'READY-F' "$copylast_dir/buffer-f" \
    && fail "tmux-copy-last leaked the next prompt into the copy"

  # Repeated use must not accumulate buffers: one stable named buffer is reused.
  copylast_before="$(tmux -L "$copylast_socket" list-buffers | wc -l | tr -d ' ')"
  run_copylast "$completed_pane" >/dev/null 2>&1
  run_copylast "$completed_pane" >/dev/null 2>&1
  copylast_after="$(tmux -L "$copylast_socket" list-buffers | wc -l | tr -d ' ')"
  [[ "$copylast_before" -eq "$copylast_after" ]] \
    || fail "repeated tmux-copy-last runs accumulate buffers ($copylast_before -> $copylast_after)"
  # The scenario panes above script the marks. This one proves the real
  # integration: an interactive zsh loading the rendered .zshrc must actually
  # register prompt marks that survive zle's redraw. A precmd-emitted mark
  # passes every scripted test and records nothing here.
  render darwin false arm64 home/dot_zshrc.tmpl "$copylast_dir/zshrc"
  mkdir -p "$copylast_dir/zdot"
  cp "$copylast_dir/zshrc" "$copylast_dir/zdot/.zshrc"
  tmux -L "$copylast_socket" new-window -c "$copylast_dir" \
    "env ZDOTDIR='$copylast_dir/zdot' HOME='$copylast_dir/zdot' zsh -i"
  zsh_pane="$(tmux -L "$copylast_socket" display-message -p '#{pane_id}')"
  # Sentinels + bounded polling, never fixed sleeps: a slow CI box must not
  # turn this into a flaky test.
  zsh_send() { # command sentinel — run it, then wait for its OUTPUT to land
    tmux -L "$copylast_socket" send-keys -t "$zsh_pane" "$1" Enter
    copylast_wait "$zsh_pane" "$2"
  }
  # The sentinel must not appear in the typed command itself, or the wait
  # returns before zsh has even run it and the whole test races.
  zsh_send "printf 'ZPROBE%s\n' 0" 'ZPROBE0'
  zsh_send "printf 'ZPROBE%s\n' 1" 'ZPROBE1'
  zsh_send "printf 'ZPROBE%s\n' 2" 'ZPROBE2'
  zsh_marks() { # how many distinct prompt marks previous-prompt can reach
    local seen=0 last="" now
    tmux -L "$copylast_socket" copy-mode -t "$zsh_pane"
    while ((seen < 12)); do
      tmux -L "$copylast_socket" send-keys -t "$zsh_pane" -X previous-prompt
      now="$(tmux -L "$copylast_socket" display-message -p -t "$zsh_pane" '#{copy_cursor_y}')"
      [[ "$now" != "$last" ]] || break
      last="$now"
      seen=$((seen + 1))
    done
    tmux -L "$copylast_socket" send-keys -t "$zsh_pane" -X cancel
    printf '%s\n' "$seen"
  }
  zsh_mark_count="$(zsh_marks)"
  ((zsh_mark_count >= 2)) \
    || fail "an interactive zsh with the rendered .zshrc registered no OSC 133 prompt marks (is the mark in a precmd hook instead of PROMPT?)"
  # Re-sourcing .zshrc (or the shell's own self-refresh) must not stack a second
  # mark onto PROMPT: duplicate marks give tmux two prompt positions per prompt
  # and make previous-prompt navigation unpredictable. Count the marks in PROMPT
  # itself rather than inferring from cursor movement.
  # grep -o | wc -l, never grep -c: grep -c counts matching LINES, so five marks
  # stacked on one prompt line would still report 1 and the test would pass.
  # shellcheck disable=SC2016 # this is zsh source text sent to a pane, not bash
  zsh_resource_cmd='source ~/.zshrc; source ~/.zshrc; printf "MK%s\n" "$(print -rn -- "$PROMPT" | grep -o "133;A" | wc -l | tr -d " ")"'
  tmux -L "$copylast_socket" send-keys -t "$zsh_pane" "$zsh_resource_cmd" Enter
  # Wait on a SEPARATE sentinel: any token inside the measurement command also
  # appears in the echoed command line, which would race the assertion.
  zsh_send "printf 'ZPROBE%s\n' 3" 'ZPROBE3'
  tmux -L "$copylast_socket" capture-pane -p -S - -t "$zsh_pane" >"$copylast_dir/zsh-marks"
  grep -qxF 'MK1' "$copylast_dir/zsh-marks" \
    || fail "re-sourcing .zshrc must leave exactly one OSC 133 mark in PROMPT (saw $(grep -oE '^MK[0-9]+$' "$copylast_dir/zsh-marks" | tail -n 1))"
  tmux -L "$copylast_socket" kill-server 2>/dev/null || true
  copylast_socket=""
fi

check "largest helper"
test -x home/dot_local/bin/executable_largest
largest_fixture="$out_dir/largest-fixture"
largest_bin="$out_dir/largest-bin"
mkdir -p "$largest_fixture" "$largest_bin"
cat >"$largest_bin/dust" <<'SH'
#!/usr/bin/env bash
printf '%s\n' "$@" >"$DUST_ARGS_FILE"
SH
chmod +x "$largest_bin/dust"
DUST_ARGS_FILE="$out_dir/dust-args" PATH="$largest_bin:$PATH" \
  home/dot_local/bin/executable_largest --files -n 7 "$largest_fixture" >"$out_dir/largest-output"
cat >"$out_dir/expected-dust-args" <<EOF
-x
-r
-n
7
-F
--
$largest_fixture
EOF
diff -u "$out_dir/expected-dust-args" "$out_dir/dust-args"
grep -qF 'Cleanup guide: match each result to its owner' "$out_dir/largest-output"
grep -qF 'groundwork-help largest' < <(home/dot_local/bin/executable_largest --help)
DUST_ARGS_FILE="$out_dir/dust-args" PATH="$largest_bin:$PATH" \
  home/dot_local/bin/executable_largest --no-advice "$largest_fixture" >"$out_dir/largest-no-advice"
assert_not_contains 'Cleanup guide' "$out_dir/largest-no-advice" "largest --no-advice printed cleanup guidance"
if home/dot_local/bin/executable_largest --files --folders "$largest_fixture" >/dev/null 2>&1; then
  fail "largest accepted mutually exclusive --files and --folders"
fi

check "docker helper suite setup"
# One scriptable docker stub serves the doctor, the tidy, the cache tidy, and
# the build wrapper. Its state is plain TSV files a test writes per case —
# images.tsv (id, tags comma-joined or -, ephemeral label, built label,
# created, size) and containers.tsv (id, image id, running|exited, name,
# ephemeral label, status text, created) — so each scenario is a declared
# policy state, not a hand-crafted case statement. Every argv is recorded one
# line per call, `image rm`/`container rm` mutate the state the way docker
# would (refusing multi-tag ID deletes and container-referenced deletes), and
# a trip hook can swap the image or container state mid-run to prove the
# apply-time re-checks.
docker_lib="$PWD/home/dot_local/share/groundwork/lib/docker-scan.sh"
test -f "$docker_lib"
docker_stub_bin="$out_dir/docker-stub"
mkdir -p "$docker_stub_bin"
cat >"$docker_stub_bin/docker" <<'SH'
#!/bin/bash
set -eu
state="${DOCKER_STATE:?}"
printf '%s\n' "$*" >>"$state/argv.log"
imgs="$state/images.tsv"; ctrs="$state/containers.tsv"
if [ -f "$state/fail.conf" ]; then
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    case "$*" in *"$f"*) exit 1 ;; esac
  done <"$state/fail.conf"
fi
if [ -f "$state/trip.conf" ]; then
  # shellcheck disable=SC1091
  . "$state/trip.conf"
  case "$*" in
    *"$TRIP_SUBSTR"*)
      tc="$(cat "$state/trip.count" 2>/dev/null || echo 0)"; tc=$((tc + 1))
      printf '%s\n' "$tc" >"$state/trip.count"
      if [ "$tc" -eq "$TRIP_AT" ]; then
        if [ -n "${TRIP_IMAGES:-}" ]; then cp "$TRIP_IMAGES" "$imgs"; fi
        if [ -n "${TRIP_CONTAINERS:-}" ]; then cp "$TRIP_CONTAINERS" "$ctrs"; fi
      fi
      ;;
  esac
fi
img_field() { awk -F'\t' -v id="$1" -v n="$2" '$1 == id { print $n; exit }' "$imgs"; }
img_exists() { awk -F'\t' -v id="$1" 'BEGIN { r = 1 } $1 == id { r = 0 } END { exit r }' "$imgs"; }
last_arg() { eval "printf '%s\n' \"\${$#}\""; }
case "$*" in
  info) exit 0 ;;
  'info --format {{.LoggingDriver}}') cat "$state/log-driver" 2>/dev/null || echo local ;;
  'info --format {{.Driver}}') echo overlayfs ;;
  'system df --format'*) printf 'Build Cache\t7.2GB\t7.2GB\n' ;;
  'system df') printf 'TYPE TOTAL ACTIVE SIZE RECLAIMABLE\n' ;;
  'images --no-trunc --filter label=dev.roost.ephemeral=true --format {{.ID}}'*)
    awk -F'\t' '$3 == "true" { n = split($2, t, ","); if ($2 == "-") n = 1; for (i = 1; i <= n; i++) print $1 "\t" $6 }' "$imgs" ;;
  'images -q --filter dangling=true')
    awk -F'\t' '$2 == "-" { print substr($1, 8, 12) }' "$imgs" ;;
  'ps -aq --no-trunc' | 'ps -aq')
    awk -F'\t' '{ print $1 }' "$ctrs" ;;
  'ps -aq --filter status=exited')
    awk -F'\t' '$3 == "exited" { print $1 }' "$ctrs" ;;
  'ps -a --no-trunc --filter status=exited --filter label=dev.roost.ephemeral=true --format {{.ID}}'*)
    awk -F'\t' '$3 == "exited" && $5 == "true" { print $1 "\t" $4 "\t" $6 }' "$ctrs" ;;
  'volume ls -q --filter dangling=true')
    cat "$state/volumes.txt" 2>/dev/null || true ;;
  'container inspect --format {{.Image}}'*)
    cid="$(last_arg "$@")"
    awk -F'\t' -v c="$cid" '$1 == c { print $2 "\t/" $4 "\t" $3; f = 1 } END { exit f ? 0 : 1 }' "$ctrs" ;;
  'container inspect --format {{.Created}}'*)
    cid="$(last_arg "$@")"
    awk -F'\t' -v c="$cid" '$1 == c { print ($7 == "" ? "-" : $7) "\t" $3 "\t" $2; f = 1 } END { exit f ? 0 : 1 }' "$ctrs" ;;
  'image inspect --format {{.Id}} '*)
    id="$(last_arg "$@")"; img_exists "$id" || exit 1; printf '%s\n' "$id" ;;
  'image inspect --format {{index .Config.Labels "dev.roost.ephemeral"}} '*)
    id="$(last_arg "$@")"; img_exists "$id" || exit 1
    v="$(img_field "$id" 3)"; [ "$v" = "-" ] && v="<no value>"; printf '%s\n' "$v" ;;
  'image inspect --format {{index .Config.Labels "dev.roost.built"}} '*)
    id="$(last_arg "$@")"; img_exists "$id" || exit 1
    v="$(img_field "$id" 4)"; [ "$v" = "-" ] && v="<no value>"; printf '%s\n' "$v" ;;
  'image inspect --format {{range .RepoTags}}{{println .}}{{end}} '*)
    id="$(last_arg "$@")"; img_exists "$id" || exit 1
    tags="$(img_field "$id" 2)"; [ "$tags" = "-" ] || printf '%s\n' "$tags" | tr ',' '\n' ;;
  'image inspect --format {{.Created}} '*)
    id="$(last_arg "$@")"; img_exists "$id" || exit 1; img_field "$id" 5 ;;
  'container rm '*)
    cid="$(last_arg "$@")"
    grep -q "^$cid	" "$ctrs" || { echo "no such container" >&2; exit 1; }
    grep -v "^$cid	" "$ctrs" >"$ctrs.tmp" || true
    mv "$ctrs.tmp" "$ctrs"; printf '%s\n' "$cid" ;;
  'image rm '*)
    ref="$(last_arg "$@")"
    if img_exists "$ref"; then
      id="$ref"
      if awk -F'\t' -v i="$id" 'BEGIN { r = 1 } $2 == i { r = 0 } END { exit r }' "$ctrs"; then
        echo "conflict: image is being used by a container" >&2; exit 1
      fi
      tags="$(img_field "$id" 2)"
      case "$tags" in
        *,*) echo "conflict: image is referenced in multiple repositories" >&2; exit 1 ;;
      esac
      grep -v "^$id	" "$imgs" >"$imgs.tmp" || true
      mv "$imgs.tmp" "$imgs"; echo "Deleted: $id"
    else
      row="$(awk -F'\t' -v t="$ref" '{ n = split($2, a, ","); for (i = 1; i <= n; i++) if (a[i] == t) { print $1; exit } }' "$imgs")"
      [ -n "$row" ] || { echo "no such image: $ref" >&2; exit 1; }
      tags="$(img_field "$row" 2)"
      case "$tags" in
        *,*)
          newtags="$(printf '%s\n' "$tags" | tr ',' '\n' | grep -vx "$ref" | paste -sd, -)"
          awk -F'\t' -v OFS='\t' -v id="$row" -v nt="$newtags" '$1 == id { $2 = nt } { print }' "$imgs" >"$imgs.tmp"
          mv "$imgs.tmp" "$imgs"; echo "Untagged: $ref"
          ;;
        *)
          if awk -F'\t' -v i="$row" 'BEGIN { r = 1 } $2 == i { r = 0 } END { exit r }' "$ctrs"; then
            echo "conflict: image is being used by a container" >&2; exit 1
          fi
          grep -v "^$row	" "$imgs" >"$imgs.tmp" || true
          mv "$imgs.tmp" "$imgs"; echo "Deleted: $row"
          ;;
      esac
    fi ;;
  'build '*)
    iid=""; tag=""; prev=""
    for a in "$@"; do
      case "$prev" in
        --iidfile) iid="$a" ;;
        -t) tag="$a" ;;
      esac
      prev="$a"
    done
    [ -n "$iid" ] && printf 'sha256:builtimage000\n' >"$iid"
    if [ -n "$tag" ]; then
      printf 'sha256:builtimage000\t%s\ttrue\t2026-01-01T00:00:00Z\t2026-01-01T00:00:00Z\t1.0GB\n' "$tag" >>"$imgs"
    fi
    echo "stub build ok" ;;
  *'prune'*) echo pruned ;;
  *) exit 0 ;;
esac
SH
chmod +x "$docker_stub_bin/docker"
# A hermetic tool PATH for the missing-jq case: the stub plus symlinks to the
# exact real tools the tidy and the scanner may use — and no jq.
docker_tools_nojq="$out_dir/docker-tools-nojq"
mkdir -p "$docker_tools_nojq"
for docker_tool in awk cat cp cut date grep head mv paste rm sed sort tr wc; do
  docker_tool_path="$(command -v "$docker_tool")" \
    || fail "docker suite: required tool missing: $docker_tool"
  ln -s "$docker_tool_path" "$docker_tools_nojq/$docker_tool"
done
unset docker_tool docker_tool_path
docker_state_init() {
  rm -rf "$1"
  mkdir -p "$1"
  : >"$1/images.tsv"
  : >"$1/containers.tsv"
  : >"$1/argv.log"
}
docker_run() {
  local state="$1" path_env="$2" script="$3"
  shift 3
  DOCKER_STATE="$state" PATH="$path_env" GROUNDWORK_DOCKER_LIB="$docker_lib" \
    /bin/bash "home/dot_local/bin/executable_$script" "$@"
}
docker_now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

check "groundwork-doctor helper"
test -x home/dot_local/bin/executable_groundwork-doctor
# The doctor reuses the shared scanner — the four scratch-image counts come
# from the same facts the tidy acts on, reported separately: a fresh in-grace
# image is NOT a leftover.
grep -qF 'lib/docker-scan.sh' home/dot_local/bin/executable_groundwork-doctor
doctor_state="$out_dir/doctor-state"
docker_state_init "$doctor_state"
printf 'sha256:young9999\tgroundwork/scratch:fresh\ttrue\t%s\t%s\t500MB\n' \
  "$docker_now" "$docker_now" >"$doctor_state/images.tsv"
printf 'c-plain\tsha256:otherbase\texited\told-c\t-\tExited (0) 3 days ago\n' >"$doctor_state/containers.tsv"
printf 'vol1\nvol2\n' >"$doctor_state/volumes.txt"
echo json-file >"$doctor_state/log-driver"
docker_run "$doctor_state" "$docker_stub_bin:$PATH" groundwork-doctor --docker >"$out_dir/doctor-output"
grep -qF 'read-only report; nothing is changed or deleted' "$out_dir/doctor-output"
grep -qF "log-driver is 'json-file'" "$out_dir/doctor-output"
grep -qF 'containerd image store is enabled' "$out_dir/doctor-output"
grep -qF 'stopped containers: 1' "$out_dir/doctor-output"
grep -qF 'dangling volumes:   2' "$out_dir/doctor-output"
grep -qF 'tidy-eligible (past grace):     0' "$out_dir/doctor-output"
grep -qF 'in grace (fresh, not leftover): 1' "$out_dir/doctor-output"
grep -qF 'groundwork-docker-cache-tidy' "$out_dir/doctor-output"
grep -qF "avoid blanket" "$out_dir/doctor-output"
assert_no_matches "the doctor must never prune or remove" grep -n 'prune\|rm ' "$doctor_state/argv.log"
# A machine whose only labeled image is fresh and in grace is CLEAN: no
# cleanup guidance, because an in-grace image is not a leftover.
docker_state_init "$doctor_state"
printf 'sha256:young9999\tgroundwork/scratch:fresh\ttrue\t%s\t%s\t500MB\n' \
  "$docker_now" "$docker_now" >"$doctor_state/images.tsv"
docker_run "$doctor_state" "$docker_stub_bin:$PATH" groundwork-doctor --docker >"$out_dir/doctor-fresh"
grep -qF 'in grace (fresh, not leftover): 1' "$out_dir/doctor-fresh"
assert_not_contains 'Cleanup guidance' "$out_dir/doctor-fresh" \
  "doctor flagged a fresh in-grace image as a leftover"
# A failed query is "unknown", never silently zero.
printf 'ps -aq --filter status=exited\n' >"$doctor_state/fail.conf"
docker_run "$doctor_state" "$docker_stub_bin:$PATH" groundwork-doctor --docker >"$out_dir/doctor-unknown"
grep -qF 'stopped containers: unknown' "$out_dir/doctor-unknown"
rm -f "$doctor_state/fail.conf"
grep -qF 'groundwork-help doctor' < <(home/dot_local/bin/executable_groundwork-doctor --help)
printf 'info\n' >"$doctor_state/fail.conf"
docker_run "$doctor_state" "$docker_stub_bin:$PATH" groundwork-doctor --docker >"$out_dir/doctor-down"
grep -qF 'Docker daemon not reachable' "$out_dir/doctor-down"
assert_not_contains 'Disk usage' "$out_dir/doctor-down" "doctor probed a down docker daemon"
if home/dot_local/bin/executable_groundwork-doctor --bogus >/dev/null 2>&1; then
  fail "groundwork-doctor accepted an unknown option"
fi

check "groundwork-docker-tidy helper"
test -x home/dot_local/bin/executable_groundwork-docker-tidy
grep -qF 'lib/docker-scan.sh' home/dot_local/bin/executable_groundwork-docker-tidy
# The default tidy acts BY ENUMERATION only. No prune of any kind may even
# appear in its source: candidate images are inspected, re-checked, and
# deleted by explicit image ID.
assert_no_matches "tidy must never hand deletion to a broad prune" \
  rg -n 'image prune|container prune|builder prune|system prune' \
  home/dot_local/bin/executable_groundwork-docker-tidy "$docker_lib"
grep -qF '*/scratch:*' "$docker_lib"
tidy_mixed_state() {
  # The policy-state fixture behind most scenarios, one image per rule:
  #   old1     old + labeled + scratch tag             -> eligible
  #   young1   labeled + scratch tag, built just now   -> retained (grace)
  #   hostile  ONE image ID tagged groundwork/scratch:review AND
  #            groundwork:latest (the retag hazard)    -> protected
  #   multi    two scratch tags on one image ID        -> ONE candidate
  #   runref   referenced by a RUNNING container       -> protected
  #   stopref  referenced by a STOPPED container       -> protected
  #   badts    malformed dev.roost.built               -> unverified
  #   nots     no dev.roost.built label                -> unverified
  #   dang1    unlabeled dangling image                -> not a candidate at all
  # plus two exited containers carrying the label: c-eph00 created long past
  # the grace (removed first) and c-ephyng created just now (retained — the
  # container grace policy matches the image grace policy).
  docker_state_init "$1"
  {
    printf 'sha256:old1000\tgroundwork/scratch:old\ttrue\t2001-01-01T00:00:00Z\t2001-01-01T00:00:00.000000000Z\t1.8GB\n'
    printf 'sha256:young100\tgroundwork/scratch:fresh\ttrue\t%s\t%s\t500MB\n' "$docker_now" "$docker_now"
    printf 'sha256:hostile0\tgroundwork/scratch:review,groundwork:latest\ttrue\t2001-01-01T00:00:00Z\t2001-01-01T00:00:00Z\t2.0GB\n'
    printf 'sha256:multi000\tgroundwork/scratch:a,groundwork/scratch:b\ttrue\t2001-01-02\t2001-01-02T00:00:00Z\t1.1GB\n'
    printf 'sha256:runref00\tgroundwork/scratch:runref\ttrue\t2001-01-01T00:00:00Z\t2001-01-01T00:00:00Z\t900MB\n'
    printf 'sha256:stopref0\tgroundwork/scratch:stopref\ttrue\t2001-01-01T00:00:00Z\t2001-01-01T00:00:00Z\t800MB\n'
    printf 'sha256:badts000\tgroundwork/scratch:badts\ttrue\tnot-a-date\t2001-01-01T00:00:00Z\t700MB\n'
    printf 'sha256:nots0000\tgroundwork/scratch:nots\ttrue\t-\t2001-01-01T00:00:00Z\t600MB\n'
    printf 'sha256:dang1000\t-\t-\t-\t2001-01-01T00:00:00Z\t300MB\n'
  } >"$1/images.tsv"
  {
    printf 'c-run00\tsha256:runref00\trunning\tkeeper\t-\tUp 2 hours\n'
    printf 'c-stop0\tsha256:stopref0\texited\tstopped-keeper\t-\tExited (0) 1 day ago\n'
    printf 'c-eph00\tsha256:otherbase\texited\ttidy-me\ttrue\tExited (0) 5 days ago\t2001-01-01T00:00:00.123456789Z\n'
    printf 'c-ephyng\tsha256:otherbase\texited\tfresh-exit\ttrue\tExited (0) 1 minute ago\t%s\n' "$docker_now"
  } >"$1/containers.tsv"
}
tidy_state="$out_dir/tidy-state"

# Scenario: dry run. Every verdict appears with its reason; the copy never
# claims "would remove"; nothing is mutated.
tidy_mixed_state "$tidy_state"
docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy >"$out_dir/tidy-dry"
grep -qF 'dry run — nothing was changed' "$out_dir/tidy-dry"
grep -F 'groundwork/scratch:old —' "$out_dir/tidy-dry" | grep -qF 'eligible'
grep -F 'groundwork/scratch:fresh' "$out_dir/tidy-dry" | grep -qF 'retained'
grep -F 'groundwork/scratch:fresh' "$out_dir/tidy-dry" | grep -qF 'grace'
grep -F 'groundwork:latest' "$out_dir/tidy-dry" | grep -qF 'protected'
grep -F 'groundwork:latest' "$out_dir/tidy-dry" | grep -qF 'tag outside the scratch namespace'
grep -F 'groundwork/scratch:runref' "$out_dir/tidy-dry" | grep -qF 'keeper (running)'
grep -F 'groundwork/scratch:stopref' "$out_dir/tidy-dry" | grep -qF 'stopped-keeper (exited)'
grep -F 'groundwork/scratch:badts' "$out_dir/tidy-dry" | grep -qF 'unverified'
grep -F 'groundwork/scratch:badts' "$out_dir/tidy-dry" | grep -qF 'malformed'
grep -F 'groundwork/scratch:nots' "$out_dir/tidy-dry" | grep -qF 'unverified'
test "$(grep -cF 'sha256:multi000' "$out_dir/tidy-dry")" = 1 \
  || fail "a multi-scratch-tag image must be ONE candidate, not one per tag"
grep -qF 'counts: 2 eligible, 1 retained (in grace), 3 protected, 2 unverified.' "$out_dir/tidy-dry"
grep -qF 'Docker may retain an item if another reference exists' "$out_dir/tidy-dry"
# Containers get the SAME grace policy, and the dry run enumerates each with
# id, name, age, and image — the old one eligible, the young one retained.
grep -F 'tidy-me' "$out_dir/tidy-dry" | grep -qF 'eligible'
grep -F 'fresh-exit' "$out_dir/tidy-dry" | grep -qF 'retained'
grep -F 'fresh-exit' "$out_dir/tidy-dry" | grep -qF 'grace'
grep -qF 'id c-eph00, age ' "$out_dir/tidy-dry"
grep -qF 'image sha256:otherbase' "$out_dir/tidy-dry"
grep -qF 'disposable only after the grace window' "$out_dir/tidy-dry"
grep -qF 'Never touched' "$out_dir/tidy-dry"
grep -qF 'groundwork-docker-cache-tidy' "$out_dir/tidy-dry"
assert_not_contains 'would remove' "$out_dir/tidy-dry" \
  "dry run claimed 'would remove' — the vocabulary is eligible/retained/protected/unverified"
assert_no_matches "tidy dry run must not remove or prune anything" \
  grep -nE ' rm |prune' "$tidy_state/argv.log"

# Scenario: apply. The labeled stopped container past the grace goes first
# (the young one is retained — same grace as images), each eligible image is
# re-checked and deleted by explicit image ID, a multi-tag image is untagged
# then ID-deleted once, and nothing protected, unverified, in grace,
# unlabeled, or daemon-wide is touched.
tidy_mixed_state "$tidy_state"
docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy --yes >"$out_dir/tidy-yes"
grep -qF 'container rm c-eph00' "$tidy_state/argv.log"
assert_no_matches "apply removed a young exited labeled container inside the grace" \
  grep -n 'container rm c-ephyng' "$tidy_state/argv.log"
grep -qF 'c-ephyng' "$tidy_state/containers.tsv" \
  || fail "young exited labeled container vanished despite being inside the grace"
grep -F 'fresh-exit' "$out_dir/tidy-yes" | grep -qF 'retained'
grep -qF 'image rm sha256:old1000' "$tidy_state/argv.log"
grep -qF 'image rm groundwork/scratch:b' "$tidy_state/argv.log"
grep -qF 'image rm sha256:multi000' "$tidy_state/argv.log"
if [[ "$(grep -n 'container rm c-eph00' "$tidy_state/argv.log" | cut -d: -f1)" \
  -gt "$(grep -n 'image rm' "$tidy_state/argv.log" | head -n 1 | cut -d: -f1)" ]]; then
  fail "the labeled exited container must be removed BEFORE image deletion"
fi
for tidy_kept in hostile0 runref00 stopref0 young100 badts000 nots0000 dang1000; do
  assert_no_matches "apply deleted a non-eligible image (sha256:$tidy_kept)" \
    grep -n "image rm sha256:$tidy_kept" "$tidy_state/argv.log"
done
unset tidy_kept
assert_no_matches "default --yes must not prune anything (no dangling/builder/daemon-wide cleanup)" \
  grep -n 'prune' "$tidy_state/argv.log"
assert_no_matches "tidy must never touch volumes" grep -n 'volume' "$tidy_state/argv.log"
grep -qF 'removed 1 container(s) and 2 image(s)' "$out_dir/tidy-yes"
if grep -qF 'sha256:old1000' "$tidy_state/images.tsv"; then
  fail "eligible image survived apply"
fi
grep -qF 'sha256:hostile0' "$tidy_state/images.tsv" || fail "protected image was deleted"
grep -qF 'sha256:dang1000' "$tidy_state/images.tsv" || fail "unlabeled dangling image was deleted"

# Scenario: the apply-time re-check. The image is eligible at scan time; the
# trip hook retags it groundwork:latest just before the re-check reads it, so
# deletion must be refused.
docker_state_init "$tidy_state"
printf 'sha256:reck0000\tgroundwork/scratch:reck\ttrue\t2001-01-01T00:00:00Z\t2001-01-01T00:00:00Z\t1.5GB\n' \
  >"$tidy_state/images.tsv"
printf 'sha256:reck0000\tgroundwork/scratch:reck,groundwork:latest\ttrue\t2001-01-01T00:00:00Z\t2001-01-01T00:00:00Z\t1.5GB\n' \
  >"$tidy_state/images-tripped.tsv"
cat >"$tidy_state/trip.conf" <<EOF
TRIP_SUBSTR='{{index .Config.Labels "dev.roost.ephemeral"}} sha256:reck0000'
TRIP_AT=2
TRIP_IMAGES=$tidy_state/images-tripped.tsv
EOF
docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy --yes >"$out_dir/tidy-recheck"
grep -qF 'state changed since the scan' "$out_dir/tidy-recheck"
assert_no_matches "apply deleted a candidate that changed after the scan" \
  grep -n 'image rm' "$tidy_state/argv.log"
grep -qF 'sha256:reck0000' "$tidy_state/images.tsv" || fail "re-check failed to protect the retagged image"

# Scenario: the container re-check. An old exited labeled container is
# eligible at scan time; the trip hook restarts it just before the pre-rm
# status re-check reads it, so removal must be refused.
docker_state_init "$tidy_state"
printf 'c-trip00\tsha256:otherbase\texited\ttrip-me\ttrue\tExited (0) 9 days ago\t2001-01-01T00:00:00Z\n' \
  >"$tidy_state/containers.tsv"
printf 'c-trip00\tsha256:otherbase\trunning\ttrip-me\ttrue\tUp 1 second\t2001-01-01T00:00:00Z\n' \
  >"$tidy_state/containers-tripped.tsv"
cat >"$tidy_state/trip.conf" <<EOF
TRIP_SUBSTR='container inspect --format {{.Created}}'
TRIP_AT=2
TRIP_CONTAINERS=$tidy_state/containers-tripped.tsv
EOF
docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy --yes >"$out_dir/tidy-ctr-recheck"
grep -qF 'state changed since the scan' "$out_dir/tidy-ctr-recheck"
assert_no_matches "apply removed a container whose status changed after the scan" \
  grep -n 'container rm' "$tidy_state/argv.log"
grep -qF 'c-trip00' "$tidy_state/containers.tsv" || fail "status re-check failed to protect the restarted container"
rm -f "$tidy_state/trip.conf" "$tidy_state/trip.count"

# Scenario: partial multi-tag cleanup honesty. The extra scratch tag untags
# cleanly, then the final ID delete is made to fail: the report must say
# "partially cleaned" and name the removed tags — never a plain "kept" that
# hides the untag that already happened.
docker_state_init "$tidy_state"
printf 'sha256:parti000\tgroundwork/scratch:pa,groundwork/scratch:pb\ttrue\t2001-01-02\t2001-01-02T00:00:00Z\t1.1GB\n' \
  >"$tidy_state/images.tsv"
printf 'image rm sha256:parti000\n' >"$tidy_state/fail.conf"
docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy --yes >"$out_dir/tidy-partial"
grep -qF 'partially cleaned: removed tags groundwork/scratch:pb; image retained because' "$out_dir/tidy-partial"
grep -F 'sha256:parti000' "$tidy_state/images.tsv" | grep -qF 'groundwork/scratch:pa' \
  || fail "partial-cleanup fixture lost its remaining tag state"
assert_no_matches "a partial multi-tag cleanup reported the plain kept verdict" \
  grep -n 'kept.*parti000\|parti000.*— docker refused the removal' "$out_dir/tidy-partial"
rm -f "$tidy_state/fail.conf"

# Scenario: no jq. Age cannot be verified, so the verdict is unverified —
# retained and explained, never "would remove", and never deleted.
tidy_nojq_state="$out_dir/tidy-nojq-state"
docker_state_init "$tidy_nojq_state"
printf 'sha256:oldnojq0\tgroundwork/scratch:nojq\ttrue\t2001-01-01T00:00:00Z\t2001-01-01T00:00:00Z\t1.8GB\n' \
  >"$tidy_nojq_state/images.tsv"
printf 'c-nojq00\tsha256:otherbase\texited\tnojq-c\ttrue\tExited (0) 9 days ago\t2001-01-01T00:00:00Z\n' \
  >"$tidy_nojq_state/containers.tsv"
docker_run "$tidy_nojq_state" "$docker_stub_bin:$docker_tools_nojq" groundwork-docker-tidy >"$out_dir/tidy-nojq"
grep -F 'groundwork/scratch:nojq' "$out_dir/tidy-nojq" | grep -qF 'unverified'
grep -F 'nojq-c' "$out_dir/tidy-nojq" | grep -qF 'unverified'
grep -qF 'jq' "$out_dir/tidy-nojq"
grep -qF 'counts: 0 eligible, 0 retained (in grace), 0 protected, 1 unverified.' "$out_dir/tidy-nojq"
assert_not_contains 'would remove' "$out_dir/tidy-nojq" \
  "an unverifiable image must never be presented as removable"
docker_run "$tidy_nojq_state" "$docker_stub_bin:$docker_tools_nojq" groundwork-docker-tidy --yes >/dev/null
assert_no_matches "apply deleted an image whose age could not be verified (no jq)" \
  grep -n 'image rm' "$tidy_nojq_state/argv.log"
assert_no_matches "apply removed a container whose age could not be verified (no jq)" \
  grep -n 'container rm' "$tidy_nojq_state/argv.log"

# --summary nudges on eligible/unverified leftovers and stays silent when the
# only labeled image is fresh and in grace.
tidy_mixed_state "$tidy_state"
docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy --summary >"$out_dir/tidy-summary"
grep -qF 'tidy-eligible' "$out_dir/tidy-summary"
# Only the past-grace container counts; the young exited one is not a leftover.
grep -qF '1 tidy-eligible exited ephemeral container(s)' "$out_dir/tidy-summary"
grep -qF 'groundwork-docker-tidy --yes' "$out_dir/tidy-summary"
assert_no_matches "tidy --summary must not remove or prune anything" \
  grep -nE ' rm |prune' "$tidy_state/argv.log"
docker_state_init "$tidy_state"
printf 'sha256:young9999\tgroundwork/scratch:fresh\ttrue\t%s\t%s\t500MB\n' \
  "$docker_now" "$docker_now" >"$tidy_state/images.tsv"
printf 'c-ephyng\tsha256:otherbase\texited\tfresh-exit\ttrue\tExited (0) 1 minute ago\t%s\n' \
  "$docker_now" >"$tidy_state/containers.tsv"
docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy --summary >"$out_dir/tidy-summary-clean"
test ! -s "$out_dir/tidy-summary-clean"

# Daemon down, option hygiene, conflicting modes, garbled policy env, and the
# missing shared scanner all fail the safe way.
docker_state_init "$tidy_state"
printf 'info\n' >"$tidy_state/fail.conf"
docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy >"$out_dir/tidy-down"
grep -qF 'Docker daemon not reachable' "$out_dir/tidy-down"
rm -f "$tidy_state/fail.conf"
grep -qF 'groundwork-help docker' < <(GROUNDWORK_DOCKER_LIB="$docker_lib" \
  home/dot_local/bin/executable_groundwork-docker-tidy --help)
if docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy --bogus >/dev/null 2>&1; then
  fail "groundwork-docker-tidy accepted an unknown option"
fi
if docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy --yes --summary \
  >"$out_dir/tidy-conflict" 2>&1; then
  fail "groundwork-docker-tidy accepted conflicting modes instead of rejecting them"
fi
grep -qF 'mutually exclusive' "$out_dir/tidy-conflict"
if GROUNDWORK_DOCKER_TIDY_MAX_AGE_HOURS=abc \
  docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy \
  >"$out_dir/tidy-badenv" 2>&1; then
  fail "groundwork-docker-tidy acted on a garbled grace-window policy"
fi
grep -qF 'invalid GROUNDWORK_DOCKER_TIDY_MAX_AGE_HOURS' "$out_dir/tidy-badenv"
if GROUNDWORK_DOCKER_TIDY_MAX_AGE_HOURS=99999 \
  docker_run "$tidy_state" "$docker_stub_bin:$PATH" groundwork-docker-tidy \
  >/dev/null 2>&1; then
  fail "groundwork-docker-tidy accepted an out-of-range grace window"
fi
if DOCKER_STATE="$tidy_state" PATH="$docker_stub_bin:$PATH" \
  GROUNDWORK_DOCKER_LIB=/nonexistent-groundwork-docker-lib \
  /bin/bash home/dot_local/bin/executable_groundwork-docker-tidy \
  >"$out_dir/tidy-nolib" 2>&1; then
  fail "groundwork-docker-tidy ran without the shared docker-scan probe"
fi
grep -qF 'docker-scan probe is missing' "$out_dir/tidy-nolib"

check "groundwork-docker-cache-tidy helper"
# Daemon-wide cleanup is a SEPARATE, owner-only command: it says it reaches
# every project, it dry-runs by default, and no refresh or scheduled path may
# ever invoke it.
test -x home/dot_local/bin/executable_groundwork-docker-cache-tidy
grep -qF 'lib/docker-scan.sh' home/dot_local/bin/executable_groundwork-docker-cache-tidy
assert_no_matches "the daemon-wide cache tidy leaked into a scheduled or refresh path" \
  rg -n 'docker-cache-tidy' \
  home/dot_local/bin/executable_update-all \
  home/dot_local/bin/executable_groundwork-update-run.tmpl \
  home/dot_zshrc.tmpl home/run_after_20-tools.sh.tmpl \
  home/run_onchange_after_10-brew-bundle.sh.tmpl
# update-all keeps only the tidy's silent one-liner, and the helper owns
# docker reachability itself — no duplicated probe in the runner.
grep -qF 'groundwork-docker-tidy" --summary' home/dot_local/bin/executable_groundwork-update-run.tmpl
assert_no_matches "update-run must not duplicate the tidy's docker reachability probe" \
  rg -n 'docker info' home/dot_local/bin/executable_groundwork-update-run.tmpl
cache_state="$out_dir/cache-state"
docker_state_init "$cache_state"
printf 'sha256:dangx000\t-\t-\t-\t2001-01-01T00:00:00Z\t300MB\n' >"$cache_state/images.tsv"
printf 'c-plain\tsha256:otherbase\texited\told-c\t-\tExited (0) 3 days ago\n' >"$cache_state/containers.tsv"
docker_run "$cache_state" "$docker_stub_bin:$PATH" groundwork-docker-cache-tidy >"$out_dir/cache-dry"
grep -qF 'DAEMON-WIDE' "$out_dir/cache-dry"
grep -qF 'ALL projects' "$out_dir/cache-dry"
grep -qF 'Dry run — nothing was changed' "$out_dir/cache-dry"
grep -qF 'does not guarantee' "$out_dir/cache-dry"
assert_no_matches "cache tidy dry run must not prune anything" grep -n 'prune' "$cache_state/argv.log"
docker_run "$cache_state" "$docker_stub_bin:$PATH" groundwork-docker-cache-tidy --yes >"$out_dir/cache-yes"
grep -qF 'container prune --force' "$cache_state/argv.log"
grep -qF 'image prune --force' "$cache_state/argv.log"
grep -qF 'builder prune --force --keep-storage 5GB' "$cache_state/argv.log"
grep -qF 'retention target' "$out_dir/cache-yes"
assert_no_matches "cache tidy must never touch volumes" grep -n 'volume' "$cache_state/argv.log"
: >"$cache_state/argv.log"
GROUNDWORK_DOCKER_CACHE_TIDY_KEEP_STORAGE=20GiB \
  docker_run "$cache_state" "$docker_stub_bin:$PATH" groundwork-docker-cache-tidy --yes >/dev/null
grep -qF 'builder prune --force --keep-storage 20GiB' "$cache_state/argv.log"
if GROUNDWORK_DOCKER_CACHE_TIDY_KEEP_STORAGE=lots \
  docker_run "$cache_state" "$docker_stub_bin:$PATH" groundwork-docker-cache-tidy \
  >"$out_dir/cache-badenv" 2>&1; then
  fail "groundwork-docker-cache-tidy accepted a keep-storage value outside the closed size format"
fi
grep -qF 'invalid GROUNDWORK_DOCKER_CACHE_TIDY_KEEP_STORAGE' "$out_dir/cache-badenv"
if docker_run "$cache_state" "$docker_stub_bin:$PATH" groundwork-docker-cache-tidy --yes --dry-run \
  >/dev/null 2>&1; then
  fail "groundwork-docker-cache-tidy accepted conflicting modes"
fi
if docker_run "$cache_state" "$docker_stub_bin:$PATH" groundwork-docker-cache-tidy --bogus >/dev/null 2>&1; then
  fail "groundwork-docker-cache-tidy accepted an unknown option"
fi
grep -qF 'groundwork-help docker' < <(GROUNDWORK_DOCKER_LIB="$docker_lib" \
  home/dot_local/bin/executable_groundwork-docker-cache-tidy --help)

check "groundwork-docker-build-scratch helper"
# The wrapper owns the contract's syntax: both labels, a generated RFC 3339
# build clock, the scratch-namespace tag, a printed image ID — and it refuses
# forwarded arguments that could break any of that.
test -x home/dot_local/bin/executable_groundwork-docker-build-scratch
build_state="$out_dir/build-state"
build_ctx="$out_dir/buildctx"
docker_state_init "$build_state"
mkdir -p "$build_ctx"
printf 'FROM scratch\n' >"$build_ctx/Dockerfile"
docker_run "$build_state" "$docker_stub_bin:$PATH" groundwork-docker-build-scratch \
  review "$build_ctx" -- --build-arg FOO=bar >"$out_dir/build-out"
grep -qF -- '--label dev.roost.ephemeral=true' "$build_state/argv.log"
grep -qE -- '--label dev\.roost\.built=[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z ' "$build_state/argv.log"
grep -qF -- '-t buildctx/scratch:review' "$build_state/argv.log"
grep -qF -- '--build-arg FOO=bar' "$build_state/argv.log"
grep -qF 'image id: sha256:builtimage000' "$out_dir/build-out"
docker_state_init "$build_state"
docker_run "$build_state" "$docker_stub_bin:$PATH" groundwork-docker-build-scratch \
  review "$build_ctx" --project myproj --rm-after >"$out_dir/build-rmafter"
grep -qF -- '-t myproj/scratch:review' "$build_state/argv.log"
grep -qF 'image rm sha256:builtimage000' "$build_state/argv.log"
grep -qF 'removed after build' "$out_dir/build-rmafter"
docker_state_init "$build_state"
if docker_run "$build_state" "$docker_stub_bin:$PATH" groundwork-docker-build-scratch \
  'bad purpose!' "$build_ctx" >"$out_dir/build-badpurpose" 2>&1; then
  fail "groundwork-docker-build-scratch accepted an illegal tag component as the purpose"
fi
grep -qF 'invalid purpose' "$out_dir/build-badpurpose"
assert_no_matches "an invalid purpose still reached docker build" grep -n 'build' "$build_state/argv.log"
for build_bad_arg in '-t' '--tag=evil' '--iidfile'; do
  if docker_run "$build_state" "$docker_stub_bin:$PATH" groundwork-docker-build-scratch \
    review "$build_ctx" -- "$build_bad_arg" evil >/dev/null 2>&1; then
    fail "groundwork-docker-build-scratch forwarded '$build_bad_arg', which breaks the contract it owns"
  fi
done
unset build_bad_arg
if docker_run "$build_state" "$docker_stub_bin:$PATH" groundwork-docker-build-scratch \
  review "$build_ctx" -- --label dev.roost.ephemeral=false >/dev/null 2>&1; then
  fail "groundwork-docker-build-scratch let a forwarded --label override the lifecycle labels"
fi
# Forwarding is a closed allowlist. Allowed options pass through in both
# separate-value and = forms; --output/-o/--push are refused by name (the
# contract requires a local inspectable image); unknown options are refused
# rather than trusted.
docker_state_init "$build_state"
docker_run "$build_state" "$docker_stub_bin:$PATH" groundwork-docker-build-scratch \
  review "$build_ctx" -- --file "$build_ctx/Dockerfile" --target=final --no-cache \
  --platform linux/arm64 >/dev/null
grep -qF -- "--file $build_ctx/Dockerfile" "$build_state/argv.log"
grep -qF -- '--target=final' "$build_state/argv.log"
grep -qF -- '--no-cache' "$build_state/argv.log"
grep -qF -- '--platform linux/arm64' "$build_state/argv.log"
for build_out_arg in '--output' '-o' '--push' '--output=type=local,dest=/tmp/x'; do
  docker_state_init "$build_state"
  if docker_run "$build_state" "$docker_stub_bin:$PATH" groundwork-docker-build-scratch \
    review "$build_ctx" -- "$build_out_arg" dest >"$out_dir/build-output-refused" 2>&1; then
    fail "groundwork-docker-build-scratch forwarded '$build_out_arg', which exports the image away from local inspection"
  fi
  grep -qF 'unsupported' "$out_dir/build-output-refused"
  grep -qF 'local inspectable image' "$out_dir/build-output-refused"
  assert_no_matches "a refused '$build_out_arg' still reached docker build" \
    grep -n 'build' "$build_state/argv.log"
done
unset build_out_arg
docker_state_init "$build_state"
if docker_run "$build_state" "$docker_stub_bin:$PATH" groundwork-docker-build-scratch \
  review "$build_ctx" -- --squash >"$out_dir/build-unknown-refused" 2>&1; then
  fail "groundwork-docker-build-scratch forwarded an option outside the allowlist"
fi
grep -qF 'not in the allowlist' "$out_dir/build-unknown-refused"
assert_no_matches "an option outside the allowlist still reached docker build" \
  grep -n 'build' "$build_state/argv.log"
grep -qF 'groundwork-help docker' < <(home/dot_local/bin/executable_groundwork-docker-build-scratch --help)
# Catalog rows for the whole docker family stay discoverable.
grep -qF $'daily\tgroundwork-docker-tidy\tcommand\t' home/dot_local/share/groundwork/commands.tsv
grep -qF $'daily\tgroundwork-docker-cache-tidy\tcommand\t' home/dot_local/share/groundwork/commands.tsv
grep -qF $'project\tgroundwork-docker-build-scratch <purpose> <context>\tcommand\t' home/dot_local/share/groundwork/commands.tsv

check "groundwork-repos helper"
test -x home/dot_local/bin/executable_groundwork-repos
# file_mtime must emit ONLY a number under any stat variant. On GNU stat,
# `-f` means "filesystem status" and can exit 0 printing a block that starts
# with "File:" — which broke CI with "File: unbound variable" the moment it
# reached arithmetic. Drive the extracted function with a GNU-like stub and
# a pathological always-garbage stub.
repos_stat_fixture="$out_dir/repos-stat"
mkdir -p "$repos_stat_fixture/gnu-bin" "$repos_stat_fixture/bsd-bin" "$repos_stat_fixture/weird-bin"
cat >"$repos_stat_fixture/gnu-bin/stat" <<'SH'
#!/usr/bin/env bash
if [[ "$1" == "-c" ]]; then echo 1752900000; exit 0; fi
printf '  File: "/some/path"\n    ID: 100000 Namelen: 255\n'
SH
# BSD/macOS: -c is an invalid flag; -f %m answers. Stubbing it keeps the
# test independent of whichever real stat this machine happens to have.
cat >"$repos_stat_fixture/bsd-bin/stat" <<'SH'
#!/usr/bin/env bash
if [[ "$1" == "-c" ]]; then exit 1; fi
if [[ "$1" == "-f" ]]; then echo 1752900001; exit 0; fi
exit 1
SH
cat >"$repos_stat_fixture/weird-bin/stat" <<'SH'
#!/usr/bin/env bash
printf '  File: "/some/path"\n'
SH
chmod +x "$repos_stat_fixture/gnu-bin/stat" "$repos_stat_fixture/bsd-bin/stat" \
  "$repos_stat_fixture/weird-bin/stat"
sed -n '/^file_mtime()/,/^}/p' home/dot_local/bin/executable_groundwork-repos \
  >"$repos_stat_fixture/file_mtime.sh"
grep -q 'file_mtime()' "$repos_stat_fixture/file_mtime.sh" \
  || fail "could not extract file_mtime from groundwork-repos for the stat-variant test"
repos_mtime="$(PATH="$repos_stat_fixture/gnu-bin:/usr/bin:/bin" bash -uc \
  ". '$repos_stat_fixture/file_mtime.sh'; file_mtime /tmp")" \
  || fail "file_mtime failed under a GNU-like stat"
[[ "$repos_mtime" == "1752900000" ]] \
  || fail "file_mtime under GNU-like stat must return the -c %Y value, got: $repos_mtime"
repos_mtime="$(PATH="$repos_stat_fixture/bsd-bin:/usr/bin:/bin" bash -uc \
  ". '$repos_stat_fixture/file_mtime.sh'; file_mtime /tmp")" \
  || fail "file_mtime failed under a BSD-like stat"
[[ "$repos_mtime" == "1752900001" ]] \
  || fail "file_mtime under BSD-like stat must fall back to -f %m, got: $repos_mtime"
repos_mtime="$(PATH="$repos_stat_fixture/weird-bin:/usr/bin:/bin" bash -uc \
  ". '$repos_stat_fixture/file_mtime.sh'; file_mtime /tmp")" \
  || fail "file_mtime failed under a garbage-emitting stat"
[[ "$repos_mtime" == "0" ]] \
  || fail "file_mtime must emit 0 when no stat variant yields a number, got: $repos_mtime"
test -f home/dot_config/groundwork/repos.conf.tmpl
test -f home/dot_config/lazygit/config.yml
# Discovery stays dynamic: the managed config configures ROOTS, never names.
grep -qF 'root = {{ .code_dir }}' home/dot_config/groundwork/repos.conf.tmpl
grep -qF 'max_depth' home/dot_config/groundwork/repos.conf.tmpl
grep -qF 'include_worktrees' home/dot_config/groundwork/repos.conf.tmpl
grep -qF 'cache_ttl_seconds' home/dot_config/groundwork/repos.conf.tmpl
grep -qF 'exclude = node_modules' home/dot_config/groundwork/repos.conf.tmpl
# The deliberately simple config format documents its own limitation.
grep -qF 'paths containing' home/dot_config/groundwork/repos.conf.tmpl
# Inspection safety: the safe_git wrapper and the fzf preview both disable
# repository hooks and the fsmonitor; the behavior proof is the fsmonitor
# tripwire below.
grep -qF 'core.hooksPath=/dev/null' home/dot_local/bin/executable_groundwork-repos
grep -F -- '--preview' home/dot_local/bin/executable_groundwork-repos | grep -qF 'core.fsmonitor=false'
# Docs promise the precise guarantee, not a blanket "never executed", and
# the honest cache timing (TTL or --refresh), not "next run".
assert_no_matches "docs/config claim a blanket never-executed guarantee for discovery" \
  rg -n 'ever executed|never executes code' docs/repo-navigation.html home/dot_config/groundwork/repos.conf.tmpl
