for page in docs/*.html; do
  # Search-engine verification stubs (google*.html) live in docs/ but are
  # not pages; the same marker rule generate-discovery uses.
  grep -q 'property="og:site_name" content="Groundwork"' "$page" || continue
  grep -q 'name="description"' "$page" || { echo "$page: missing description meta tag" >&2; exit 1; }
  grep -q ' · Groundwork</title>' "$page" || { echo "$page: page title must use middle dot separator: Page · Groundwork" >&2; exit 1; }
  grep -q 'property="og:title"' "$page" || { echo "$page: missing Open Graph title" >&2; exit 1; }
  grep -q 'property="og:title" content=".* · Groundwork"' "$page" || { echo "$page: Open Graph title must use middle dot separator: Page · Groundwork" >&2; exit 1; }
  grep -q 'property="og:url" content="https://jasondockery.github.io/groundwork/'"$(basename "$page")"'"' "$page" || { echo "$page: missing Open Graph URL" >&2; exit 1; }
  grep -q 'name="twitter:title" content=".* · Groundwork"' "$page" || { echo "$page: Twitter title must use middle dot separator: Page · Groundwork" >&2; exit 1; }
  grep -q 'property="og:image" content="https://jasondockery.github.io/groundwork/assets/social-card.png"' "$page" || { echo "$page: missing PNG Open Graph image" >&2; exit 1; }
  grep -q 'rel="canonical" href="https://jasondockery.github.io/groundwork/'"$(basename "$page")"'"' "$page" || { echo "$page: missing canonical URL" >&2; exit 1; }
  grep -q 'rel="icon"' "$page" || { echo "$page: missing favicon link" >&2; exit 1; }
  grep -q '<a class="skip-link" href="#main">Skip to content</a>' "$page" || { echo "$page: missing skip link" >&2; exit 1; }
  grep -q '<main id="main" class="main">' "$page" || { echo "$page: missing main landmark id" >&2; exit 1; }
  grep -q 'data-nav-toggle aria-controls="site-sidebar" aria-expanded="false"' "$page" || { echo "$page: mobile nav toggle missing aria-controls/expanded" >&2; exit 1; }
  grep -q '<aside id="site-sidebar" class="sidebar">' "$page" || { echo "$page: sidebar missing controlled id" >&2; exit 1; }
  grep -q '<div class="scrim" aria-hidden="true"></div>' "$page" || { echo "$page: scrim missing aria-hidden" >&2; exit 1; }
  grep -q 'localStorage.getItem("fg-theme")' "$page" || { echo "$page: missing early theme bootstrap" >&2; exit 1; }
  assert_not_contains 'data-theme="dark"' "$page" "$page: hardcoded dark theme causes light-theme flash"
  grep -q 'href="platforms.html"' "$page" || { echo "$page: missing Platforms sidebar link" >&2; exit 1; }
  for group in "Start here" "Set up" "Foundations" "Daily workflow" "Directing agents" "AI tools" "Interest tracks" "Mac desktop" "Reference"; do
    grep -q "<h4>$group</h4>" "$page" || { echo "$page: missing sidebar group: $group" >&2; exit 1; }
  done
  active_count="$(grep -c 'class="active"' "$page" || true)"
  [[ "$active_count" == "1" ]] || { echo "$page: expected one active sidebar link, found $active_count" >&2; exit 1; }
done
# Every page carries its own copy of the sidebar; with the active marker
# stripped they must be identical, or link order and grouping silently drift
# page by page. The og:site_name marker is the same site-page rule as
# generate-discovery's is_site_page().
python3 - <<'PY'
import pathlib, re, sys
aside_re = re.compile(r'<aside id="site-sidebar".*?</aside>', re.S)
reference, reference_page = None, None
for page in sorted(pathlib.Path("docs").glob("*.html")):
    text = page.read_text()
    if 'property="og:site_name" content="Groundwork"' not in text:
        continue
    m = aside_re.search(text)
    if not m:
        sys.exit(f"{page}: sidebar <aside> block not found")
    nav = m.group(0).replace(' class="active"', "")
    if reference is None:
        reference, reference_page = nav, page
    elif nav != reference:
        sys.exit(f"{page}: sidebar differs from {reference_page}; every page must carry the identical sidebar (only the active marker may vary)")
PY
assert_no_matches "old docs title separator found" rg -n '(<title>[^<]*( — | -- | - )Groundwork|<(meta)[^>]+content="[^"]*( — | -- | - )Groundwork")' docs
assert_no_matches "old macOS windows label found" rg -n "macOS windows" docs README.md
assert_no_matches "old sidebar group label found" rg -n '<h4>(The path|Workflows|Tracks)</h4>' docs
commands_page_text="$(
  sed -E 's/<[^>]+>/ /g; s/&lt;/</g; s/&gt;/>/g; s/&amp;/\\&/g; s/&quot;/\"/g; s/&#39;/'"'"'/g' docs/commands.html |
    tr '\n' ' ' |
    tr -s '[:space:]' ' '
)"
while IFS=$'\t' read -r _category command _kind _description; do
  [[ -n "$command" && "$command" != \#* ]] || continue
  command_key="${command%% *}"
  case "$command" in
    Ctrl+a*) command_key="Ctrl a" ;;
    Ctrl+R) command_key="Ctrl R" ;;
    Ctrl+T) command_key="Ctrl T" ;;
    Alt+C) command_key="Alt C" ;;
    Alt+h*) command_key="Alt h" ;;
    "vim / vi") command_key="vim" ;;
    *update_plugins*) command_key="update_plugins" ;;
  esac
  grep -Fq "$command_key" <<<"$commands_page_text" || { echo "docs/commands.html missing command catalog entry for: $command" >&2; exit 1; }
done < home/dot_local/share/groundwork/commands.tsv

