  home/dot_local/bin/executable_groundwork-repos
# lazygit defaults keep their agent-inspection and accessibility contract.
grep -qF 'editPreset: nvim' home/dot_config/lazygit/config.yml
grep -qF 'language: auto' home/dot_config/lazygit/config.yml
grep -qF 'showBottomLine: true' home/dot_config/lazygit/config.yml
