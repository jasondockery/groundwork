check "update-flow safety contract"
# `chezmoi apply --force` would turn the overwrite question into silent data
# loss: local drift gets clobbered with no prompt. The drift preflight in
# update-all names the files and chezmoi asks — force is never the answer.
assert_no_matches "chezmoi apply --force silently clobbers local drift; the apply must ask" \
  rg -n -g '!validate-groundwork' 'chezmoi (apply|update)[^#]*--force' home bootstrap-mac.sh docker scripts
# Disabling Homebrew's tap-trust check would reopen the supply-chain gate it
# exists to close; per-formula `brew trust` is the documented narrow path.
assert_no_matches "never disable Homebrew tap trust; trust specific formulae instead" \
  rg -n 'HOMEBREW_NO_REQUIRE_TAP_TRUST' home bootstrap-mac.sh docker
# The declined-reset branch is the steady state on most machines and must be
# SILENT on routine updates — a future template edit must not quietly bring
# back per-run no-op chatter. (Static guard first: this render must be the
# declined branch, so running it can never move real files.)
render linux false amd64 home/run_before_06-reset-conflicting-configs.sh.tmpl \
  "$out_dir/reset-declined.sh"
if grep -qF 'move_path' "$out_dir/reset-declined.sh"; then
  fail "the reset render unexpectedly produced the ACTIVE branch; refusing to run it"
fi
reset_declined_home="$out_dir/reset-declined-home"
mkdir -p "$reset_declined_home"
HOME="$reset_declined_home" bash "$out_dir/reset-declined.sh" \
  >"$out_dir/reset-declined-out" 2>&1 \
  || fail "the declined reset branch must exit 0"
test ! -s "$out_dir/reset-declined-out" \
  || fail "the declined reset branch must produce no output on routine updates"

check "old name residue"
assert_no_matches "old name residue found" rg -n "Primer|primer|mac-dev-primer|Mac Dev|MAC_DEV_PRIMER|validate-primer|jasondockery/mac-dev-primer|PRIMER" . --hidden -g '!.git' -g '!node_modules' -g '!scripts/validate-groundwork'

check "discovery artifacts current (descriptions, sitemap, llms.txt)"
scripts/generate-discovery --check

check "discovery generator fails closed on a shallow clone"
# The regression: a shallow checkout made git log report HEAD's date for every
# page. The generator must now refuse rather than emit silently-wrong dates.
# file:// forces the transport that honors --depth (a plain path hardlink-clones
# and ignores it). Test the working-tree generator, not the committed copy.
shallow_dir="$(mktemp -d "${TMPDIR:-/tmp}/groundwork-shallow.XXXXXX")"
git clone --quiet --depth 1 "file://$PWD/.git" "$shallow_dir/repo"
cp scripts/generate-discovery "$shallow_dir/repo/scripts/generate-discovery"
if (cd "$shallow_dir/repo" && python3 scripts/generate-discovery --check) \
    >/dev/null 2>"$shallow_dir/err"; then
  echo "generate-discovery did not fail closed in a shallow clone" >&2
  rm -rf "$shallow_dir"
  exit 1
fi
if ! grep -qi shallow "$shallow_dir/err"; then
  echo "generate-discovery failed in a shallow clone but not with the shallow message" >&2
  cat "$shallow_dir/err" >&2
  rm -rf "$shallow_dir"
  exit 1
fi
rm -rf "$shallow_dir"

check "discovery generator lastmod: committed date vs today for dirty/untracked"
# Black-box all three date paths in a throwaway repo: a clean committed page
# keeps its actual commit date, while dirty and untracked pages get today.
# Pages carry the description the generator would compute, so it stays
# idempotent (no metadata rewrite that would otherwise dirty a committed page).
datefx_dir="$(mktemp -d "${TMPDIR:-/tmp}/groundwork-datefx.XXXXXX")"
write_fixture_page() {
  printf '%s' '<html><head><meta name="description" content="Lead."><meta property="og:site_name" content="Groundwork"><title>T</title></head><body><div class="content"><p class="lead">Lead.</p></div></body></html>' > "$1"
}
if ! (
  cd "$datefx_dir" || exit 1
  git init -q
  git config user.email t@example.com
  git config user.name tester
  mkdir -p docs scripts
  cp "$repo/scripts/generate-discovery" scripts/generate-discovery
  write_fixture_page docs/a.html
  write_fixture_page docs/b.html
  export GIT_AUTHOR_DATE="2020-01-01T00:00:00" GIT_COMMITTER_DATE="2020-01-01T00:00:00"
  git add -A
  git commit -qm init
  unset GIT_AUTHOR_DATE GIT_COMMITTER_DATE
  printf '\n' >> docs/b.html       # tracked and dirty
  write_fixture_page docs/c.html   # untracked
  python3 scripts/generate-discovery >/dev/null
  python3 - <<'PY'
import datetime
import xml.etree.ElementTree as ET

namespace = {"sitemap": "http://www.sitemaps.org/schemas/sitemap/0.9"}
entries = [
    (
        element.findtext("sitemap:loc", namespaces=namespace),
        element.findtext("sitemap:lastmod", namespaces=namespace),
    )
    for element in ET.parse("docs/sitemap.xml").getroot().findall("sitemap:url", namespace)
]
actual = dict(entries)
today = datetime.date.today().isoformat()
expected = {
    "https://jasondockery.github.io/groundwork/a.html": "2020-01-01",
    "https://jasondockery.github.io/groundwork/b.html": today,
    "https://jasondockery.github.io/groundwork/c.html": today,
}
if len(entries) != len(actual) or actual != expected:
    raise SystemExit(f"unexpected sitemap lastmod mapping: {actual!r}; expected {expected!r}")
PY
); then
  rm -rf "$datefx_dir"
  exit 1
fi
rm -rf "$datefx_dir"

check "whitespace"
git diff --check

echo "ok: Groundwork validation passed"
