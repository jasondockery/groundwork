check "template brace balance"
while IFS= read -r template; do
  left=$(grep -o '{{' "$template" | wc -l | tr -d ' ' || true)
  right=$(grep -o '}}' "$template" | wc -l | tr -d ' ' || true)
  [[ "$left" == "$right" ]] || { echo "unbalanced template braces: $template" >&2; exit 1; }
done < <(find . -path ./.git -prune -o -name '*.tmpl' -print)

shell_templates=(home/run_*.sh.tmpl home/dot_local/bin/*.tmpl)
for os in darwin linux; do
  for headless in false true; do
    case_name="${os}-${headless}"
    mkdir -p "$out_dir/$case_name"
    check "rendered shell templates ($case_name)"
    for script in "${shell_templates[@]}"; do
      rendered="$out_dir/$case_name/$(basename "${script%.tmpl}")"
      render "$os" "$headless" "amd64" "$script" "$rendered"
      bash -n "$rendered"
      run_shellcheck "$rendered"
    done

    check "rendered zsh ($case_name)"
    render "$os" "$headless" "amd64" home/dot_zshrc.tmpl "$out_dir/$case_name/zshrc"
    render "$os" "$headless" "amd64" home/dot_zprofile.tmpl "$out_dir/$case_name/zprofile"
    zsh -n "$out_dir/$case_name/zshrc"
    zsh -n "$out_dir/$case_name/zprofile"

    check "rendered tmux ($case_name)"
    render "$os" "$headless" "amd64" home/dot_config/tmux/tmux.conf.tmpl "$out_dir/$case_name/tmux.conf"
    grep -qF "set-environment -g TMUX_PLUGIN_MANAGER_PATH \"\$HOME/.config/tmux/plugins/\"" "$out_dir/$case_name/tmux.conf"
    if [[ "$headless" == "true" ]]; then
      grep -qF "set -g @continuum-restore 'off'" "$out_dir/$case_name/tmux.conf"
      assert_not_contains "@continuum-restore 'on'" "$out_dir/$case_name/tmux.conf" "continuum auto-restore leaked into $case_name tmux config"
    else
      grep -qF "set -g @continuum-restore 'on'" "$out_dir/$case_name/tmux.conf"
      assert_not_contains "@continuum-restore 'off'" "$out_dir/$case_name/tmux.conf" "continuum auto-restore disabled in $case_name tmux config"
    fi

    check "rendered Brewfile ($case_name)"
    render "$os" "$headless" "amd64" home/dot_config/homebrew/Brewfile.tmpl "$out_dir/$case_name/Brewfile"
    if [[ "$os" == "linux" || "$headless" == "true" ]]; then
      assert_not_contains '^(cask|mas) ' "$out_dir/$case_name/Brewfile" "cask/mas leaked into $case_name Brewfile"
    fi

    check "rendered ignore ($case_name)"
    render "$os" "$headless" "amd64" home/.chezmoiignore "$out_dir/$case_name/chezmoiignore"
    if [[ "$os" != "darwin" || "$headless" == "true" ]]; then
      grep -q '^Library/\*\*' "$out_dir/$case_name/chezmoiignore"
      grep -q '^\.config/karabiner/\*\*' "$out_dir/$case_name/chezmoiignore"
    fi

    if [[ "$os" == "linux" || "$headless" == "true" ]]; then
      render "$os" "$headless" "amd64" home/run_onchange_after_30-macos-defaults.sh.tmpl "$out_dir/$case_name/macos-defaults.sh"
      assert_not_contains 'defaults write' "$out_dir/$case_name/macos-defaults.sh" "macOS defaults leaked into $case_name"
