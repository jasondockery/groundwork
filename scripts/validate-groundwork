#!/usr/bin/env bash
set -euo pipefail

repo="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo"
shopt -s nullglob

out_dir="$(mktemp -d "${TMPDIR:-/tmp}/groundwork-rendered.XXXXXX")"
trap 'rm -rf "$out_dir"' EXIT

# Render hermetically: without --config, chezmoi merges the developer's real
# ~/.config/chezmoi data under --override-data, so keys a test omits on purpose
# (like xcode) leak in from the local machine and pass/fail differs from CI.
empty_config="$out_dir/empty-config.toml"
: > "$empty_config"

base_data='"name":"CI User","email_personal":"ci@example.com","email_work":"","code_dir":"~/code","reset_existing_configs":false,"password_manager":"bitwarden","signingkey":"","obsidian_vault_name":"ci","game_dev":false'

render() {
  local os="$1" headless="$2" arch="${3:-arm64}" input="$4" output="$5"
  local work="${6:-false}"
  local xcode="${7:-false}"
  local beta="${8:-false}"
  local os_release='{}'
  [[ "$os" == "linux" ]] && os_release='{"ID":"ubuntu"}'
  local data="{${base_data},\"work\":${work},\"headless\":${headless},\"xcode\":${xcode},\"beta\":${beta},\"chezmoi\":{\"os\":\"${os}\",\"arch\":\"${arch}\",\"osRelease\":${os_release}}}"
  chezmoi --config "$empty_config" --source "$PWD" --destination "$out_dir/home" --override-data "$data" execute-template < "$input" > "$output"
}

render_without_xcode_key() {
  local os="$1" headless="$2" arch="${3:-arm64}" input="$4" output="$5"
  local work="${6:-false}"
  local os_release='{}'
  [[ "$os" == "linux" ]] && os_release='{"ID":"ubuntu"}'
  local data="{${base_data},\"work\":${work},\"headless\":${headless},\"chezmoi\":{\"os\":\"${os}\",\"arch\":\"${arch}\",\"osRelease\":${os_release}}}"
  chezmoi --config "$empty_config" --source "$PWD" --destination "$out_dir/home" --override-data "$data" execute-template < "$input" > "$output"
}

assert_not_contains() {
  local pattern="$1" file="$2" message="$3"
  if grep -Eq "$pattern" "$file"; then
    echo "$message" >&2
    sed -n '1,160p' "$file" >&2
    exit 1
  fi
}

assert_symlink_target() {
  local path="$1" target="$2"
  if [[ ! -L "$path" ]]; then
    echo "$path must be a symlink to $target" >&2
    exit 1
  fi
  if [[ "$(readlink "$path")" != "$target" ]]; then
    echo "$path must point to $target" >&2
    exit 1
  fi
}

assert_no_matches() {
  local message="$1" status
  shift
  if "$@"; then
    echo "$message" >&2
    exit 1
  else
    status=$?
    if [[ "$status" -gt 1 ]]; then
      echo "failed while checking: $message" >&2
      exit "$status"
    fi
  fi
}

line_number() {
  local pattern="$1" file="$2" line
  line="$(grep -nF -m1 "$pattern" "$file" | cut -d: -f1 || true)"
  if [[ -z "$line" ]]; then
    echo "$file: missing expected line: $pattern" >&2
    exit 1
  fi
  printf '%s\n' "$line"
}

echo "check: bootstrap syntax"
bash -n bootstrap-mac.sh

echo "check: helper script syntax"
shellcheck_files=(bootstrap-mac.sh)
for script in docker/*.sh home/dot_local/bin/executable_* home/dot_config/karabiner/modify_karabiner.json scripts/*; do
  [[ -f "$script" ]] || continue
  [[ "$script" == *.tmpl ]] && continue
  if head -n 1 "$script" | grep -q 'bash'; then
    bash -n "$script"
    shellcheck_files+=("$script")
  fi
done

echo "check: shellcheck"
shellcheck "${shellcheck_files[@]}"

echo "check: chezmoi root"
test "$(cat .chezmoiroot)" = "home"
grep -q '^2\.70\.0$' .chezmoiversion
test -f home/.chezmoi.toml.tmpl
test ! -f .chezmoi.toml.tmpl
grep -q '^  game_dev = false$' docker/chezmoi.headless.toml
grep -q '^  xcode = false$' docker/chezmoi.headless.toml
grep -q 'Is this a server/CI Mac with no desktop apps? Most Macs should say no. \[y/N\]' home/.chezmoi.toml.tmpl
grep -q 'Headless/server environment with no desktop apps? \[Y/n\]' home/.chezmoi.toml.tmpl
if grep -Eq 'Use a headless/server profile|Headless / server profile|Set up desktop apps' home/.chezmoi.toml.tmpl; then
  echo "old headless prompt wording found in home/.chezmoi.toml.tmpl" >&2
  exit 1
fi
grep -q 'Install optional Unity game development tools? Large download. \[y/N\]' home/.chezmoi.toml.tmpl
grep -q 'Install Xcode for native Apple/iOS development? Large (~15GB+). \[y/N\]' home/.chezmoi.toml.tmpl

echo "check: no create_ seed files"
create_seeds="$(find home -name 'create_*' -print)"
if [[ -n "$create_seeds" ]]; then
  echo "create_ seed-once files are not used in this repo: they hide drift from chezmoi diff, never receive upstream updates, and push users to hand-edit applied targets. Use a fully managed file or a local override instead (see skills/chezmoi-change/SKILL.md, Ownership Model)." >&2
  echo "$create_seeds" >&2
  exit 1
fi

echo "check: Claude Code keybindings"
if ! jq -e '
  (.bindings | type == "array") and
  ([.bindings[] | select(.context == "Chat")] | length == 1) and
  ([.bindings[] | select(.context == "Chat")][0].bindings | has("escape") and (.escape == null))
' home/dot_claude/keybindings.json >/dev/null; then
  echo "home/dot_claude/keybindings.json must parse as JSON and keep the Chat-context escape unbind (escape: null); see docs/troubleshooting.html Claude Code section" >&2
  exit 1
fi
assert_no_matches "personal snippet filename found" rg -n 'jason-snippets' home docs README.md
grep -Eq "^python[[:space:]]*=[[:space:]]*\\[[\"']3\\.13[\"'][[:space:]]*,[[:space:]]*[\"']3\\.12[\"']\\][[:space:]]*$" home/dot_config/mise/config.toml
grep -Eq '^[[:space:]]*aider_python="3\.12"[[:space:]]*$' home/run_after_20-tools.sh.tmpl
grep -qF "uv tool install --python \"\$aider_python\" --reinstall aider-chat" home/run_after_20-tools.sh.tmpl
grep -qF "tmux_plugin_dir=\"\$HOME/.config/tmux/plugins\"" home/run_after_20-tools.sh.tmpl
grep -qF "tmux_conf=\"\$HOME/.config/tmux/tmux.conf\"" home/run_after_20-tools.sh.tmpl
test -f home/dot_config/tmux/tmux.conf.tmpl
test ! -f home/dot_config/tmux/tmux.conf
grep -qF "set-environment -g TMUX_PLUGIN_MANAGER_PATH \"\$HOME/.config/tmux/plugins/\"" home/dot_config/tmux/tmux.conf.tmpl
unexpected_tmux_templates="$(
  grep -nE '\{\{|\}\}' home/dot_config/tmux/tmux.conf.tmpl |
    grep -vF '{{- if not .headless }}' |
    grep -vF '{{- else }}' |
    grep -vF '{{- end }}' || true
)"
if [[ -n "$unexpected_tmux_templates" ]]; then
  echo "unexpected Go template marker in tmux.conf.tmpl" >&2
  echo "$unexpected_tmux_templates" >&2
  exit 1
fi
grep -qF "source-file -q ~/.config/tmux/plugins/tmux/catppuccin_options_tmux.conf" home/dot_config/tmux/tmux.conf.tmpl
grep -qF "source-file -q ~/.config/tmux/plugins/tmux/catppuccin_tmux.conf" home/dot_config/tmux/tmux.conf.tmpl
grep -qF "set -agF status-right '#{E:@catppuccin_status_cpu}'" home/dot_config/tmux/tmux.conf.tmpl
grep -qF "set -agF status-right '#{E:@catppuccin_status_ram}'" home/dot_config/tmux/tmux.conf.tmpl
grep -qF "set -agF status-right '#{E:@catppuccin_status_battery}'" home/dot_config/tmux/tmux.conf.tmpl
catppuccin_source_line="$(line_number "source-file -q ~/.config/tmux/plugins/tmux/catppuccin_tmux.conf" home/dot_config/tmux/tmux.conf.tmpl)"
cpu_status_line="$(line_number "set -agF status-right '#{E:@catppuccin_status_cpu}'" home/dot_config/tmux/tmux.conf.tmpl)"
tpm_run_line="$(line_number "run '~/.config/tmux/plugins/tpm/tpm'" home/dot_config/tmux/tmux.conf.tmpl)"
if (( catppuccin_source_line >= cpu_status_line || cpu_status_line >= tpm_run_line )); then
  echo "tmux status modules must source Catppuccin before set -agF modules, before TPM runs" >&2
  exit 1
fi
grep -qF 'set(-option)?[[:space:]]+-g[[:space:]]+@plugin' home/run_after_20-tools.sh.tmpl
if grep -qF 'tmux_required_plugins=' home/run_after_20-tools.sh.tmpl; then
  echo "run_after_20-tools.sh.tmpl must derive tmux plugins from tmux.conf, not a static duplicate list" >&2
  exit 1
fi
tmux_declared_plugins="$(
  sed -nE "s/^[[:space:]]*set(-option)?[[:space:]]+-g[[:space:]]+@plugin[[:space:]]+['\"]?([^'\"[:space:]]+)['\"]?.*$/\2/p" home/dot_config/tmux/tmux.conf.tmpl |
    sed -E 's/#.*$//; s|.*/||; s/\.git$//'
)"
for plugin in tpm tmux-sensible tmux-yank tmux-resurrect tmux-continuum tmux-cpu tmux-battery vim-tmux-navigator tmux; do
  grep -qx "$plugin" <<<"$tmux_declared_plugins" || { echo "tmux plugin parser missed $plugin" >&2; exit 1; }
done
grep -qF "\"\$tmux_plugin_dir/tpm/bin/install_plugins\" || true" home/run_after_20-tools.sh.tmpl
grep -qF 'enable-atuin-ai' home/dot_zshrc.tmpl
grep -qF -- '--disable-ai' home/dot_zshrc.tmpl
grep -qF "files copied to \$dest, but git commit failed" home/dot_zshrc.tmpl
grep -qF 'reproducible headless path; pin/checksum it before making it required.' home/run_after_20-tools.sh.tmpl
grep -qF 'https://deb.gierens.de stable main' docker/install-headless-tools.sh
assert_no_matches "eza apt repo must use HTTPS" rg -n 'http://deb\.gierens\.de' docker

echo "check: AI thesis wiring"
test -f home/.chezmoitemplates/ai-thesis.md
test -L AI_THESIS.md
test "$(readlink AI_THESIS.md)" = "home/.chezmoitemplates/ai-thesis.md"
test -f home/dot_claude/CLAUDE.md.tmpl
test -f home/dot_codex/AGENTS.md.tmpl
test ! -f home/dot_claude/CLAUDE.md
test ! -f home/dot_codex/AGENTS.md

echo "check: static docs"
test -f .github/workflows/pages.yml
test -f .github/workflows/ci.yml
test ! -f .github/workflows/validate.yml
grep -q 'actions/configure-pages@' .github/workflows/pages.yml
grep -q 'actions/upload-pages-artifact@' .github/workflows/pages.yml
grep -q 'actions/deploy-pages@' .github/workflows/pages.yml
assert_no_matches "GitHub Actions must be pinned to full commit SHAs, with the version tag left as a comment" rg -n 'uses:[[:space:]]+[^#]+@v[0-9]' .github/workflows
grep -q 'path: docs' .github/workflows/pages.yml
assert_no_matches "Pages workflow must deploy on every main push; do not add paths filters" rg -n '^[[:space:]]+paths(-ignore)?:' .github/workflows/pages.yml
test -f docs/.nojekyll
test -f docs/assets/favicon.svg
test -f docs/assets/social-card.png
test -f docs/platforms.html
for page in docs/*.html; do
  grep -q 'name="description"' "$page" || { echo "$page: missing description meta tag" >&2; exit 1; }
  grep -q ' · Groundwork</title>' "$page" || { echo "$page: page title must use middle dot separator: Page · Groundwork" >&2; exit 1; }
  grep -q 'property="og:title"' "$page" || { echo "$page: missing Open Graph title" >&2; exit 1; }
  grep -q 'property="og:title" content=".* · Groundwork"' "$page" || { echo "$page: Open Graph title must use middle dot separator: Page · Groundwork" >&2; exit 1; }
  grep -q 'property="og:url" content="https://jasondockery.github.io/groundwork/'"$(basename "$page")"'"' "$page" || { echo "$page: missing Open Graph URL" >&2; exit 1; }
  grep -q 'name="twitter:title" content=".* · Groundwork"' "$page" || { echo "$page: Twitter title must use middle dot separator: Page · Groundwork" >&2; exit 1; }
  grep -q 'property="og:image" content="https://jasondockery.github.io/groundwork/assets/social-card.png"' "$page" || { echo "$page: missing PNG Open Graph image" >&2; exit 1; }
  grep -q 'rel="canonical" href="https://jasondockery.github.io/groundwork/'"$(basename "$page")"'"' "$page" || { echo "$page: missing canonical URL" >&2; exit 1; }
  grep -q 'rel="icon"' "$page" || { echo "$page: missing favicon link" >&2; exit 1; }
  grep -q '<a class="skip-link" href="#main">Skip to content</a>' "$page" || { echo "$page: missing skip link" >&2; exit 1; }
  grep -q '<main id="main" class="main">' "$page" || { echo "$page: missing main landmark id" >&2; exit 1; }
  grep -q 'data-nav-toggle aria-controls="site-sidebar" aria-expanded="false"' "$page" || { echo "$page: mobile nav toggle missing aria-controls/expanded" >&2; exit 1; }
  grep -q '<aside id="site-sidebar" class="sidebar">' "$page" || { echo "$page: sidebar missing controlled id" >&2; exit 1; }
  grep -q '<div class="scrim" aria-hidden="true"></div>' "$page" || { echo "$page: scrim missing aria-hidden" >&2; exit 1; }
  grep -q 'localStorage.getItem("fg-theme")' "$page" || { echo "$page: missing early theme bootstrap" >&2; exit 1; }
  assert_not_contains 'data-theme="dark"' "$page" "$page: hardcoded dark theme causes light-theme flash"
  grep -q 'href="platforms.html"' "$page" || { echo "$page: missing Platforms sidebar link" >&2; exit 1; }
  for group in "Start here" "Set up" "Foundations" "Daily workflow" "Tracks" "Mac desktop" "Reference"; do
    grep -q "<h4>$group</h4>" "$page" || { echo "$page: missing sidebar group: $group" >&2; exit 1; }
  done
  active_count="$(grep -c 'class="active"' "$page" || true)"
  [[ "$active_count" == "1" ]] || { echo "$page: expected one active sidebar link, found $active_count" >&2; exit 1; }
done
assert_no_matches "old docs title separator found" rg -n '(<title>[^<]*( — | -- | - )Groundwork|<(meta)[^>]+content="[^"]*( — | -- | - )Groundwork")' docs
assert_no_matches "old macOS windows label found" rg -n "macOS windows" docs README.md
assert_no_matches "old sidebar group label found" rg -n '<h4>(The path|Workflows)</h4>' docs
commands_page_text="$(
  sed -E 's/<[^>]+>/ /g; s/&lt;/</g; s/&gt;/>/g; s/&amp;/\\&/g; s/&quot;/\"/g; s/&#39;/'"'"'/g' docs/commands.html |
    tr '\n' ' ' |
    tr -s '[:space:]' ' '
)"
while IFS=$'\t' read -r _category command _kind _description; do
  [[ -n "$command" && "$command" != \#* ]] || continue
  command_key="${command%% *}"
  case "$command" in
    Ctrl+a*) command_key="Ctrl a" ;;
    Ctrl+R) command_key="Ctrl R" ;;
    Ctrl+T) command_key="Ctrl T" ;;
    Alt+C) command_key="Alt C" ;;
    Alt+h*) command_key="Alt h" ;;
    "vim / vi") command_key="vim" ;;
    *update_plugins*) command_key="update_plugins" ;;
  esac
  grep -Fq "$command_key" <<<"$commands_page_text" || { echo "docs/commands.html missing command catalog entry for: $command" >&2; exit 1; }
done < home/dot_local/share/groundwork/commands.tsv

echo "check: supply-chain guardrails"
grep -qE '^FROM ubuntu:24\.04@sha256:[0-9a-f]{64}$' Dockerfile
# Renovate owns dependency updates (renovate.json); a dependabot.yml would
# create duplicate PRs, so its absence is the guarded state.
grep -q '"config:best-practices"' renovate.json
if [[ -e .github/dependabot.yml ]]; then
  echo "remove .github/dependabot.yml: Renovate owns dependency updates (see PLAYBOOK.md)" >&2
  exit 1
fi
grep -qF 'brew "opencode"' home/dot_config/homebrew/Brewfile.tmpl
assert_no_matches "OpenCode CLI must be managed by Homebrew, not a curl-to-shell installer" rg -n 'opencode\.ai/install|\.opencode/bin' home README.md docs docker Dockerfile

echo "check: agent skill discovery"
assert_symlink_target .claude/skills ../skills
assert_symlink_target .codex/skills ../skills
if [[ -e .agents/skills || -L .agents/skills ]]; then
  echo ".agents/skills must not exist in this repo; keep canonical skills in skills/" >&2
  exit 1
fi

echo "check: Codex skill metadata"
allowed_openai_metadata='^[[:space:]]*$|^[[:space:]]*#|^interface:[[:space:]]*$|^[[:space:]]+display_name:[[:space:]]*"[^"]+"[[:space:]]*$'
for metadata in skills/*/agents/openai.yaml; do
  [[ -e "$metadata" ]] || continue
  if grep -vqE "$allowed_openai_metadata" "$metadata"; then
    echo "$metadata: only interface.display_name is allowed; keep descriptions and prompts in SKILL.md" >&2
    exit 1
  fi
  if ! grep -qE '^[[:space:]]+display_name:[[:space:]]*"[^"]+"[[:space:]]*$' "$metadata"; then
    echo "$metadata: missing interface.display_name" >&2
    exit 1
  fi
done

echo "check: template brace balance"
while IFS= read -r template; do
  left=$(grep -o '{{' "$template" | wc -l | tr -d ' ' || true)
  right=$(grep -o '}}' "$template" | wc -l | tr -d ' ' || true)
  [[ "$left" == "$right" ]] || { echo "unbalanced template braces: $template" >&2; exit 1; }
done < <(find . -path ./.git -prune -o -name '*.tmpl' -print)

shell_templates=(home/run_*.sh.tmpl home/dot_local/bin/*.tmpl)
for os in darwin linux; do
  for headless in false true; do
    case_name="${os}-${headless}"
    mkdir -p "$out_dir/$case_name"
    echo "check: rendered shell templates ($case_name)"
    for script in "${shell_templates[@]}"; do
      rendered="$out_dir/$case_name/$(basename "${script%.tmpl}")"
      render "$os" "$headless" "amd64" "$script" "$rendered"
      bash -n "$rendered"
      shellcheck "$rendered"
    done

    echo "check: rendered zsh ($case_name)"
    render "$os" "$headless" "amd64" home/dot_zshrc.tmpl "$out_dir/$case_name/zshrc"
    zsh -n "$out_dir/$case_name/zshrc"

    echo "check: rendered tmux ($case_name)"
    render "$os" "$headless" "amd64" home/dot_config/tmux/tmux.conf.tmpl "$out_dir/$case_name/tmux.conf"
    grep -qF "set-environment -g TMUX_PLUGIN_MANAGER_PATH \"\$HOME/.config/tmux/plugins/\"" "$out_dir/$case_name/tmux.conf"
    if [[ "$headless" == "true" ]]; then
      grep -qF "set -g @continuum-restore 'off'" "$out_dir/$case_name/tmux.conf"
      assert_not_contains "@continuum-restore 'on'" "$out_dir/$case_name/tmux.conf" "continuum auto-restore leaked into $case_name tmux config"
    else
      grep -qF "set -g @continuum-restore 'on'" "$out_dir/$case_name/tmux.conf"
      assert_not_contains "@continuum-restore 'off'" "$out_dir/$case_name/tmux.conf" "continuum auto-restore disabled in $case_name tmux config"
    fi

    echo "check: rendered Brewfile ($case_name)"
    render "$os" "$headless" "amd64" home/dot_config/homebrew/Brewfile.tmpl "$out_dir/$case_name/Brewfile"
    if [[ "$os" == "linux" || "$headless" == "true" ]]; then
      assert_not_contains '^(cask|mas) ' "$out_dir/$case_name/Brewfile" "cask/mas leaked into $case_name Brewfile"
    fi

    echo "check: rendered ignore ($case_name)"
    render "$os" "$headless" "amd64" home/.chezmoiignore "$out_dir/$case_name/chezmoiignore"
    if [[ "$os" != "darwin" || "$headless" == "true" ]]; then
      grep -q '^Library/\*\*' "$out_dir/$case_name/chezmoiignore"
      grep -q '^\.config/karabiner/\*\*' "$out_dir/$case_name/chezmoiignore"
    fi

    if [[ "$os" == "linux" || "$headless" == "true" ]]; then
      render "$os" "$headless" "amd64" home/run_onchange_after_30-macos-defaults.sh.tmpl "$out_dir/$case_name/macos-defaults.sh"
      assert_not_contains 'defaults write' "$out_dir/$case_name/macos-defaults.sh" "macOS defaults leaked into $case_name"
      render "$os" "$headless" "amd64" home/run_after_40-obsidian-vault.sh.tmpl "$out_dir/$case_name/obsidian-vault.sh"
      assert_not_contains 'Obsidian|Library/Mobile Documents|obsidian.json' "$out_dir/$case_name/obsidian-vault.sh" "Obsidian vault body leaked into $case_name"
      render "$os" "$headless" "amd64" home/run_after_45-obsidian-plugins.sh.tmpl "$out_dir/$case_name/obsidian-plugins.sh"
      assert_not_contains 'obsidian-plugins|Library/Mobile Documents' "$out_dir/$case_name/obsidian-plugins.sh" "Obsidian plugins body leaked into $case_name"
      render "$os" "$headless" "amd64" home/run_after_55-zen-bitwarden-biometrics.sh.tmpl "$out_dir/$case_name/zen-bitwarden.sh"
      assert_not_contains 'NativeMessagingHosts|zen' "$out_dir/$case_name/zen-bitwarden.sh" "Zen biometrics body leaked into $case_name"
      assert_not_contains 'SSH_AUTH_SOCK' "$out_dir/$case_name/zshrc" "SSH_AUTH_SOCK leaked into $case_name zshrc"
    fi
  done
done

echo "check: rendered work macOS profile"
mkdir -p "$out_dir/darwin-work"
render darwin false arm64 home/.chezmoiignore "$out_dir/darwin-work/chezmoiignore" true
render darwin false arm64 home/dot_config/homebrew/Brewfile.tmpl "$out_dir/darwin-work/Brewfile" true
assert_not_contains '^\.config/karabiner/\*\*' "$out_dir/darwin-work/chezmoiignore" "Karabiner was ignored on work macOS"
grep -q '^cask "karabiner-elements"$' "$out_dir/darwin-work/Brewfile"
grep -q '^brew "colima"$' "$out_dir/darwin-work/Brewfile"
assert_not_contains '^cask "docker-desktop"$' "$out_dir/darwin-work/Brewfile" "Docker Desktop leaked into work macOS"
assert_not_contains '^mas "Xcode"' "$out_dir/darwin-work/Brewfile" "Xcode leaked into default work macOS"

echo "check: rendered Xcode macOS profile"
mkdir -p "$out_dir/darwin-no-xcode" "$out_dir/darwin-xcode" "$out_dir/darwin-legacy-no-xcode"
render darwin false arm64 home/dot_config/homebrew/Brewfile.tmpl "$out_dir/darwin-no-xcode/Brewfile" false false
assert_not_contains '^mas "Xcode"' "$out_dir/darwin-no-xcode/Brewfile" "Xcode leaked into default personal macOS"
render darwin false arm64 home/dot_config/homebrew/Brewfile.tmpl "$out_dir/darwin-xcode/Brewfile" false true
grep -q '^mas "Xcode", id: 497799835' "$out_dir/darwin-xcode/Brewfile"
render_without_xcode_key darwin false arm64 home/dot_config/homebrew/Brewfile.tmpl "$out_dir/darwin-legacy-no-xcode/Brewfile" false
assert_not_contains '^mas "Xcode"' "$out_dir/darwin-legacy-no-xcode/Brewfile" "Xcode leaked when xcode key was absent"

echo "check: rendered beta channel profile"
mkdir -p "$out_dir/darwin-beta" "$out_dir/darwin-nobeta" "$out_dir/darwin-beta-noxcode"
render darwin false arm64 home/dot_config/homebrew/Brewfile.tmpl "$out_dir/darwin-beta/Brewfile" false true true
grep -q '^brew "xcodes"' "$out_dir/darwin-beta/Brewfile"
render darwin false arm64 home/dot_zshrc.tmpl "$out_dir/darwin-beta/zshrc" false true true
grep -q "beta channel on" "$out_dir/darwin-beta/zshrc"
render darwin false arm64 home/dot_config/homebrew/Brewfile.tmpl "$out_dir/darwin-nobeta/Brewfile" false true false
assert_not_contains '^brew "xcodes"' "$out_dir/darwin-nobeta/Brewfile" "xcodes leaked without the beta channel"
render darwin false arm64 home/dot_zshrc.tmpl "$out_dir/darwin-nobeta/zshrc" false true false
assert_not_contains "beta channel on" "$out_dir/darwin-nobeta/zshrc" "beta reminder leaked into update-all without the beta channel"
# beta is only meaningful with Xcode: xcode=false + beta=true must normalize to
# no xcodes and no reminder, matching the prompt that only offers beta under Xcode.
render darwin false arm64 home/dot_config/homebrew/Brewfile.tmpl "$out_dir/darwin-beta-noxcode/Brewfile" false false true
assert_not_contains '^brew "xcodes"' "$out_dir/darwin-beta-noxcode/Brewfile" "xcodes installed with beta but no Xcode"
render darwin false arm64 home/dot_zshrc.tmpl "$out_dir/darwin-beta-noxcode/zshrc" false false true
assert_not_contains "beta channel on" "$out_dir/darwin-beta-noxcode/zshrc" "beta reminder shown with beta but no Xcode"
# Lock the update-all Homebrew command so it cannot revert to bare --greedy,
# which re-downloads and re-quarantines self-updating casks (repeated Gatekeeper prompts).
grep -q 'HOMEBREW_NO_UPGRADE_AUTO_UPDATES_CASKS=1 brew upgrade --greedy-latest' "$out_dir/darwin-beta/zshrc"
assert_not_contains 'brew upgrade --greedy( |$)' "$out_dir/darwin-beta/zshrc" "update-all reverted to --greedy (re-quarantines self-updating casks)"

echo "check: rendered agent adapters"
render darwin false arm64 home/dot_claude/CLAUDE.md.tmpl "$out_dir/CLAUDE.md"
render darwin false arm64 home/dot_codex/AGENTS.md.tmpl "$out_dir/AGENTS.md"
grep -q "AI-Native Groundwork" "$out_dir/CLAUDE.md"
grep -q "AI-Native Groundwork" "$out_dir/AGENTS.md"
grep -q "Claude Code Notes" "$out_dir/CLAUDE.md"
grep -q "Codex Notes" "$out_dir/AGENTS.md"

echo "check: docs links"
for page in docs/*.html; do
  dir="$(dirname "$page")"
  while IFS= read -r href; do
    case "$href" in
      http:*|https:*|mailto:*|"") continue ;;
    esac
    target="${href%%#*}"
    fragment=""
    [[ "$href" == *#* ]] && fragment="${href#*#}"
    target_path="$dir/${target:-$(basename "$page")}"
    if [[ ! -e "$target_path" ]]; then
      echo "missing $page: $href" >&2
      exit 1
    fi
    if [[ -n "$fragment" ]] && ! grep -Eq "(id|name)=\"$fragment\"" "$target_path"; then
      echo "missing fragment $page: $href" >&2
      exit 1
    fi
  done < <(grep -Eo 'href="[^"]+"' "$page" | sed -E 's/^href="([^"]*)"$/\1/')
  while IFS= read -r src; do
    case "$src" in
      http:*|https:*|data:*|"") continue ;;
    esac
    if [[ ! -e "$dir/$src" ]]; then
      echo "missing asset $page: $src" >&2
      exit 1
    fi
  done < <(grep -Eo 'src="[^"]+"' "$page" | sed -E 's/^src="([^"]*)"$/\1/')
done

echo "check: line endings stay LF"
grep -q '^\* text=auto eol=lf$' .gitattributes
assert_no_matches "CRLF line endings found in tracked files" git grep -Il $'\r' -- .

echo "check: common secret patterns"
assert_no_matches "secret-like pattern found" git grep -n -E '(-----BEGIN [A-Z ]*PRIVATE KEY-----|ghp_[A-Za-z0-9_]{20,}|github_pat_[A-Za-z0-9_]{20,}|sk-[A-Za-z0-9_-]{20,}|xox[baprs]-[A-Za-z0-9-]{20,}|AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{35})'

if [[ -n "${GROUNDWORK_PUBLIC_DENYLIST_PATTERN:-}" ]]; then
  echo "check: local public denylist env pattern"
  assert_no_matches "local public denylist env pattern matched" rg -n "$GROUNDWORK_PUBLIC_DENYLIST_PATTERN" . --hidden -g '!.git' -g '!node_modules'
fi

if [[ -f .groundwork-public-denylist ]]; then
  echo "check: local public denylist file"
  while IFS= read -r pattern; do
    [[ -z "$pattern" || "$pattern" == \#* ]] && continue
    assert_no_matches "local public denylist file pattern matched" rg -n "$pattern" . --hidden -g '!.git' -g '!node_modules' -g '!.groundwork-public-denylist'
  done < .groundwork-public-denylist
fi

echo "check: old name residue"
assert_no_matches "old name residue found" rg -n "Primer|primer|mac-dev-primer|Mac Dev|MAC_DEV_PRIMER|validate-primer|jasondockery/mac-dev-primer|PRIMER" . --hidden -g '!.git' -g '!node_modules' -g '!scripts/validate-groundwork'

echo "check: whitespace"
git diff --check

echo "ok: Groundwork validation passed"
