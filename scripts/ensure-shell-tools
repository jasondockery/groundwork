#!/usr/bin/env bash
set -euo pipefail

# Resolve the pinned ShellCheck and shfmt for THIS OS/arch, downloading and
# caching them on first use, and print their absolute paths. CI and local dev
# both call this, so validation always uses the exact pinned analyzers regardless
# of what is on PATH (a Homebrew ShellCheck may sit at a different version). No
# sudo: binaries live under the user cache.
#
# Machine-readable stdout (consumed by scripts/lint-shell):
#   SHELLCHECK_BIN=/abs/path/shellcheck
#   SHFMT_BIN=/abs/path/shfmt
# Human receipts (versions, cache hits, downloads) go to stderr.

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=/dev/null
. "$repo_root/tools/shell-tools.env"
: "${SHELLCHECK_VERSION:?missing in tools/shell-tools.env}"
: "${SHFMT_VERSION:?missing in tools/shell-tools.env}"

cache_root="${XDG_CACHE_HOME:-$HOME/.cache}/groundwork/shell-tools"

os="$(uname -s)"
case "$os" in
  Linux) os_l=linux ;;
  Darwin) os_l=darwin ;;
  *)
    echo "ensure-shell-tools: unsupported OS: $os" >&2
    exit 1
    ;;
esac
os_u="$(printf '%s' "$os_l" | tr '[:lower:]' '[:upper:]')"

machine="$(uname -m)"
case "$machine" in
  # ShellCheck names arches x86_64/aarch64; shfmt names them amd64/arm64.
  x86_64 | amd64)
    sc_arch=x86_64
    shfmt_arch=amd64
    ;;
  arm64 | aarch64)
    sc_arch=aarch64
    shfmt_arch=arm64
    ;;
  *)
    echo "ensure-shell-tools: unsupported arch: $machine" >&2
    exit 1
    ;;
esac

tmp_root="$(mktemp -d)"
trap 'rm -rf -- "$tmp_root"' EXIT

sha_of() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  else
    shasum -a 256 "$1" | awk '{print $1}'
  fi
}

fetch() { # url dest — bounded: connect + total deadline, retry transient failures
  curl --fail --silent --show-error --location \
    --retry 3 --retry-all-errors --connect-timeout 15 --max-time 120 \
    --output "$2" "$1"
}

verify() { # file expected_sha
  local got
  got="$(sha_of "$1")"
  if [[ "$got" != "$2" ]]; then
    echo "ensure-shell-tools: checksum mismatch for $(basename "$1") (want $2, got $got)" >&2
    return 1
  fi
}

promote() { # src destfinal — atomic install into the cache (stage on the same fs)
  local src="$1" dest="$2" dir staging
  dir="$(dirname "$dest")"
  mkdir -p "$dir"
  staging="$(mktemp "$dir/.tool.XXXXXX")"
  cp "$src" "$staging"
  chmod +x "$staging"
  mv -f "$staging" "$dest"
}

checksum_for() { # KEYSUFFIX (e.g. SHELLCHECK_SHA256_LINUX_X86_64) -> value or fail
  local key="$1" val
  val="$(eval "printf '%s' \"\${$key:-}\"")"
  if [[ -z "$val" ]]; then
    echo "ensure-shell-tools: no checksum $key in tools/shell-tools.env" >&2
    return 1
  fi
  printf '%s' "$val"
}

ensure_shellcheck() {
  local ver="$SHELLCHECK_VERSION" dest sha asset url
  dest="$cache_root/shellcheck/$ver/$os_l-$sc_arch/shellcheck"
  if [[ -x "$dest" ]] \
    && [[ "$("$dest" --version 2>/dev/null | awk '/^version:/ {print $2}')" == "$ver" ]]; then
    echo "ensure-shell-tools: shellcheck $ver (cached)" >&2
    printf '%s' "$dest"
    return 0
  fi
  sha="$(checksum_for "SHELLCHECK_SHA256_${os_u}_$(printf '%s' "$sc_arch" | tr '[:lower:]' '[:upper:]')")"
  asset="shellcheck-v${ver}.${os_l}.${sc_arch}.tar.xz"
  url="https://github.com/koalaman/shellcheck/releases/download/v${ver}/${asset}"
  echo "ensure-shell-tools: downloading shellcheck $ver ($os_l-$sc_arch)" >&2
  fetch "$url" "$tmp_root/sc.tar.xz"
  verify "$tmp_root/sc.tar.xz" "$sha"
  tar -xJf "$tmp_root/sc.tar.xz" -C "$tmp_root"
  promote "$tmp_root/shellcheck-v${ver}/shellcheck" "$dest"
  printf '%s' "$dest"
}

ensure_shfmt() {
  local ver="$SHFMT_VERSION" dest sha asset url
  dest="$cache_root/shfmt/$ver/$os_l-$shfmt_arch/shfmt"
  if [[ -x "$dest" ]] \
    && [[ "$("$dest" --version 2>/dev/null | sed 's/^v//')" == "$ver" ]]; then
    echo "ensure-shell-tools: shfmt $ver (cached)" >&2
    printf '%s' "$dest"
    return 0
  fi
  sha="$(checksum_for "SHFMT_SHA256_${os_u}_$(printf '%s' "$shfmt_arch" | tr '[:lower:]' '[:upper:]')")"
  asset="shfmt_v${ver}_${os_l}_${shfmt_arch}"
  url="https://github.com/mvdan/sh/releases/download/v${ver}/${asset}"
  echo "ensure-shell-tools: downloading shfmt $ver ($os_l-$shfmt_arch)" >&2
  fetch "$url" "$tmp_root/shfmt"
  verify "$tmp_root/shfmt" "$sha"
  promote "$tmp_root/shfmt" "$dest"
  printf '%s' "$dest"
}

sc_bin="$(ensure_shellcheck)"
shf_bin="$(ensure_shfmt)"
echo "ensure-shell-tools: ShellCheck $("$sc_bin" --version | awk '/^version:/ {print $2}'), shfmt $("$shf_bin" --version | sed 's/^v//')" >&2
printf 'SHELLCHECK_BIN=%s\nSHFMT_BIN=%s\n' "$sc_bin" "$shf_bin"
