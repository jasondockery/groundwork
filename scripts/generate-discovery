#!/usr/bin/env python3
"""Generate search/AI discovery artifacts from the docs pages themselves.

Derives, so pages stay the single source of truth:
  - per-page meta descriptions (description, og:description,
    twitter:description) from each page's lead paragraph: the lead IS the
    search snippet, so write leads accordingly (skills/docs-alignment).
  - docs/sitemap.xml for search engines (submit once in Search Console;
    project pages cannot serve a root robots.txt, so the sitemap is
    registered there rather than referenced from robots).
  - docs/llms.txt for AI/IDE agents (Claude Code, Cursor, and peers fetch
    it when pointed at a docs site).

Modes: --write (default) rewrites artifacts; --check exits 1 if a rewrite
would change anything (wired into scripts/validate-groundwork).
"""

import datetime
import html
import pathlib
import re
import subprocess
import sys

ROOT = pathlib.Path(__file__).resolve().parent.parent
DOCS = ROOT / "docs"
BASE = "https://jasondockery.github.io/groundwork"
SITE = "Groundwork"
SUMMARY = (
    "An AI-native development foundation for Mac, Linux/WSL, and headless "
    "agent workspaces: tool setup plus the fundamentals that stay useful "
    "when tools change (shell, Git, project instructions, verification, "
    "and directing AI agents)."
)
MAX_DESC = 158

LEAD_RE = re.compile(r'<p class="lead">(.*?)</p>', re.S)
FIRST_P_RE = re.compile(r'<div class="content">.*?<p[^>]*>(.*?)</p>', re.S)
TITLE_RE = re.compile(r"<title>(.*?)</title>", re.S)
TAG_RE = re.compile(r"<[^>]+>")


def page_description(text: str) -> str:
    m = LEAD_RE.search(text) or FIRST_P_RE.search(text)
    if not m:
        return SUMMARY
    raw = html.unescape(TAG_RE.sub("", m.group(1)))
    desc = " ".join(raw.split())
    if len(desc) > MAX_DESC:
        desc = desc[: MAX_DESC + 1].rsplit(" ", 1)[0].rstrip(",;:") + "…"
    return desc


def page_title(text: str) -> str:
    m = TITLE_RE.search(text)
    return " ".join(m.group(1).split()) if m else SITE


def set_meta(text: str, pattern: str, replacement: str) -> str:
    return re.sub(pattern, replacement, text, count=1)


def run_git(*args: str) -> str:
    """Run git and fail closed. Any nonzero exit stops generation instead of
    letting incomplete history silently produce a valid-looking but false
    sitemap — the same fail-open trap the shallow-clone check closes."""
    result = subprocess.run(
        ["git", *args], cwd=ROOT, capture_output=True, text=True,
    )
    if result.returncode != 0:
        sys.stderr.write(
            f"generate-discovery: git {' '.join(args)} failed: "
            f"{result.stderr.strip() or 'unknown error'}\n"
        )
        raise SystemExit(1)
    return result.stdout


def assert_full_history() -> None:
    """Git history is a declared input here, not ambient state: sitemap
    lastmod dates are each page's newest commit date. A shallow clone can't
    prove it holds the commit that last changed a page, so the dates would be
    silently wrong. Fail closed: if the history state cannot even be
    established, that is an error, not a pass. The declared contract is the
    checked-out branch's complete history."""
    result = subprocess.run(
        ["git", "rev-parse", "--is-shallow-repository"],
        cwd=ROOT, capture_output=True, text=True,
    )
    if result.returncode != 0:
        sys.stderr.write(
            "generate-discovery: cannot determine git history state: "
            f"{result.stderr.strip()}\n"
        )
        raise SystemExit(1)
    state = result.stdout.strip()
    if state not in ("true", "false"):
        sys.stderr.write(
            f"generate-discovery: unexpected shallow-state {state!r} "
            "(expected 'true' or 'false')\n"
        )
        raise SystemExit(1)
    if state == "true":
        sys.stderr.write(
            "generate-discovery: shallow clone; sitemap lastmod dates need "
            "the checked-out branch's full history. In GitHub Actions set "
            "checkout fetch-depth: 0 (add filter: blob:none to skip old "
            "blobs); locally run `git fetch --unshallow`.\n"
        )
        raise SystemExit(1)


def dirty_docs_paths() -> set[str]:
    """Docs paths with uncommitted changes (modified, added, renamed, or
    untracked). These get today's date; committed pages get their last commit
    date. `-z` gives unambiguous NUL-delimited records, so filenames with
    spaces, quotes, or unicode can't corrupt parsing."""
    out = run_git("status", "--porcelain=v1", "-z", "--", "docs")
    fields = out.split("\0")
    paths: set[str] = set()
    i = 0
    while i < len(fields):
        record = fields[i]
        if not record:
            i += 1
            continue
        status, path = record[:2], record[3:]
        paths.add(path)
        # A rename/copy record is followed by its source path in the next
        # NUL field; the destination path (above) is what exists now.
        if "R" in status or "C" in status:
            i += 1
        i += 1
    return paths


def commit_date_map() -> dict[str, str]:
    """Newest commit date per docs path in ONE history traversal (not a
    `git log` per page). A NUL prefix marks date lines so a date-shaped
    filename cannot be misread as a date; quotePath=false keeps unicode paths
    literal. git log is newest-first, so a path's first appearance is its
    latest change."""
    out = run_git(
        "-c", "core.quotePath=false",
        "log", "--format=%x00%cs", "--name-only", "--", "docs",
    )
    dates: dict[str, str] = {}
    current = ""
    for line in out.splitlines():
        if line.startswith("\0"):
            current = line[1:].strip()
        elif line:
            dates.setdefault(line, current)
    return dates


def is_site_page(path: pathlib.Path) -> bool:
    # Verification stubs (Search Console's google*.html and similar) live in
    # docs/ but are not pages: no Groundwork head, and they must never
    # appear in the sitemap or llms.txt.
    return 'property="og:site_name" content="Groundwork"' in path.read_text()


def main() -> int:
    check = "--check" in sys.argv
    assert_full_history()
    pages = sorted(p for p in DOCS.glob("*.html") if is_site_page(p))
    changed: list[str] = []
    entries = []

    for page in pages:
        text = page.read_text()
        desc_attr = html.escape(page_description(text), quote=True)
        new = text
        new = set_meta(
            new,
            r'(<meta name="description" content=")[^"]*(")',
            rf"\g<1>{desc_attr}\g<2>",
        )
        new = set_meta(
            new,
            r'(<meta property="og:description" content=")[^"]*(")',
            rf"\g<1>{desc_attr}\g<2>",
        )
        new = set_meta(
            new,
            r'(<meta name="twitter:description" content=")[^"]*(")',
            rf"\g<1>{desc_attr}\g<2>",
        )
        if new != text:
            changed.append(f"docs/{page.name}")
            if not check:
                page.write_text(new)
        entries.append((page, page_title(new), page_description(new)))

    url_of = lambda p: f"{BASE}/" if p.name == "index.html" else f"{BASE}/{p.name}"

    dirty = dirty_docs_paths()
    dates = commit_date_map()
    today = datetime.date.today().isoformat()

    def page_lastmod(page: pathlib.Path) -> str:
        rel = f"docs/{page.name}"
        if rel in dirty:
            return today
        date = dates.get(rel)
        if not date:
            # Committed but absent from the history map: an invariant failure
            # (incomplete history), not a page to stamp with a placeholder.
            sys.stderr.write(
                f"generate-discovery: {rel} is tracked but has no commit "
                "date; refusing to emit a placeholder lastmod.\n"
            )
            raise SystemExit(1)
        return date

    sitemap_lines = ['<?xml version="1.0" encoding="UTF-8"?>']
    sitemap_lines.append(
        '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">'
    )
    for page, _title, _desc in entries:
        sitemap_lines.append("  <url>")
        sitemap_lines.append(f"    <loc>{url_of(page)}</loc>")
        sitemap_lines.append(f"    <lastmod>{page_lastmod(page)}</lastmod>")
        sitemap_lines.append("  </url>")
    sitemap_lines.append("</urlset>")
    sitemap = "\n".join(sitemap_lines) + "\n"

    llms_lines = [f"# {SITE}", "", f"> {SUMMARY}", ""]
    llms_lines.append(
        "Groundwork scaffolds the developer: environment, fundamentals, and"
    )
    llms_lines.append(
        "agent-direction skills. Its sibling, Roost, scaffolds an"
    )
    llms_lines.append(
        "organization's code and process. Repo:"
    )
    llms_lines.append("https://github.com/jasondockery/groundwork")
    llms_lines.append("")
    llms_lines.append("## Docs")
    llms_lines.append("")
    for page, title, desc in entries:
        llms_lines.append(f"- [{title}]({url_of(page)}): {desc}")
    llms = "\n".join(llms_lines) + "\n"

    for name, content in (("sitemap.xml", sitemap), ("llms.txt", llms)):
        path = DOCS / name
        if not path.exists() or path.read_text() != content:
            changed.append(f"docs/{name}")
            if not check:
                path.write_text(content)

    if check and changed:
        print("discovery artifacts stale; run scripts/generate-discovery:")
        for c in sorted(set(changed)):
            print(f"  {c}")
        return 1
    if changed:
        print(f"updated: {len(set(changed))} file(s)")
    else:
        print("discovery artifacts already current")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
