alias rga="rg -uu"

rgf() {
  emulate -L zsh
  local query="${*:-}"
  local rg_args=(--column --line-number --no-heading --color=always --smart-case)

  if [[ -n "$query" ]]; then
    rg "${rg_args[@]}" "$query" |
      fzf --ansi --delimiter : \
        --preview 'bat --color=always --style=numbers --highlight-line {2} {1}' \
        --preview-window 'right,60%,border-left,+{2}+3/3,~3' \
        --bind 'enter:become($EDITOR {1} +{2})'
  else
    fzf --ansi --disabled --prompt 'rg> ' --delimiter : \
      --bind 'change:reload:[[ -n {q} ]] && rg --column --line-number --no-heading --color=always --smart-case {q} || true' \
      --preview 'bat --color=always --style=numbers --highlight-line {2} {1}' \
      --preview-window 'right,60%,border-left,+{2}+3/3,~3' \
      --bind 'enter:become($EDITOR {1} +{2})'
  fi
}

# Yazi visual file browser. `y` opens it, and on quit drops the shell into
# whatever folder you were browsing, so a visual detour ends where you looked
# instead of back where you started. `command cat` bypasses the bat alias so
# the cwd file reads as plain text. Image/PDF previews render inline in Ghostty.
y() {
  emulate -L zsh
  local tmp cwd
  tmp="$(mktemp -t yazi-cwd.XXXXXX)" || return
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [[ -n "$cwd" && "$cwd" != "$PWD" ]]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

groundwork-repo-dir() {
  emulate -L zsh
  local source_path="$(chezmoi source-path 2>/dev/null || true)"
  [[ -n "$source_path" ]] || return 1
  if [[ "${source_path:t}" == "home" && -f "${source_path:h}/AGENTS.md" ]]; then
    print -r -- "${source_path:h}"
  else
    print -r -- "$source_path"
  fi
}

# Scaffold the Groundwork Twelve learning-log repo. Day 1 teaches typing the
# ritual by hand; this helper is for restarts and additional machines.
new-twelve-log() {
  emulate -L zsh
  local dest="${1:-$HOME/groundwork-log}"
  dest=${~dest}
  if [[ -e "$dest" ]]; then
    print "new-twelve-log: $dest already exists"
    return 1
  fi
  local repo="$(groundwork-repo-dir)"
  local src="$repo/skel/twelve-log"
  if [[ ! -d "$src" ]]; then
    print "new-twelve-log: skeleton not found at $src"
    return 1
  fi
  cp -R "$src" "$dest" || return 1
  git -C "$dest" init -q || return 1
  git -C "$dest" add -A || return 1
  if ! git -C "$dest" commit -qm "init groundwork twelve log"; then
    print "new-twelve-log: files copied to $dest, but git commit failed"
    print "fix your git identity/signing setup, then run:"
    print "  git -C ${(q)dest} add -A && git -C ${(q)dest} commit -m 'init groundwork twelve log'"
    return 1
  fi
  print "log ready: $dest"
  print "next: open log.md, write your Day 1 line, and commit it — that commit is Day 1"
  cd "$dest"
}

new-wiki() {
  emulate -L zsh
  if [[ -z "$1" ]]; then
    print "usage: new-wiki <path>"
    return 1
  fi
  local dest=${~1}
  if [[ -e "$dest" ]]; then
    print "new-wiki: $dest already exists"
    return 1
  fi
  local repo="$(groundwork-repo-dir)"
  local src="$repo/skel/llm-wiki"
  if [[ ! -d "$src" ]]; then
    print "new-wiki: skeleton not found at $src"
    return 1
  fi
  cp -R "$src" "$dest" || return 1
  [[ -f "$dest/gitignore" ]] && mv "$dest/gitignore" "$dest/.gitignore"
  git -C "$dest" init -q || return 1
  git -C "$dest" add -A || return 1
  if ! git -C "$dest" commit -qm "init knowledge wiki"; then
    print "new-wiki: files copied to $dest, but git commit failed"
    print "fix your git identity/signing setup, then run:"
    print "  git -C ${(q)dest} add -A && git -C ${(q)dest} commit -m 'init knowledge wiki'"
    return 1
  fi
  print "wiki ready: $dest"
  print "next: obsidian-plugins $dest"
  print "then open it with Claude Code or Codex, add a source to raw/, and say: ingest raw/<file>"
  cd "$dest"
}

# Personal shell overrides. This file is intentionally unmanaged by Groundwork and
# loads last, so aliases/functions exported here win without forking the repo.
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

{{ if not .headless -}}
groundwork-update-reminder() {
  emulate -L zsh
  [[ -o interactive ]] || return
  [[ -z "${CI:-}" ]] || return
  [[ "${GROUNDWORK_UPDATE_REMINDER:-1}" != "0" ]] || return

  local threshold="${GROUNDWORK_UPDATE_REMINDER_DAYS:-7}"
  [[ "$threshold" == <-> ]] || threshold=7
  (( threshold > 0 )) || return

  zmodload zsh/stat 2>/dev/null || return

  local state_dir="$HOME/.local/state/groundwork"
  local stamp="$state_dir/last-update-all"
  local shown="$state_dir/update-reminder-last-shown"
  local now shown_epoch last_epoch age_days

  now="$(date +%s 2>/dev/null)" || return

  if [[ -f "$shown" ]]; then
    shown_epoch="$(zstat +mtime "$shown" 2>/dev/null || print 0)"
    (( now - shown_epoch < 86400 )) && return
  fi

  if [[ -f "$stamp" ]]; then
    last_epoch="$(zstat +mtime "$stamp" 2>/dev/null)" || return
    age_days=$(( (now - last_epoch) / 86400 ))
    (( age_days < threshold )) && return
    print -P "%F{yellow}Groundwork:%f tools last refreshed ${age_days} days ago; run %Bupdate-all%b when you have a few minutes."
  else
    print -P "%F{yellow}Groundwork:%f no successful %Bupdate-all%b refresh has been recorded yet; run it when you have a few minutes."
  fi

  print "Set GROUNDWORK_UPDATE_REMINDER=0 in ~/.zshrc.local to silence this reminder."
  mkdir -p "$state_dir" && : >| "$shown"
}
groundwork-update-reminder
unfunction groundwork-update-reminder
{{- end }}
