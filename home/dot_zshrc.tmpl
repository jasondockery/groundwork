alias ll="eza -lah --git --group-directories-first"
alias lt="eza --tree --level=2 --group-directories-first"
alias ltt="eza --tree --level=3 --group-directories-first"
alias cat="bat"
alias lg="lazygit"
{{ if eq .chezmoi.os "darwin" -}}
alias zen="open -a Zen"
