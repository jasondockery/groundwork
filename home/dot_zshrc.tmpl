for _brew in /opt/homebrew/bin/brew /home/linuxbrew/.linuxbrew/bin/brew /usr/local/bin/brew; do
  [[ -x "$_brew" ]] && eval "$("$_brew" shellenv)" && break
done
unset _brew

export PATH="$HOME/.local/bin:$PATH"
typeset -gU path PATH

# macOS still ships a 256-open-file soft limit per process; file watchers,
# bundlers, LSP servers, and parallel agent sessions blow through it with
# confusing "too many open files" errors. Raise the soft limit toward 10240,
# never above the hard limit this shell actually has (containers set lower ones).
() {
  local target=10240 hard="$(ulimit -Hn)"
  [[ "$hard" != unlimited ]] && (( hard < target )) && target=$hard
  (( $(ulimit -Sn) < target )) && ulimit -Sn "$target" 2>/dev/null
}
{{ if and (eq .chezmoi.os "darwin") (not .headless) (ne .password_manager "none") -}}
{{ if eq .password_manager "bitwarden" }}
# Bitwarden SSH agent (.dmg/Homebrew build). App Store build:
# $HOME/Library/Containers/com.bitwarden.desktop/Data/.bitwarden-ssh-agent.sock
export SSH_AUTH_SOCK="$HOME/.bitwarden-ssh-agent.sock"
{{- else if eq .password_manager "1password" }}
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- end }}
{{- end }}

export EDITOR="nvim"
export VISUAL="nvim"
export PAGER="less"
# -i = smart-case search in everything less pages (bat, man, git log):
# lowercase patterns match any case; one uppercase letter makes it exact.
# Matches the rg/fzf/LazyVim default so / behaves the same in every tool.
export LESS="-iR"
export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/config"
export FZF_DEFAULT_COMMAND="rg --files"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type d"
export FZF_DEFAULT_OPTS="--height 40% --layout reverse --border"
# Ctrl+T previews files with bat; Alt+C previews folders as a short tree.
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:200 {}' --preview-window 'right,55%,border-left'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --level=2 --group-directories-first --color=always {}'"
# Inside tmux, the Ctrl+T and Alt+C pickers open in a floating popup instead of
# squashing the pane; fzf's key bindings read this and ignore it outside tmux.
export FZF_TMUX_OPTS="-p 80%,60%"
# AI coding agents move quickly; keep Claude Code's package-managed install on
# its vendor-supported latest path while broad Homebrew/mise upgrades stay manual.
export CLAUDE_CODE_PACKAGE_MANAGER_AUTO_UPDATE=1
# Unlike modern build tools, plain make compiles one file at a time unless told
# otherwise. Derive parallelism from this machine's cores; never hardcode it.
if [[ -z "${MAKEFLAGS:-}" ]]; then
  export MAKEFLAGS="-j$(sysctl -n hw.ncpu 2>/dev/null || nproc 2>/dev/null || print 1)"
fi

# Docker CLI completions (generated by Groundwork's tools script; Docker
# Desktop's "Install" button would append this to .zshrc itself — an edit
# chezmoi owns and would revert). Must precede antidote: ez-compinit runs
# compinit during plugin load, and fpath additions after that are invisible.
[[ -d "$HOME/.docker/completions" ]] && fpath=("$HOME/.docker/completions" $fpath)

for _antidote in "${HOMEBREW_PREFIX:-}/share/antidote/antidote.zsh" /usr/local/share/antidote/antidote.zsh "$HOME/.local/share/antidote/antidote.zsh"; do
  if [[ -f "$_antidote" ]]; then
    source "$_antidote"
    antidote load "$HOME/.zsh_plugins.txt"
    break
  fi
done
unset _antidote

# Emacs-style command-line editing (Ctrl+A/E/W/U/K; accept an autosuggestion with Ctrl+E).
# Forced explicitly: zsh otherwise selects vi mode because $EDITOR is nvim (contains "vi"),
# which leaves those keys unbound. Affects line editing only, not which editor opens.
bindkey -e

# history
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000
setopt EXTENDED_HISTORY SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS HIST_VERIFY HIST_FCNTL_LOCK

# navigation + globbing
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS PUSHD_SILENT
setopt EXTENDED_GLOB NO_CASE_GLOB INTERACTIVE_COMMENTS NO_BEEP

# Starship's right_format (repo/folder context) shows on the active prompt
# only; this erases it from lines already accepted, keeping scrollback lean.
setopt TRANSIENT_RPROMPT

# completion
setopt COMPLETE_IN_WORD ALWAYS_TO_END
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' menu select
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' rehash true

# The prompt is lean, so show the current folder once in the terminal
# tab/window title instead. Inside tmux the pane border already carries it,
# and overwriting the pane title would double the path shown there.
if [[ -z "${TMUX:-}" ]]; then
  autoload -Uz add-zsh-hook
  _groundwork_title_precmd() { print -Pn '\e]0;%~\a'; }
  add-zsh-hook precmd _groundwork_title_precmd
fi

# Self-refreshing shells: after `chezmoi apply` rewrites ~/.zshrc, every open
# pane is a stale shell that never re-reads config. Instead of anything
# reaching into panes (unsafe mid-vim/ssh/typing), each shell checks its own
# config mtime at the prompt boundary — the one moment nothing is running —
# and reloads itself. Guard: background jobs would die on exec, so with jobs
# present it prints a hint once instead. cwd and history survive exec zsh;
# only the pushd stack resets.
zmodload -F zsh/stat b:zstat 2>/dev/null
if (( $+builtins[zstat] )); then
  _groundwork_zshrc_mtime() { zstat +mtime -- "${ZDOTDIR:-$HOME}/.zshrc" 2>/dev/null; }
  _groundwork_zshrc_loaded="$(_groundwork_zshrc_mtime)"
  _groundwork_config_refresh_precmd() {
    local now
    now="$(_groundwork_zshrc_mtime)" || return 0
    [[ -n "$now" && -n "$_groundwork_zshrc_loaded" && "$now" != "$_groundwork_zshrc_loaded" ]] || return 0
    if [[ -z "$(jobs)" ]]; then
      print -P '%F{cyan}↻ shell config updated — reloading this shell%f'
      exec zsh
    elif [[ "${_groundwork_config_notified:-}" != "$now" ]]; then
      _groundwork_config_notified="$now"
      print -P '%F{yellow}↻ shell config updated — reloads when background jobs finish (or run exec zsh)%f'
    fi
  }
  autoload -Uz add-zsh-hook
  add-zsh-hook precmd _groundwork_config_refresh_precmd
fi

command -v starship >/dev/null && eval "$(starship init zsh)"
command -v zoxide   >/dev/null && eval "$(zoxide init zsh)"
command -v mise     >/dev/null && eval "$(mise activate zsh)"
command -v direnv   >/dev/null && eval "$(direnv hook zsh)"
if command -v fzf >/dev/null; then
  _fzf_init="$(fzf --zsh 2>/dev/null || true)"
  if [[ -n "$_fzf_init" ]]; then
    source <(print -r -- "$_fzf_init")
  fi
  unset _fzf_init
fi
# Atuin owns Ctrl+R history. Leave Up Arrow as plain shell history. Keep bare ?
# free unless the user explicitly opts into Atuin AI's question-mark binding.
if command -v atuin >/dev/null; then
  _atuin_flags=(--disable-up-arrow)
  if [[ ! -f "$HOME/.config/groundwork/enable-atuin-ai" ]]; then
    _atuin_flags+=(--disable-ai)
  fi
  eval "$(atuin init zsh "${_atuin_flags[@]}")"
  unset _atuin_flags
fi

