#!/usr/bin/env bash
set -euo pipefail
{{- $brewfile := joinPath .chezmoi.sourceDir "dot_config/homebrew/Brewfile.tmpl" }}
{{- if stat $brewfile }}
# Brewfile hash: {{ includeTemplate "dot_config/homebrew/Brewfile.tmpl" . | sha256sum }}
{{- end }}

for brew_bin in /opt/homebrew/bin/brew /home/linuxbrew/.linuxbrew/bin/brew /usr/local/bin/brew; do
  [[ -x "$brew_bin" ]] && eval "$("$brew_bin" shellenv)" && break
done
unset brew_bin

command -v brew >/dev/null 2>&1 || exit 0

# claude-code and claude-code@latest both install the `claude` binary, so
# existing stable-channel installs need to be removed before brew bundle can
# switch them to the latest channel declared in the Brewfile.
if grep -q '^cask "claude-code@latest"' "$HOME/.config/homebrew/Brewfile" \
  && brew list --cask claude-code >/dev/null 2>&1 \
  && ! brew list --cask claude-code@latest >/dev/null 2>&1; then
  brew uninstall --cask claude-code
fi

# --verbose streams each download and install; the default prints one
# "Fetching ..." line and then nothing for a multi-gigabyte fetch, which
# reads as a hang and invites a Ctrl+C that only delays the install.
# Downloads still run in parallel and the fetch phase can be quiet for
# stretches, so say so up front, and let Homebrew print a heartbeat dot
# (at most one per minute) whenever it would otherwise be silent.
echo "Groundwork: fetching Homebrew packages — a fresh install downloads"
echo "several gigabytes in parallel and can look quiet for minutes at a"
echo "time. It has not hung; interrupting only delays it (it resumes)."
export HOMEBREW_VERBOSE_USING_DOTS=1
# One failed package must not skip the recovery steps below (a dead cask
# should never leave the launcher or keyboard driver down), but the script
# still exits non-zero afterwards so chezmoi retries the bundle on the next
# apply instead of recording it as done. Output is teed to a log so that
# when Homebrew prints its own remediation block (circular formula
# dependencies and similar known-broken states), groundwork-brew-repair can
# offer to run exactly those commands and the bundle retries once.
bundle_log="$(mktemp "${TMPDIR:-/tmp}/groundwork-brew-bundle.XXXXXX")"
trap 'rm -f -- "$bundle_log"' EXIT
bundle_status=0
# Checksums are an INSTALL-time policy, not just an upgrade-time one: a fresh
# machine gets its casks from here, long before update-all ever runs.
# HOMEBREW_CASK_OPTS is how --require-sha reaches `brew bundle`'s cask installs.
# A cask with no checksum must fail the bundle, not be quietly accepted.
#
# The user's own HOMEBREW_CASK_OPTS is PRESERVED, not replaced: it can carry
# their appdir, language, --no-binaries, or their own --require-sha. Groundwork
# appends its requirement for its own commands and never exports over theirs.
user_cask_opts="${HOMEBREW_CASK_OPTS-}"
safe_cask_opts="${user_cask_opts:+$user_cask_opts }--require-sha"
HOMEBREW_CASK_OPTS="$safe_cask_opts" \
  brew bundle --verbose --file="$HOME/.config/homebrew/Brewfile" 2>&1 | tee "$bundle_log" || bundle_status=$?
if [[ "$bundle_status" -ne 0 ]] \
  && "$HOME/.local/bin/groundwork-brew-repair" "$bundle_log"; then
  bundle_status=0
  HOMEBREW_CASK_OPTS="$safe_cask_opts" \
    brew bundle --verbose --file="$HOME/.config/homebrew/Brewfile" || bundle_status=$?
fi

{{- if and (eq .chezmoi.os "darwin") (not .headless) }}
# Homebrew may quit always-on apps (Karabiner, Raycast, BetterDisplay,
# Anybox) during an install/upgrade and does not relaunch them; reopen any
# that are installed but not running so hotkeys, keyboard rules, and menu-bar
# services do not silently disappear.
"$HOME/.local/bin/groundwork-apps-start" || true
{{- end }}

if [[ "$bundle_status" -ne 0 ]]; then
  echo "Groundwork: brew bundle failed for at least one package — scroll up for its 'failed' line."
  echo "Everything that installed is fine and stays installed; the next chezmoi apply retries only what's missing."
  echo "To retry just the packages now: brew bundle --file=\"\$HOME/.config/homebrew/Brewfile\""
  exit "$bundle_status"
fi
{{- if and (eq .chezmoi.os "darwin") (not .headless) (hasKey . "install_chrome") .install_chrome }}

# ---- The one checksum exception, and ONLY after the safe lane succeeded ----
#
# Chrome ships `sha256 :no_check` upstream (Google's own updater owns the
# binary), so it cannot satisfy the --require-sha policy the Brewfile is
# installed under — which is exactly why it is not IN the Brewfile. It is
# installed here only because you said yes at setup, and only after every
# checksum-verified package succeeded: a failed safe lane must never trigger an
# unsafe exception lane.
#
# Failure is a real failure. `run_onchange` would otherwise record this script
# as done and never retry, leaving a machine that silently lacks something
# Groundwork claims to install.
if ! brew list --cask google-chrome >/dev/null 2>&1; then
  echo "Groundwork: installing google-chrome WITHOUT a checksum — you approved this at setup."
  echo "  Chrome declares 'sha256 :no_check' upstream; Google's own updater owns the binary."
  echo "  Every other Groundwork cask is checksum-verified."
  # Two policies now contradict each other: setup says install Chrome, the
  # user's own HOMEBREW_CASK_OPTS says never install an unchecked cask.
  # Groundwork will not strip their security choice, and will not quietly
  # convert "install it" into "skipped, all good" either — that leaves a
  # machine whose desired state was never reached and which may never retry.
  # Fail, and make the person pick one.
  if [[ "$user_cask_opts" == *--require-sha* ]]; then
    cat >&2 <<'CONFLICT'
Groundwork: Google Chrome was requested at setup, but your own
HOMEBREW_CASK_OPTS requires checksummed casks — and Chrome ships none.

Chrome was NOT installed and this apply is incomplete. Pick one policy:
  - keep your --require-sha and turn Chrome off:
      chezmoi edit-config   (set install_chrome = false)
  - or drop your own --require-sha and re-run chezmoi apply.
CONFLICT
    exit 1
  fi
  HOMEBREW_CASK_OPTS="$user_cask_opts" brew install --cask google-chrome
fi
{{- end }}
