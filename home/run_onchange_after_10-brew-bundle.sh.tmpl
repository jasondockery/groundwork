#!/usr/bin/env bash
set -euo pipefail
{{- $brewfile := joinPath .chezmoi.sourceDir "dot_config/homebrew/Brewfile.tmpl" }}
{{- if stat $brewfile }}
# Brewfile hash: {{ includeTemplate "dot_config/homebrew/Brewfile.tmpl" . | sha256sum }}
{{- end }}

for brew_bin in /opt/homebrew/bin/brew /home/linuxbrew/.linuxbrew/bin/brew /usr/local/bin/brew; do
  [[ -x "$brew_bin" ]] && eval "$("$brew_bin" shellenv)" && break
done
unset brew_bin

command -v brew >/dev/null 2>&1 || exit 0

# claude-code and claude-code@latest both install the `claude` binary, so
# existing stable-channel installs need to be removed before brew bundle can
# switch them to the latest channel declared in the Brewfile.
if grep -q '^cask "claude-code@latest"' "$HOME/.config/homebrew/Brewfile" \
  && brew list --cask claude-code >/dev/null 2>&1 \
  && ! brew list --cask claude-code@latest >/dev/null 2>&1; then
  brew uninstall --cask claude-code
fi

# --verbose streams each download and install; the default prints one
# "Fetching ..." line and then nothing for a multi-gigabyte fetch, which
# reads as a hang and invites a Ctrl+C that only delays the install.
# Downloads still run in parallel and the fetch phase can be quiet for
# stretches, so say so up front, and let Homebrew print a heartbeat dot
# (at most one per minute) whenever it would otherwise be silent.
echo "Groundwork: fetching Homebrew packages — a fresh install downloads"
echo "several gigabytes in parallel and can look quiet for minutes at a"
echo "time. It has not hung; interrupting only delays it (it resumes)."
export HOMEBREW_VERBOSE_USING_DOTS=1
# One failed package must not skip the recovery steps below (a dead cask
# should never leave the launcher or keyboard driver down), but the script
# still exits non-zero afterwards so chezmoi retries the bundle on the next
# apply instead of recording it as done.
bundle_status=0
brew bundle --verbose --file="$HOME/.config/homebrew/Brewfile" || bundle_status=$?

{{- if and (eq .chezmoi.os "darwin") (not .headless) }}
# Homebrew may quit always-on apps (Karabiner, Raycast, BetterDisplay,
# Anybox) during an install/upgrade and does not relaunch them; reopen any
# that are installed but not running so hotkeys, keyboard rules, and menu-bar
# services do not silently disappear.
"$HOME/.local/bin/groundwork-apps-start" || true
{{- end }}

if [[ "$bundle_status" -ne 0 ]]; then
  echo "Groundwork: brew bundle failed for at least one package — scroll up for its 'failed' line."
  echo "Everything that installed is fine and stays installed; the next chezmoi apply retries only what's missing."
  echo "To retry just the packages now: brew bundle --file=\"\$HOME/.config/homebrew/Brewfile\""
  exit "$bundle_status"
fi
