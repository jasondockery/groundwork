set -g mouse on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -g history-limit 100000
set -g escape-time 10

set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",xterm-256color:RGB,*:RGB"
set-environment -g TMUX_PLUGIN_MANAGER_PATH "$HOME/.config/tmux/plugins/"

setw -g mode-keys vi
set -g set-clipboard on
set -g detach-on-destroy off
set -g allow-passthrough on
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi C-v send -X rectangle-toggle
bind -T copy-mode-vi y send -X copy-selection-and-cancel
# Copy the last completed command + its output, selected by semantic prompt
# marks (OSC 133, emitted by Groundwork's zsh) — running commands and
# prompt-looking output can't fool it. Terminal-native "select last output"
# can't see inside tmux panes; this is the tmux-owned equivalent. Absolute
# path and -b: don't trust a long-lived server's PATH, don't block the client.
bind Y run-shell -b '"$HOME/.local/bin/tmux-copy-last" "#{pane_id}" "#{client_name}"'

unbind C-b
set -g prefix C-a
bind C-a send-prefix

bind r source-file ~/.config/tmux/tmux.conf \; display-message "tmux reloaded"

# Window naming is hybrid, and these are tmux's defaults — stated here so the
# behavior is a documented decision, not an accident. Unnamed windows auto-name
# from the running command (zsh, nvim, claude); renaming one with prefix-,
# turns auto-rename off for that window only, so the human's name sticks.
# allow-rename stays off so programs can't rename windows via escape sequences
# (they may still set the pane title, shown in the pane border — that's the
# right place for machine chatter like an agent's task summary).
set -g allow-rename off
setw -g automatic-rename on

# rename feedback: the status line only re-renders every status-interval (10s)
# or on events like switching windows, so a rename can look ignored. Force an
# immediate status redraw after renaming a window or session, then save the
# session state — continuum autosaves only every 15 minutes, and a rename that
# misses the last save before a server restart is silently lost on restore.
bind , command-prompt -I "#W" "rename-window -- '%%' ; refresh-client -S ; run-shell -b 'save=~/.config/tmux/plugins/tmux-resurrect/scripts/save.sh; [ -x \"$save\" ] && \"$save\" quiet || true'"
bind '$' command-prompt -I "#S" "rename-session -- '%%' ; refresh-client -S ; run-shell -b 'save=~/.config/tmux/plugins/tmux-resurrect/scripts/save.sh; [ -x \"$save\" ] && \"$save\" quiet || true'"

bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"

bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# keep readline control keys available to the shell after reloading older configs
unbind -nq C-h
unbind -nq C-j
unbind -nq C-k
unbind -nq C-l
unbind -nq C-\\
unbind -T prefix -q C-l

# clear: C-l stays the normal shell clear-screen key; prefix C-k also wipes tmux scrollback.
bind C-k send-keys C-l \; clear-history
# Destructive keys ask first. tmux's own default for x is confirm-before, and
# x sits right next to z (zoom) — a mistyped zoom must not silently destroy a
# pane with a running agent, server, or unsaved editor in it.
bind x confirm-before -p "kill pane #P (#{pane_current_command})? (y/n)" kill-pane

# resize panes (repeatable: hold the key)
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# reorder the current window in the list
bind -r < swap-window -d -t -1
bind -r > swap-window -d -t +1

# show each pane's title and current directory in the border; useful when a full-screen app hides the prompt.
set -g pane-border-status top
set -g pane-border-format ' #{?pane_active,#[fg=colour225,bold],#[fg=colour245]}#{pane_index}:#{pane_title} #[fg=colour244]#{pane_current_path} '
bind P command-prompt -I "#{pane_title}" "select-pane -T '%%'"

# toggle typing into all panes at once
bind S set-window-option synchronize-panes \; display-message "sync-panes #{?synchronize-panes,on,off}"

# lazygit in a popup, opened in the current folder
bind g display-popup -E -d "#{pane_current_path}" -w 90% -h 90% lazygit

# Inside the picker, Ctrl+x kills the highlighted tmux session and reloads the
# list (folder rows aren't live sessions, so Ctrl+x is a no-op on those).
bind -N "session switcher" T display-popup -E -w 40% -h 50% \
  "sesh connect \"$(sesh list --icons | fzf --ansi --reverse --no-sort --prompt 'sesh ' \
    --header 'enter connect · ctrl-x kill session' \
    --bind 'ctrl-x:execute-silent(tmux kill-session -t {2..})+reload(sesh list --icons)')\""

set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'tmux-plugins/tmux-cpu'
set -g @plugin 'tmux-plugins/tmux-battery'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'catppuccin/tmux#v2.3.0'

# tmux-yank claims prefix+Y for "copy the pane's working directory", and
# plugins load after this file, so it would silently win over the prefix+Y
# copy-last-command binding above. Move its pwd copy to prefix+C-y (still
# available, just not on the more valuable key).
set -g @yank_pane_pwd 'C-y'

set -g @vim_navigator_mapping_left 'M-h'
set -g @vim_navigator_mapping_down 'M-j'
set -g @vim_navigator_mapping_up 'M-k'
set -g @vim_navigator_mapping_right 'M-l'
set -g @vim_navigator_mapping_prev ''
set -g @vim_navigator_prefix_mapping_clear_screen ''

{{- if not .headless }}
set -g @continuum-restore 'on'
{{- else }}
set -g @continuum-restore 'off'
{{- end }}
set -g @resurrect-dir '~/.local/share/tmux/resurrect'
set -g @resurrect-capture-pane-contents 'on'

# catppuccin v2: set the flavor AND build the status line, or the modules don't render.
# Keep system modules glanceable, not chatty; tmux-sensible's default is 5s.
set -g status-interval 10
set -g status-left-length 100
set -g status-right-length 160

set -g @catppuccin_flavor 'mocha'
set -g @catppuccin_window_status_style 'rounded'
set -g @catppuccin_window_number_position 'right'
set -g @catppuccin_window_text ' #W'
set -g @catppuccin_window_current_text ' #W'
set -g @catppuccin_date_time_text '%a %H:%M'

# Catppuccin's CPU/RAM/battery modules contain plugin placeholders such as
# #{cpu_percentage}. Source the theme before building the status line so the
# -F expansions below expose those placeholders for tmux-cpu/tmux-battery.
source-file -q ~/.config/tmux/plugins/tmux/catppuccin_options_tmux.conf
source-file -q ~/.config/tmux/plugins/tmux/catppuccin_tmux.conf

set -g status-left '#{E:@catppuccin_status_session}'
set -g status-right '#{E:@catppuccin_status_application}'
set -agF status-right '#{E:@catppuccin_status_cpu}'
set -agF status-right '#{E:@catppuccin_status_ram}'
set -ag status-right '#{E:@catppuccin_status_host}'
if-shell 'pmset -g batt 2>/dev/null | grep -q InternalBattery || ls /sys/class/power_supply/BAT* >/dev/null 2>&1' "set -agF status-right '#{E:@catppuccin_status_battery}'"
set -ag status-right '#{E:@catppuccin_status_date_time}'

# Personal tmux overrides. This file is intentionally unmanaged by Groundwork and
# loads after shared defaults, so local bindings/options can win without forking.
source-file -q ~/.config/tmux/tmux.local.conf

run '~/.config/tmux/plugins/tpm/tpm'
