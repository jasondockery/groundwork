#!/usr/bin/env bash
set -euo pipefail

for _brew in /opt/homebrew/bin/brew /home/linuxbrew/.linuxbrew/bin/brew /usr/local/bin/brew; do
  [[ -x "$_brew" ]] && eval "$("$_brew" shellenv)" && break
done
unset _brew

# This script always runs (not run_once), so a tool that failed to install — network
# blip, registry hiccup — is retried on the next apply. The guards below make each
# install a no-op once the tool is present, so re-running is cheap. Put the install
# dirs on PATH first so those `command -v` checks find what's already there.
export PATH="$HOME/.local/bin:$PATH"

tmux_plugin_dir="$HOME/.config/tmux/plugins"
tmux_conf="$HOME/.config/tmux/tmux.conf"
if [[ ! -d "$tmux_plugin_dir/tpm" ]]; then
  mkdir -p "$tmux_plugin_dir"
  git clone --depth 1 https://github.com/tmux-plugins/tpm "$tmux_plugin_dir/tpm" || true
fi
tmux_plugins_missing=false
if [[ -f "$tmux_conf" ]]; then
  while IFS= read -r _tmux_plugin; do
    _tmux_plugin="${_tmux_plugin%%#*}"
    _tmux_plugin="${_tmux_plugin%.git}"
    _tmux_plugin="${_tmux_plugin##*/}"
    [[ -n "$_tmux_plugin" ]] || continue
    if [[ ! -d "$tmux_plugin_dir/$_tmux_plugin" ]]; then
      tmux_plugins_missing=true
      break
    fi
  done < <(sed -nE "s/^[[:space:]]*set(-option)?[[:space:]]+-g[[:space:]]+@plugin[[:space:]]+['\"]?([^'\"[:space:]]+)['\"]?.*$/\2/p" "$tmux_conf")
  unset _tmux_plugin
fi
if [[ "$tmux_plugins_missing" == true ]] && command -v tmux >/dev/null 2>&1 && [[ -x "$tmux_plugin_dir/tpm/bin/install_plugins" ]]; then
  # TPM's CLI reads ~/.config/tmux/tmux.conf and can install plugins without a
  # live tmux client. Do not reload or kill the user's current tmux session here.
  "$tmux_plugin_dir/tpm/bin/install_plugins" || true
fi

if [[ ! -e "$HOME/.config/nvim/init.lua" ]]; then
  tmp_nvim="$(mktemp -d)"
  if git clone --depth 1 https://github.com/LazyVim/starter "$tmp_nvim"; then
    rm -rf "$tmp_nvim/.git"
    mkdir -p "$HOME/.config/nvim"
    cp -R "$tmp_nvim"/. "$HOME/.config/nvim"/
  else
    echo "LazyVim starter clone failed; will retry on next chezmoi apply." >&2
  fi
  rm -rf "$tmp_nvim"
fi

# Install the tools declared in mise's global config (Node LTS, pnpm, Python).
# `mise activate` only puts tools on PATH — it never installs them — so without this they're
# declared but missing. Idempotent: already-installed versions are skipped.
if command -v mise >/dev/null 2>&1; then
  mise install || true
fi

if command -v uv >/dev/null 2>&1; then
  # Aider's voice dependency still imports audioop/pyaudioop on startup. Python
  # 3.13 removed audioop, so keep Aider's isolated uv tool runtime on 3.12 until
  # that upstream dependency path is fixed.
  aider_python="3.12"
  if ! command -v aider >/dev/null 2>&1 || ! aider --version >/dev/null 2>&1; then
    uv tool install --python "$aider_python" --reinstall aider-chat || true
  fi
fi

# Seed the manual-update reminder without resetting it on every apply. `update-all`
# refreshes this marker after a successful visible/batched update.
groundwork_state_dir="$HOME/.local/state/groundwork"
mkdir -p "$groundwork_state_dir"
if [[ ! -e "$groundwork_state_dir/last-update-all" ]]; then
  touch "$groundwork_state_dir/last-update-all"
fi

{{ if and (not .work) (not .headless) -}}
# Grok Build (xAI CLI) — personal machines only. Requires a SuperGrok / X Premium+ subscription.
# This vendor installer is intentionally best-effort and not part of the
# reproducible headless path; pin/checksum it before making it required.
if ! command -v grok >/dev/null 2>&1; then
  curl -fsSL https://x.ai/cli/install.sh | bash || true
fi
{{- end }}
