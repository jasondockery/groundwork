{{- if eq .chezmoi.os "windows" -}}
{{- fail "Groundwork's terminal environment requires macOS, Linux, or WSL2. On Windows, install WSL2 with Ubuntu and run Groundwork inside WSL; native PowerShell/CMD is not part of the Groundwork v1 support contract. See https://jasondockery.github.io/groundwork/platforms.html" -}}
{{- end -}}
{{- $work := promptBoolOnce . "work" "Is this a work machine? [y/N]" false -}}
{{- $headless := false -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $headless = promptBoolOnce . "headless" "Is this a server/CI Mac with no desktop apps? Most Macs should say no. [y/N]" false -}}
{{- else -}}
{{- $headless = promptBoolOnce . "headless" "Headless/server environment with no desktop apps? [Y/n]" true -}}
{{- end -}}
{{- $name := promptStringOnce . "name" "What name should Git use for commits?" -}}
{{- $emailPersonal := promptStringOnce . "email_personal" "What personal email should Git use for commits?" -}}
{{- $emailWork := promptStringOnce . "email_work" "What work email should Git use? (blank if none)" "" -}}
{{- $codeDir := promptStringOnce . "code_dir" "Where should projects live?" "~/code" -}}
{{- $resetExisting := promptBoolOnce . "reset_existing_configs" "Reset old terminal/editor/tmux state before applying? [y/N]" false -}}
{{- $pwManagers := list "bitwarden" "1password" "none" -}}
{{- $pwManager := promptChoiceOnce . "password_manager" "Which password manager should Groundwork configure for SSH + git signing?" $pwManagers "bitwarden" -}}
{{- $signingKey := promptStringOnce . "signingkey" "What SSH public key should Git use for signing? (blank to skip)" "" -}}
{{- $obsidianVault := promptStringOnce . "obsidian_vault_name" "What should the Obsidian vault be named? (blank to skip)" "my_obsidian_vault" -}}
{{- $gameDev := promptBoolOnce . "game_dev" "Install optional Unity game development tools? Large download. [y/N]" false -}}
{{- $xcode := promptBoolOnce . "xcode" "Install Xcode for native Apple/iOS development? Large (~15GB+). [y/N]" false -}}
{{- $beta := false -}}
{{- if $xcode -}}
{{- $beta = promptBoolOnce . "beta" "Also follow Apple's Xcode beta channel? Adds the xcodes tool so you can install Xcode betas from Apple's developer downloads; you sign in with your Apple Account (no paid membership needed) and choose versions yourself. [y/N]" false -}}
{{- end -}}

sourceDir = {{ .chezmoi.workingTree | quote }}

[data]
    work = {{ $work }}
    headless = {{ $headless }}
    name = {{ $name | quote }}
    email_personal = {{ $emailPersonal | quote }}
    email_work = {{ $emailWork | quote }}
    code_dir = {{ $codeDir | quote }}
    reset_existing_configs = {{ $resetExisting }}
    password_manager = {{ $pwManager | quote }}
    signingkey = {{ $signingKey | quote }}
    obsidian_vault_name = {{ $obsidianVault | quote }}
    game_dev = {{ $gameDev }}
    xcode = {{ $xcode }}
    beta = {{ $beta }}

[edit]
    command = "nvim"

[diff]
    pager = "delta"
