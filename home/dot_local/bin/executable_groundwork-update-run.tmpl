#!/usr/bin/env bash
set -euo pipefail

# The post-sync half of update-all. The update-all launcher runs
# `chezmoi update --init` and then execs this freshly applied file, so every
# stage below runs the implementation the sync just installed. Stages guard on
# `command -v`, so the same file works on macOS, Linux, and WSL2 whether or not
# a given manager is installed. Run update-all, not this file, for a refresh
# that includes the sync.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

# The update-all launcher decides color once for the whole run and exports
# GROUNDWORK_COLOR before the sync, so every stage and hook script inherits
# it. Recompute only when invoked directly (same rules: NO_COLOR off,
# FORCE_COLOR on, else a real terminal on stdout).
if [[ -z "${GROUNDWORK_COLOR:-}" ]]; then
  if [[ -n "${NO_COLOR:-}" ]]; then
    GROUNDWORK_COLOR=0
  elif [[ -n "${FORCE_COLOR:-}" && "${FORCE_COLOR}" != "0" ]]; then
    GROUNDWORK_COLOR=1
  elif [[ -t 1 ]]; then
    GROUNDWORK_COLOR=1
  else
    GROUNDWORK_COLOR=0
  fi
fi
export GROUNDWORK_COLOR
if [[ "$GROUNDWORK_COLOR" == "1" ]]; then
  # Homebrew decides color per-process from its own stdout; the run-wide
  # signal already decided. HOMEBREW_COLOR is Homebrew's documented switch
  # for exactly this (force color even when stdout is not a TTY), and
  # Homebrew itself still honors NO_COLOR above it.
  export HOMEBREW_COLOR=1
fi

# Fail closed before any stage can mutate tools or the timestamp: the support
# contract is macOS, native Linux, and WSL2 — never WSL1 or an unverifiable
# WSL environment.
if [[ ! -x "$HOME/.local/bin/groundwork-platform" ]]; then
  echo "Groundwork: the platform helper is missing: $HOME/.local/bin/groundwork-platform" >&2
  echo "Restore it from the source you already have (this cannot fetch an upstream fix):" >&2
  echo "  chezmoi apply --exclude=scripts ~/.local/bin/groundwork-platform" >&2
  exit 1
fi
platform="$("$HOME/.local/bin/groundwork-platform" 2>/dev/null || echo unknown)"
case "$platform" in
  darwin | linux | wsl2) ;;
  wsl1)
    echo "Groundwork requires WSL2; WSL1 is unsupported. From PowerShell: \`wsl --list --verbose\` to check versions, \`wsl --set-version <DistributionName> 2\` to convert." >&2
    exit 1
    ;;
  wsl-unknown)
    echo "Groundwork detected WSL but could not verify WSL2. From PowerShell, run \`wsl --list --verbose\`; convert with \`wsl --set-version <DistributionName> 2\` if needed." >&2
    exit 1
    ;;
  *)
    echo "Groundwork does not support this platform: $platform" >&2
    exit 1
    ;;
esac

if command -v brew >/dev/null 2>&1; then
  "$HOME/.local/bin/groundwork-brew-update"
  # Use the metadata snapshot that just refreshed. A user-customized Homebrew
  # auto-update interval must not start a second, unwrapped update here.
  {{- if eq .chezmoi.os "darwin" }}
  # --require-sha: refuse to upgrade a cask that ships no checksum. Every cask
  # Groundwork installs is versioned and checksummed today (the AI CLIs
  # included — `claude-code@latest` is a faster release CHANNEL, not Homebrew's
  # `version :latest`), so this costs nothing now and fails loudly if an
  # unverified artifact ever enters the upgrade set. A checksum failure must
  # stop here; never retry without the flag, which would turn a policy refusal
  # into a silent bypass.
  #
  # No --greedy-latest: it only adds `version :latest` casks, and Groundwork
  # installs none — it was a no-op justified by a wrong comment.
  # NO_UPGRADE_AUTO_UPDATES_CASKS still leaves self-updating GUI apps to their
  # own channels, so they are not re-downloaded and re-quarantined behind fresh
  # Gatekeeper prompts.
  HOMEBREW_NO_AUTO_UPDATE=1 HOMEBREW_NO_UPGRADE_AUTO_UPDATES_CASKS=1 \
    brew upgrade --require-sha
  {{- else }}
  # Casks are a macOS concern; Homebrew on Linux/WSL2 upgrades formulae only.
  HOMEBREW_NO_AUTO_UPDATE=1 brew upgrade
  {{- end }}
  # Remove formulae that were only ever dependencies and are no longer
  # needed — this clears deprecated leftovers (a versioned icu4c, an old
  # python) that otherwise warn on every upgrade forever.
  brew autoremove
  brew cleanup
  {{- if and (eq .chezmoi.os "darwin") (not .headless) }}
  "$HOME/.local/bin/groundwork-apps-start" || true
  {{- end }}
fi

# Docker hygiene: one line, and only when disposable build leftovers have
# piled up. Like shell adoption, deletion is never something a refresh does
# silently — groundwork-docker-tidy --yes is the explicit owner step, and the
# tidy only ever touches images that opted in with the ephemeral label. The
# helper owns docker CLI and daemon reachability itself (--summary stays
# silent when either is missing), so no probe is duplicated here — and
# daemon-wide cleanup stays owner-run only, never invoked from a refresh.
if [[ -x "$HOME/.local/bin/groundwork-docker-tidy" ]]; then
  "$HOME/.local/bin/groundwork-docker-tidy" --summary || true
fi

if command -v mise >/dev/null 2>&1; then
  # The same 5-day floor the renovate-config preset applies to repo
  # dependencies, now applied to the machine: don't adopt a release the world
  # has not had time to notice was poisoned. It filters only fuzzy versions
  # (`lts`, `latest`); an explicitly pinned version is exempt, which is the
  # escape hatch for a security fix that must land immediately.
  if ! mise upgrade --help 2>/dev/null | grep -q -- '--minimum-release-age'; then
    # Fail closed. A policy that steps aside whenever it cannot be enforced is
    # not a control. The escape hatch for an urgent release already exists and
    # is narrow: pin that one runtime to an exact version, which the floor
    # exempts by design — no need for a second hatch that ungates everything.
    cat >&2 <<'EOF'
Groundwork: this mise cannot enforce the 5-day release floor
(--minimum-release-age is missing), so runtime upgrades were skipped.

  Upgrade mise, then run update-all again:  brew upgrade mise
  Urgent security release? Pin that exact runtime version; pinned versions
  bypass the floor by design.
EOF
    exit 1
  fi
  mise upgrade --minimum-release-age 5d
fi

{{- if ne .chezmoi.os "darwin" }}

# Ownership boundary: Groundwork updates the developer environment it manages
# and never mutates the operating system it runs inside — no distro package
# upgrades on Linux, no Windows-host updates from WSL2.
case "$platform" in
  wsl2)
    echo "Groundwork updated the WSL2 development environment. Windows applications and Windows Update are managed separately on the host."
    ;;
  linux)
    echo "Groundwork updated its managed developer tools. Operating-system packages (apt, dnf, pacman) are managed separately by your distribution."
    ;;
esac
{{- end }}

{{- if and (hasKey . "xcode") .xcode (hasKey . "beta") .beta }}
# Beta channel is opt-in and only meaningful with Xcode. update-all never
# downloads betas because they require the developer's Apple Account.
if command -v xcodes >/dev/null 2>&1; then
  echo 'Groundwork: beta channel on. Xcode betas: `xcodes list` to see them, `xcodes install "<version>"` to add one, and `xcodes select` to switch.'
fi
{{- end }}

# The reminder timestamp represents the complete transaction. Write a real UTC
# timestamp through an atomic rename so a failed or interrupted stage preserves
# the previous successful value.
timestamp="$HOME/.local/state/groundwork/last-update-all"
mkdir -p "$(dirname "$timestamp")"
temporary="${timestamp}.tmp.$$"
trap 'rm -f -- "$temporary"' EXIT
date -u '+%Y-%m-%dT%H:%M:%SZ' >"$temporary"
mv -f -- "$temporary" "$timestamp"
trap - EXIT

echo "Groundwork tools refreshed. The shell reminder will stay quiet until the next stale window."
