#!/usr/bin/env bash
set -euo pipefail

# Owner-scoped Docker tidy for the ephemeral-build contract.
#
# AI-native work builds images constantly: every review, test, or agent
# session that touches a Dockerfile builds a full image to verify it, tags it
# something ad hoc, and moves on — and nothing in that flow prunes. The
# contract fixes intent at build time: a disposable build declares itself with
# the ephemeral label and a scratch tag (groundwork-docker-build-scratch owns
# that syntax). This command removes only what opted in — the label is the
# consent — and it honors that consent BY ENUMERATION: every labeled image is
# inspected and judged individually by the shared scanner (lib/docker-scan.sh,
# the same facts groundwork-doctor reports), re-checked immediately before
# deletion, and deleted by explicit image ID. No broad prune ever runs here;
# daemon-wide state (dangling images, stopped containers, builder cache) is
# groundwork-docker-cache-tidy, a separate owner-only command.
#
# groundwork-doctor reports; this command acts — and still defaults to a dry
# run, because deleting stays the owner's decision.

EPHEMERAL_LABEL="dev.roost.ephemeral=true"
BUILT_LABEL="dev.roost.built"

usage() {
  cat <<EOF
Safe Docker tidy for ephemeral build images (dry run by default).

Usage:
  groundwork-docker-tidy             dry run: scan and report every candidate
  groundwork-docker-tidy --yes       remove what the scan proves eligible
  groundwork-docker-tidy --summary   one line when tidy-eligible leftovers
                                     exist, silence when clean (update-all
                                     uses this)
  groundwork-docker-tidy -h|--help   show this help

--yes removes ONLY:
  1. exited containers labeled $EPHEMERAL_LABEL whose CreatedAt is older than
     the SAME grace window that protects images — container state under an
     ephemeral image is disposable only after the grace — with the status
     re-checked immediately before removal, each removed by ID. A container
     whose age cannot be verified is retained and explained.
  2. images that pass EVERY check in the candidate scan:
       - carry $EPHEMERAL_LABEL, verified again on inspect
       - a strict-parsed $BUILT_LABEL timestamp older than the grace window
         (absent, malformed, or unverifiable = retained, never removed)
       - every tag inside the scratch namespace (*/scratch:*) — any other
         tag protects the image, even though a retag keeps the label
       - no container references it, running or stopped
     Candidates are deduplicated by image ID, re-checked immediately before
     deletion, and deleted by explicit image ID.

Verdicts: eligible (passes every check now), retained (inside the grace
window), protected (non-scratch tag or a container reference), unverified
(missing jq, or a missing/malformed $BUILT_LABEL — retained and explained).

Never touched: volumes, running containers and their images, unlabeled
images (your real 'groundwork' image, base images, every other project's
images), dangling images, and builder cache. Daemon-wide cleanup — which
reaches every project on this machine — is the separate, owner-run
groundwork-docker-cache-tidy.

Grace window: ${MAX_AGE_HOURS}h (GROUNDWORK_DOCKER_TIDY_MAX_AGE_HOURS, 1-8760).

Build scratch images with the wrapper so the contract cannot be mistyped:
  groundwork-docker-build-scratch <purpose> <context>

More help:
  groundwork-help docker
  https://jasondockery.github.io/groundwork/platforms.html
EOF
}

heading() { printf '\n== %s ==\n' "$1"; }
item() { printf '  %-11s %s\n' "$1" "$2"; }
detail() { printf '  %-11s %s\n' "" "$1"; }
note() { printf '  note  %s\n' "$1"; }

lib="${GROUNDWORK_DOCKER_LIB:-$HOME/.local/share/groundwork/lib/docker-scan.sh}"
if [[ ! -r "$lib" ]]; then
  echo "groundwork-docker-tidy: the docker-scan probe is missing: $lib" >&2
  echo "Restore it (this runs no install hooks): chezmoi apply --exclude=scripts ~/.local/share/groundwork" >&2
  exit 1
fi
# shellcheck source=/dev/null
. "$lib"

if ! MAX_AGE_HOURS="$(gw_docker_max_age_hours)"; then
  echo "groundwork-docker-tidy: invalid GROUNDWORK_DOCKER_TIDY_MAX_AGE_HOURS='${GROUNDWORK_DOCKER_TIDY_MAX_AGE_HOURS:-}' — want whole hours, 1-8760. Refusing to act on a garbled policy." >&2
  exit 2
fi

# The exited-container listing shared by every mode. One tab-separated line
# per container: id, name, status text. Prints nothing and returns 1 when the
# query itself failed, so callers can say "unknown" instead of "0".
list_exited_ephemeral() {
  docker ps -a --no-trunc --filter status=exited \
    --filter "label=$EPHEMERAL_LABEL" \
    --format $'{{.ID}}\t{{.Names}}\t{{.Status}}' 2>/dev/null
}

# Fresh per-container facts: created timestamp, current state, image.
# One inspect, three fields, tab-separated; fails when the container is gone.
container_facts() {
  docker container inspect \
    --format $'{{.Created}}\t{{.State.Status}}\t{{.Config.Image}}' "$1" 2>/dev/null
}

# Judge one exited labeled container against the SAME grace policy as images:
# its CreatedAt is the clock, and an age that cannot be proven retains it.
# Prints "verdict<TAB>reason<TAB>age<TAB>image"; verdict is eligible,
# retained, unverified, or missing.
container_verdict() {
  local cid="$1" facts created state image epoch now age
  if ! facts="$(container_facts "$cid")"; then
    printf 'missing\tno longer present\t-\t-\n'
    return 0
  fi
  IFS=$'\t' read -r created state image <<<"$facts"
  if [[ "$state" != "exited" ]]; then
    printf 'retained\tno longer exited (now %s)\t-\t%s\n' "$state" "$image"
    return 0
  fi
  # Docker reports .Created with fractional seconds; normalize to the
  # seconds-precision Zulu form the shared strict parser accepts.
  created="${created%Z}"
  created="${created%%.*}Z"
  if epoch="$(gw_docker_built_epoch "$created")"; then
    now="$(date -u +%s)"
    age=$(((now - epoch) / 3600))
    if ((age < MAX_AGE_HOURS)); then
      printf 'retained\tinside the %sh grace window (created %sh ago)\t%s\t%s\n' \
        "$MAX_AGE_HOURS" "$age" "$age" "$image"
    else
      printf 'eligible\tcreated %sh ago, past the %sh grace\t%s\t%s\n' \
        "$age" "$MAX_AGE_HOURS" "$age" "$image"
    fi
  elif [[ $? -eq 2 ]]; then
    printf 'unverified\tretained: jq is not installed, so the container age cannot be verified\t-\t%s\n' "$image"
  else
    printf 'unverified\tretained: unparseable CreatedAt, so the container age cannot be verified\t-\t%s\n' "$image"
  fi
}

count_status() {
  awk -F'\t' -v s="$1" '$2 == s { n++ } END { print n + 0 }'
}

report_scan_line() {
  local id="$1" status="$2" reason="$3" tags="$4" built="$5" age="$6" created="$7" size="$8" refs="$9"
  local age_display="unverified"
  [[ "$age" == "-" ]] || age_display="${age}h"
  item "$status" "${tags} — ${reason}"
  detail "id ${id}, built label ${built}, age ${age_display}, est. size ${size}, created ${created} (diagnostic only), container refs: ${refs}"
}

dry_run() {
  echo "groundwork-docker-tidy: dry run — nothing was changed. Add --yes to act."

  heading "Ephemeral build images (label $EPHEMERAL_LABEL, ${MAX_AGE_HOURS}h grace)"
  local scan n_eligible n_retained n_protected n_unverified
  scan="$(gw_docker_scan "$MAX_AGE_HOURS")"
  if [[ -z "$scan" ]]; then
    note "none found. Scratch builds opt in via groundwork-docker-build-scratch (see --help)."
    n_eligible=0
  else
    while IFS=$'\t' read -r id status reason tags built age created size refs; do
      [[ -n "$id" ]] || continue
      report_scan_line "$id" "$status" "$reason" "$tags" "$built" "$age" "$created" "$size" "$refs"
    done <<<"$scan"
    n_eligible="$(count_status eligible <<<"$scan")"
    n_retained="$(count_status retained <<<"$scan")"
    n_protected="$(count_status protected <<<"$scan")"
    n_unverified="$(count_status unverified <<<"$scan")"
    note "counts: $n_eligible eligible, $n_retained retained (in grace), $n_protected protected, $n_unverified unverified."
    if ((n_eligible > 0)); then
      note "eligible means eligible under the policy right now: --yes re-checks each image immediately before deletion, and Docker may retain an item if another reference exists by then."
    fi
  fi

  heading "Exited ephemeral containers (same label, same ${MAX_AGE_HOURS}h grace)"
  local exited verdict vreason vage vimage age_display
  if exited="$(list_exited_ephemeral)"; then
    if [[ -z "$exited" ]]; then
      note "none found."
    else
      while IFS=$'\t' read -r cid name cstatus; do
        [[ -n "$cid" ]] || continue
        IFS=$'\t' read -r verdict vreason vage vimage <<<"$(container_verdict "$cid")"
        age_display="unverified"
        [[ "$vage" == "-" ]] || age_display="${vage}h"
        item "$verdict" "$name ($cstatus) — $vreason"
        detail "id ${cid}, age ${age_display}, image ${vimage}"
      done <<<"$exited"
      note "container state under an ephemeral image is disposable only after the grace window; --yes re-checks each container's status immediately before removal."
    fi
  else
    note "could not list exited containers — reported as unknown, not zero."
  fi

  heading "Never touched"
  note "volumes — a dangling volume can still be the only copy of a database."
  note "running containers and their images."
  note "unlabeled images: your real 'groundwork' image, base images, and every other project's images — including unlabeled dangling images."
  note "builder cache. Dangling images, stopped containers, and builder cache are daemon-wide state (every project on this machine): that cleanup is the separate groundwork-docker-cache-tidy, which update-all never runs."
}

apply() {
  echo "groundwork-docker-tidy: tidying by the label contract ($EPHEMERAL_LABEL), by enumeration."

  local removed_containers=0 removed_images=0 skipped=0

  heading "1/2 exited containers labeled $EPHEMERAL_LABEL, past the ${MAX_AGE_HOURS}h grace"
  local exited verdict vreason vage vimage rstatus2 rreason2
  if exited="$(list_exited_ephemeral)"; then
    if [[ -z "$exited" ]]; then
      note "none found."
    else
      while IFS=$'\t' read -r cid name cstatus; do
        [[ -n "$cid" ]] || continue
        IFS=$'\t' read -r verdict vreason vage vimage <<<"$(container_verdict "$cid")"
        if [[ "$verdict" != "eligible" ]]; then
          item "$verdict" "$name (id $cid) — $vreason"
          [[ "$verdict" == "missing" ]] || skipped=$((skipped + 1))
          continue
        fi
        # Re-check with fresh facts immediately before removal: the container
        # may have been restarted or removed since the scan.
        IFS=$'\t' read -r rstatus2 rreason2 _ _ <<<"$(container_verdict "$cid")"
        if [[ "$rstatus2" == "missing" ]]; then
          item "skipped" "$name (id $cid) — already gone"
          continue
        fi
        if [[ "$rstatus2" != "eligible" ]]; then
          item "skipped" "$name (id $cid) — state changed since the scan: $rreason2"
          skipped=$((skipped + 1))
          continue
        fi
        if docker container rm "$cid" >/dev/null 2>&1; then
          item "removed" "$name ($cstatus, id $cid, age ${vage}h, image $vimage)"
          removed_containers=$((removed_containers + 1))
        else
          item "kept" "$name (id $cid) — docker refused the removal"
          skipped=$((skipped + 1))
        fi
      done <<<"$exited"
    fi
  else
    note "could not list exited containers; none were removed."
  fi

  heading "2/2 labeled images past the ${MAX_AGE_HOURS}h grace, each re-checked before deletion"
  local scan candidates id status reason tags built age created size refs
  scan="$(gw_docker_scan "$MAX_AGE_HOURS")"
  candidates="$(printf '%s\n' "$scan" | awk -F'\t' '$2 == "eligible"')"
  if [[ -z "$candidates" ]]; then
    note "no eligible images."
  else
    while IFS=$'\t' read -r id status reason tags built age created size refs; do
      [[ -n "$id" ]] || continue
      # Re-check with fresh facts immediately before deletion: the state may
      # have changed since the scan (a new tag, a new container, a rebuild).
      gw_docker_refresh_refs
      local recheck rstatus rreason rtags
      recheck="$(gw_docker_image_verdict "$id" "$MAX_AGE_HOURS" "$size")"
      rstatus="$(printf '%s' "$recheck" | cut -f2)"
      rreason="$(printf '%s' "$recheck" | cut -f3)"
      rtags="$(printf '%s' "$recheck" | cut -f4)"
      if [[ "$rstatus" == "missing" ]]; then
        item "skipped" "$tags — already gone (id $id)"
        continue
      fi
      if [[ "$rstatus" != "eligible" ]]; then
        item "skipped" "$rtags — state changed since the scan: now $rstatus ($rreason)"
        skipped=$((skipped + 1))
        continue
      fi
      # All tags are verified scratch tags on THIS image ID. Docker refuses an
      # ID delete while several tags point at the image, so release the extra
      # references first (each rm of a non-final tag only untags), then delete
      # by explicit image ID — never --force. A partial outcome is reported as
      # exactly that: which tags came off, and why the image stayed — never a
      # plain "kept" that hides work already done.
      local tag first_tag=true removed_tags="" failed_tag="" rm_err=""
      while IFS= read -r tag; do
        [[ -n "$tag" && "$tag" != "-" ]] || continue
        if [[ "$first_tag" == true ]]; then
          first_tag=false
          continue
        fi
        if docker image rm "$tag" >/dev/null 2>&1; then
          removed_tags="${removed_tags:+$removed_tags, }$tag"
        else
          failed_tag="$tag"
          break
        fi
      done < <(printf '%s\n' "$rtags" | tr ',' '\n' | sed 's/^ *//')
      if [[ -n "$failed_tag" ]]; then
        if [[ -n "$removed_tags" ]]; then
          item "partial" "$rtags (id $id) — partially cleaned: removed tags $removed_tags; image retained because docker refused to untag $failed_tag"
        else
          item "kept" "$rtags (id $id) — docker refused to untag $failed_tag"
        fi
        skipped=$((skipped + 1))
      elif rm_err="$(docker image rm "$id" 2>&1 >/dev/null)"; then
        item "removed" "$rtags (id $id, est. size $size, built label $built)"
        removed_images=$((removed_images + 1))
      else
        rm_err="$(printf '%s' "$rm_err" | head -n 1)"
        [[ -n "$rm_err" ]] || rm_err="docker refused the removal"
        if [[ -n "$removed_tags" ]]; then
          item "partial" "$rtags (id $id) — partially cleaned: removed tags $removed_tags; image retained because $rm_err"
        else
          item "kept" "$rtags (id $id) — $rm_err"
        fi
        skipped=$((skipped + 1))
      fi
    done <<<"$candidates"
  fi

  heading "Result"
  note "removed $removed_containers container(s) and $removed_images image(s); kept or skipped $skipped."
  note "volumes, running containers, unlabeled images, dangling images, and builder cache were not touched. Daemon-wide cleanup is groundwork-docker-cache-tidy — a separate command, run only by you."
}

summary() {
  local scan n_eligible n_unverified exited n_exited=0 cid verdict
  scan="$(gw_docker_scan "$MAX_AGE_HOURS")"
  n_eligible="$(count_status eligible <<<"$scan")"
  n_unverified="$(count_status unverified <<<"$scan")"
  # Containers count only when they are actually removable under the policy:
  # an exited container still inside the grace window is not a leftover.
  if exited="$(list_exited_ephemeral)"; then
    while IFS=$'\t' read -r cid _ _; do
      [[ -n "$cid" ]] || continue
      IFS=$'\t' read -r verdict _ _ _ <<<"$(container_verdict "$cid")"
      [[ "$verdict" == "eligible" ]] && n_exited=$((n_exited + 1))
    done <<<"$exited"
  fi
  if ((n_eligible == 0 && n_unverified == 0 && n_exited == 0)); then
    return 0
  fi
  local line="Docker: $n_eligible tidy-eligible ephemeral build image(s)"
  if ((n_unverified > 0)); then
    line="$line, $n_unverified with unverifiable build metadata (retained)"
  fi
  line="$line, $n_exited tidy-eligible exited ephemeral container(s)."
  echo "$line Review: groundwork-docker-tidy — clean: groundwork-docker-tidy --yes"
}

mode=""
set_mode() {
  if [[ -n "$mode" && "$mode" != "$1" ]]; then
    echo "groundwork-docker-tidy: conflicting modes: --$mode and --$1 are mutually exclusive." >&2
    exit 2
  fi
  mode="$1"
}

while (($#)); do
  case "$1" in
    --dry-run) set_mode "dry-run" ;;
    --yes) set_mode "yes" ;;
    --summary) set_mode "summary" ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "groundwork-docker-tidy: unknown option: $1" >&2
      echo "Run 'groundwork-docker-tidy --help' for usage." >&2
      exit 2
      ;;
  esac
  shift
done
[[ -n "$mode" ]] || mode="dry-run"

if ! command -v docker >/dev/null 2>&1; then
  if [[ "$mode" != summary ]]; then
    echo "groundwork-docker-tidy: docker CLI not installed; nothing to tidy."
  fi
  exit 0
fi
if ! docker info >/dev/null 2>&1; then
  if [[ "$mode" != summary ]]; then
    echo "groundwork-docker-tidy: Docker daemon not reachable. Start Docker Desktop, or run 'colima start' on a work Mac, then rerun."
  fi
  exit 0
fi

case "$mode" in
  dry-run) dry_run ;;
  yes) apply ;;
  summary) summary ;;
esac
