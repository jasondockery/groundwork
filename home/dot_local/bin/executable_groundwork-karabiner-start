#!/usr/bin/env bash
set -euo pipefail

[[ "$(uname -s)" == "Darwin" ]] || exit 0

app="/Applications/Karabiner-Elements.app"
[[ -d "$app" ]] || exit 0

if pgrep -f '/Karabiner-Elements\.app/' >/dev/null 2>&1; then
  exit 0
fi

echo "Karabiner-Elements is installed but not running; opening it so keyboard rules and permission prompts are visible."
open -a "Karabiner-Elements" || true

# Karabiner documents this as the command-line restart path. It is best-effort:
# first-run permissions, driver approval, and Gatekeeper prompts still belong to
# the signed app and must be approved by the person at the keyboard.
launchctl kickstart -k "gui/$(id -u)/org.pqrs.service.agent.karabiner_console_user_server" >/dev/null 2>&1 || true
