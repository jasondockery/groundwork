#!/usr/bin/env bash
set -euo pipefail

# When Homebrew hits a known-broken state (e.g. a circular formula
# dependency), it prints its own remediation block:
#   Please run the following commands and try again:
#     brew update
#     brew uninstall --ignore-dependencies --force libtiff webp
#     brew install libtiff webp
# Given a log containing that block, offer to run exactly those commands —
# nothing invented, shown in full, only with a person at the terminal saying
# yes. Exit 0 only after the remediation ran cleanly, so the caller knows a
# retry is worth it.

log="${1:-}"
[[ -n "$log" && -r "$log" ]] || exit 1

# The bundle log can carry ANSI color codes (update-all forces brew color
# through the tee so the terminal keeps it); strip them before parsing so
# the marker and the command whitelist match the text, not the styling.
esc="$(printf '\033')"
log_text="$(sed "s/${esc}\[[0-9;]*m//g" "$log")"

printf '%s\n' "$log_text" | grep -qF "Please run the following commands and try again:" || exit 1

# Take the suggested commands after the marker, and accept only plain brew
# invocations whose flags and formula names match Homebrew's own naming
# rules. Anything else in the block means we do not understand the
# suggestion, so we stay hands-off.
commands="$(printf '%s\n' "$log_text" | awk '/Please run the following commands and try again:/{found=1; next} found && /^[[:space:]]*brew /{sub(/^[[:space:]]+/, ""); print} found && !/^[[:space:]]*brew /{exit}')"
[[ -n "$commands" ]] || exit 1
while IFS= read -r cmd; do
  [[ "$cmd" =~ ^brew[\ ]([a-z-]+)([\ ]--[a-z-]+)*([\ ][A-Za-z0-9@._+-]+)*$ ]] || exit 1
done <<<"$commands"

echo "Groundwork: Homebrew reported a known-broken state and printed its own fix:"
printf '%s\n' "$commands" | awk '{print "  " $0}'
# Ask on the controlling terminal even when stdin is a pipe; only a run with
# no terminal at all takes the default, and it says which default that is.
# (The seam lets the validator substitute the terminal device.)
prompt_tty="${GROUNDWORK_PROMPT_TTY:-/dev/tty}"
if [[ -t 0 ]]; then
  printf 'Run these now? [y/N] '
  read -r answer || answer=""
elif { exec 3<"$prompt_tty"; } 2>/dev/null; then
  printf 'Run these now? [y/N] '
  read -r -u 3 answer || answer=""
  exec 3<&-
else
  echo "Groundwork: no terminal; defaulting to N (skip)."
  echo "Run these yourself, then re-run chezmoi apply:"
  printf '%s\n' "$commands" | awk '{print "  " $0}'
  exit 1
fi
case "$answer" in
  y|Y|yes|YES)
    while IFS= read -r cmd; do
      echo "Groundwork: running: $cmd"
      if ! $cmd; then
        echo "Groundwork: '$cmd' failed — often a transient network error."
        echo "Nothing is half-applied; re-run chezmoi apply to try the whole sequence again."
        exit 1
      fi
    done <<<"$commands"
    echo "Groundwork: repair finished; retrying."
    ;;
  *)
    echo "Groundwork: skipped. Run the commands above yourself, then re-run chezmoi apply."
    exit 1
    ;;
esac
