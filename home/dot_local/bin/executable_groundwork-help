#!/usr/bin/env bash
set -euo pipefail

catalog="${GROUNDWORK_COMMANDS:-$HOME/.local/share/groundwork/commands.tsv}"

if [[ ! -f "$catalog" ]]; then
  source_path="$(chezmoi source-path 2>/dev/null || true)"
  if [[ -n "$source_path" && -f "$source_path/dot_local/share/groundwork/commands.tsv" ]]; then
    catalog="$source_path/dot_local/share/groundwork/commands.tsv"
  elif [[ -n "$source_path" && -f "$source_path/home/dot_local/share/groundwork/commands.tsv" ]]; then
    catalog="$source_path/home/dot_local/share/groundwork/commands.tsv"
  else
    echo "groundwork-help: command catalog not found" >&2
    echo "expected: $HOME/.local/share/groundwork/commands.tsv" >&2
    exit 1
  fi
fi

pick=false
if [[ "${1:-}" == "--pick" ]]; then
  pick=true
  shift
fi
query="${*:-}"

if [[ "$pick" == true ]]; then
  if ! command -v fzf >/dev/null 2>&1; then
    echo "groundwork-help: --pick needs fzf on PATH" >&2
    exit 1
  fi
  selection="$(
    grep -v '^#' "$catalog" \
      | fzf --delimiter '\t' --with-nth 1,2,4 --query "$query" \
        --prompt 'groundwork> ' --layout reverse --border \
        --preview 'printf "%s\n\n%s" {2} {4}' --preview-window 'down,4,wrap'
  )" || exit 0
  cmd="$(cut -f2 <<<"$selection")"
  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$cmd" | pbcopy
    echo "copied to clipboard: $cmd" >&2
  elif command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$cmd" | wl-copy
    echo "copied to clipboard: $cmd" >&2
  fi
  printf '%s\n' "$cmd"
  exit 0
fi

awk -F '\t' -v query="$query" '
  BEGIN {
    if (query != "") {
      q = tolower(query)
      print "groundwork-help: showing matches for \"" query "\""
      print ""
    } else {
      print "groundwork-help: Groundwork command catalog"
      print "usage: groundwork-help [query]          filter the catalog"
      print "       groundwork-help --pick [query]   fuzzy-pick a command; prints and copies it"
      print ""
    }
  }
  /^#/ || NF < 4 { next }
  {
    haystack = tolower($1 " " $2 " " $3 " " $4)
    if (q != "" && index(haystack, q) == 0) next
    if ($1 != last) {
      if (last != "") print ""
      print "[" $1 "]"
      last = $1
    }
    printf "  %-28s %-8s %s\n", $2, "(" $3 ")", $4
    found = 1
  }
  END {
    if (!found) {
      print "No matches."
      exit 1
    }
  }
' "$catalog"
