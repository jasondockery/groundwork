#!/usr/bin/env bash
set -euo pipefail

# Stable launcher. A running script keeps executing the copy it opened, so this
# file stays a boring two-step trampoline: synchronize Groundwork, then hand
# this same invocation to the freshly applied runner. Update stages live in
# groundwork-update-run so a fix delivered by the sync governs the rest of the
# run; keep substantive logic out of this file.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

# One color decision for the whole refresh, made here while the user's
# terminal is still what stdout points at. Every stage and hook script keys
# on this signal instead of probing its own stdout, so a tee or capture
# INSIDE the pipeline (the brew-bundle log, a summary stage) can no longer
# strip color the terminal supports — while redirecting the WHOLE command
# to a file still disables it. Standard overrides win: NO_COLOR forces off,
# FORCE_COLOR (non-zero) forces on, and a caller-provided GROUNDWORK_COLOR
# is respected as-is.
if [[ -z "${GROUNDWORK_COLOR:-}" ]]; then
  if [[ -n "${NO_COLOR:-}" ]]; then
    GROUNDWORK_COLOR=0
  elif [[ -n "${FORCE_COLOR:-}" && "${FORCE_COLOR}" != "0" ]]; then
    GROUNDWORK_COLOR=1
  elif [[ -t 1 ]]; then
    GROUNDWORK_COLOR=1
  else
    GROUNDWORK_COLOR=0
  fi
fi
export GROUNDWORK_COLOR

command -v chezmoi >/dev/null 2>&1 || {
  echo "Groundwork: chezmoi is not on PATH." >&2
  exit 1
}

# Gate the platform BEFORE syncing: `chezmoi update` runs the install hooks
# (Homebrew bootstrap, brew bundle, every run_ script), so an unsupported
# platform must be refused here, not after the machine has been mutated. The
# runner re-checks, which covers a direct runner invocation.
platform="$("$HOME/.local/bin/groundwork-platform" 2>/dev/null || echo unknown)"
case "$platform" in
  darwin | linux | wsl2) ;;
  wsl1)
    echo "Groundwork requires WSL2; WSL1 is unsupported. From PowerShell: \`wsl --list --verbose\` to check versions, \`wsl --set-version <DistributionName> 2\` to convert." >&2
    exit 1
    ;;
  wsl-unknown)
    echo "Groundwork detected WSL but could not verify WSL2. From PowerShell, run \`wsl --list --verbose\`; convert with \`wsl --set-version <DistributionName> 2\` if needed." >&2
    exit 1
    ;;
  unknown)
    # Do NOT suggest a bare `chezmoi apply` here: that runs the very install
    # hooks this gate exists to withhold until the platform is known. Restore
    # just the detector.
    echo "Groundwork: the platform helper is missing or failed: $HOME/.local/bin/groundwork-platform" >&2
    echo "Restore it from the source you already have (this cannot fetch an upstream fix):" >&2
    echo "  chezmoi apply --exclude=scripts ~/.local/bin/groundwork-platform" >&2
    exit 1
    ;;
  *)
    echo "Groundwork does not support this platform: $platform" >&2
    exit 1
    ;;
esac

# Preflight the SOURCE branch before `chezmoi update` runs git pull: a local
# development branch with no upstream (or a detached HEAD) gets Groundwork's
# two-lane guidance instead of a raw git error. The branch-state model lives in
# the stable helper (installed like groundwork-platform); the launcher stays a
# trampoline. Skip only when the helper is not yet present (a first install,
# where the source is a fresh tracked clone anyway). The helper never mutates.
gw_preflight="$HOME/.local/bin/groundwork-source-preflight"
if [[ -x "$gw_preflight" ]]; then
  "$gw_preflight" || exit $?
fi

# Snapshot the managed config so the discoverability nudge fires only when
# regeneration actually changed it. Groundwork always uses chezmoi's default
# config path.
gw_config="${XDG_CONFIG_HOME:-$HOME/.config}/chezmoi/chezmoi.toml"
gw_config_before=""
[[ -f "$gw_config" ]] && gw_config_before="$(cksum < "$gw_config" 2>/dev/null || true)"

# --init regenerates the config when .chezmoi.toml.tmpl changed; all prompts
# are *Once, so existing answers are reused without asking again. Pull WITHOUT
# applying: the drift preflight below inspects status first, and the full apply
# runs inside the freshly installed runner so long installs happen in a phase
# the new implementation owns.
chezmoi update --init --apply=false

gw_config_after=""
[[ -f "$gw_config" ]] && gw_config_after="$(cksum < "$gw_config" 2>/dev/null || true)"
gw_regenerated=0
[[ "$gw_config_before" != "$gw_config_after" ]] && gw_regenerated=1

# The preflight must succeed before anything is applied: a status failure
# means chezmoi cannot render this source against this machine, and applying
# anyway would run install hooks against a state nobody inspected.
if ! status_output="$(chezmoi status)"; then
  echo "Groundwork: could not inspect managed-file drift (chezmoi status failed above); nothing was applied." >&2
  exit 1
fi

# A file is MM when it changed on disk since chezmoi last wrote it AND this
# update also changes it — exactly the files the apply will stop and ask
# about. Name them and explain the choices before any question appears.
drift="$(printf '%s\n' "$status_output" | sed -n 's/^MM //p')"
if [[ -n "$drift" ]]; then
  echo "Groundwork: these managed files changed on this machine since Groundwork last wrote them,"
  echo "and this update also changes them, so chezmoi will ask about each one:"
  while IFS= read -r drift_path; do
    printf '  ~/%s\n' "$drift_path"
  done <<<"$drift"
  echo "Answer y to take Groundwork's version, n to keep your local change this time,"
  echo "or d to see the diff first. Nothing is overwritten without your answer."
  # The overwrite question needs a person. With no usable terminal (an agent,
  # cron, redirected stdin with no controlling tty), stop BEFORE the apply
  # instead of leaving chezmoi to hang or fail mid-run. Exit 2 = review
  # required. (GROUNDWORK_PROMPT_TTY is the same test seam the other
  # Groundwork prompts use.)
  prompt_tty="${GROUNDWORK_PROMPT_TTY:-/dev/tty}"
  if [[ ! -t 0 ]] && ! { : <"$prompt_tty"; } 2>/dev/null; then
    echo "Groundwork: no interactive terminal to answer on — stopping before the apply." >&2
    echo "Nothing was overwritten. Review each file with 'chezmoi diff <file>', resolve it," >&2
    echo "then run update-all again from a terminal." >&2
    exit 2
  fi
fi

runner="$HOME/.local/bin/groundwork-update-run"

# Install ONLY the fresh runner (a targeted apply runs no hook scripts), then
# prove it matches the synchronized source — a runner kept as a local edit
# must never run wearing the "freshly applied" label. The full apply,
# configuration files and install hooks alike, happens inside the runner.
chezmoi apply "$runner"
if ! chezmoi verify "$runner"; then
  echo "Groundwork: $runner does not match the synchronized source (a kept local edit?)." >&2
  echo "Refusing to run a stale updater. Review it with: chezmoi diff ~/.local/bin/groundwork-update-run" >&2
  exit 1
fi
if [[ ! -x "$runner" ]]; then
  echo "Groundwork: chezmoi finished, but the update runner is missing or not executable: $runner" >&2
  exit 1
fi

# Discoverability nudge: emitted only after the launcher transaction succeeded
# (source synced, config regenerated, runner verified) and only when the config
# actually changed. A checksum change means the TEMPLATE regenerated the config;
# it is not a claim about which stored answers changed. Never a prompt — an
# update finishes the update.
if [[ "$gw_regenerated" == 1 ]]; then
  echo
  echo "Groundwork configuration was regenerated from the current template."
  echo "To review or change a setting: groundwork-configure"
fi

exec "$runner" "$@"
