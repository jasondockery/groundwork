#!/usr/bin/env bash
set -euo pipefail

# Stable launcher. A running script keeps executing the copy it opened, so this
# file stays a boring two-step trampoline: synchronize Groundwork, then hand
# this same invocation to the freshly applied runner. Update stages live in
# groundwork-update-run so a fix delivered by the sync governs the rest of the
# run; keep substantive logic out of this file.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

command -v chezmoi >/dev/null 2>&1 || {
  echo "Groundwork: chezmoi is not on PATH." >&2
  exit 1
}

# --init regenerates the config when .chezmoi.toml.tmpl changed; all prompts
# are *Once, so existing answers are reused without asking again.
chezmoi update --init

runner="$HOME/.local/bin/groundwork-update-run"
if [[ ! -x "$runner" ]]; then
  echo "Groundwork: chezmoi finished, but the update runner is missing or not executable: $runner" >&2
  exit 1
fi

exec "$runner" "$@"
