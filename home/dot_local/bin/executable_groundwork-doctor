#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Read-only machine health report for a Groundwork setup.

Usage:
  groundwork-doctor [options]

Options:
  --shell       run only the shell runtime section
  --runtimes    run only the runtime release-age section
  --docker      run only the Docker section
  -h, --help    show this help

Sections (all run by default):
  Shell runtime whether Groundwork's managed zsh is installed and owned by
                Homebrew, registered in /etc/shells, selected as your account's
                login shell, and actually running in this terminal — plus that
                the shell you had before adopting still exists, so --revert has
                somewhere to go.
  Runtime age   whether any mise-managed runtime was adopted inside the release
                floor update-all enforces. A cooldown filters what you acquire;
                it never rolls back what is already installed, so a version taken
                before the floor existed stays until something says so.
  Docker        daemon reachability, engine hygiene (log rotation, image
                store), disk usage, and leftovers: containers, dangling
                images, volumes, and the labeled-ephemeral scratch images —
                judged by the same shared scanner groundwork-docker-tidy
                acts on, with tidy-eligible, in-grace, protected, and
                unverified counts reported separately (a fresh in-grace
                image is not a leftover). Each finding is paired with the
                owner-scoped cleanup command, never a blanket prune.

The doctor only reports. It never installs, deletes, prunes, or changes
settings; every fix stays your decision.

More help:
  groundwork-help doctor
  https://jasondockery.github.io/groundwork/platforms.html
EOF
}

heading() { printf '\n== %s ==\n' "$1"; }
ok()      { printf '  ok    %s\n' "$1"; }
warn()    { printf '  warn  %s\n' "$1"; }
note()    { printf '  note  %s\n' "$1"; }

docker_section() {
  heading "Docker"

  if ! command -v docker >/dev/null 2>&1; then
    note "docker CLI not installed; skipping. Personal Mac: Docker Desktop. Work Mac: Colima + Docker CLI (both ship with Groundwork)."
    return 0
  fi
  if ! docker info >/dev/null 2>&1; then
    note "Docker daemon not reachable; skipping Docker checks. Start Docker Desktop, or run 'colima start' on a work Mac, then rerun groundwork-doctor."
    return 0
  fi
  ok "Docker daemon is reachable"

  local driver log_driver settings_hint=false
  log_driver="$(docker info --format '{{.LoggingDriver}}' 2>/dev/null || echo unknown)"
  if [[ "$log_driver" == "local" ]]; then
    ok "container logs rotate automatically (log-driver: local)"
  else
    warn "log-driver is '$log_driver'; the default json-file never rotates, so a chatty container grows its log forever. Set \"log-driver\": \"local\" in the engine settings."
    settings_hint=true
  fi

  driver="$(docker info --format '{{.Driver}}' 2>/dev/null || echo unknown)"
  if [[ "$driver" == "overlayfs" ]]; then
    ok "containerd image store is enabled (multi-platform builds work locally)"
  else
    note "storage driver is '$driver'; the containerd image store (shows as 'overlayfs') is what multi-platform builds expect. Older installs may still have it off."
    settings_hint=true
  fi

  printf '\n  Disk usage (docker system df):\n'
  docker system df 2>/dev/null | sed 's/^/    /' || note "could not read docker system df"

  # Leftover facts come from the same shared scanner groundwork-docker-tidy
  # acts on (lib/docker-scan.sh), so the doctor's counts and the tidy's
  # decisions can never disagree. A count of "unknown" means the query
  # failed — a different fact from zero, and reported as such.
  local docker_lib="${GROUNDWORK_DOCKER_LIB:-$HOME/.local/share/groundwork/lib/docker-scan.sh}"
  if [[ ! -r "$docker_lib" ]]; then
    warn "Groundwork's docker-scan probe is missing: $docker_lib — leftover counts skipped."
    note "Restore it (this runs no install hooks): chezmoi apply --exclude=scripts ~/.local/share/groundwork"
  else
    # shellcheck source=/dev/null
    . "$docker_lib"

    local max_age
    if ! max_age="$(gw_docker_max_age_hours)"; then
      warn "invalid GROUNDWORK_DOCKER_TIDY_MAX_AGE_HOURS='${GROUNDWORK_DOCKER_TIDY_MAX_AGE_HOURS:-}' — reporting with the ${max_age}h default (groundwork-docker-tidy refuses to act until it is fixed)."
    fi

    local stopped dangling_images dangling_volumes
    stopped="$(gw_docker_count ps -aq --filter status=exited)"
    dangling_images="$(gw_docker_count images -q --filter dangling=true)"
    dangling_volumes="$(gw_docker_count volume ls -q --filter dangling=true)"

    local scan n_eligible n_retained n_protected n_unverified
    scan="$(gw_docker_scan "$max_age")"
    n_eligible="$(printf '%s\n' "$scan" | awk -F'\t' '$2 == "eligible" { n++ } END { print n + 0 }')"
    n_retained="$(printf '%s\n' "$scan" | awk -F'\t' '$2 == "retained" { n++ } END { print n + 0 }')"
    n_protected="$(printf '%s\n' "$scan" | awk -F'\t' '$2 == "protected" { n++ } END { print n + 0 }')"
    n_unverified="$(printf '%s\n' "$scan" | awk -F'\t' '$2 == "unverified" { n++ } END { print n + 0 }')"

    printf '\n  Leftovers (unknown = the query failed, not zero):\n'
    printf '    stopped containers: %s\n' "$stopped"
    printf '    dangling images:    %s\n' "$dangling_images"
    printf '    dangling volumes:   %s\n' "$dangling_volumes"
    printf '    ephemeral scratch images (label dev.roost.ephemeral=true, %sh grace):\n' "$max_age"
    printf '      tidy-eligible (past grace):     %s\n' "$n_eligible"
    printf '      in grace (fresh, not leftover): %s\n' "$n_retained"
    printf '      protected (tag/container ref):  %s\n' "$n_protected"
    printf '      unverified (retained):          %s\n' "$n_unverified"

    # A fresh in-grace image is NOT a leftover — it never triggers guidance.
    if [[ "$stopped" != 0 || "$dangling_images" != 0 || "$dangling_volumes" != 0 ]] \
      || ((n_eligible + n_protected + n_unverified > 0)); then
      cat <<'EOF'

  Cleanup guidance (review first; the doctor never deletes):
    Prefer the owning repo's clean commands — well-run projects ship
    repo-scoped cleanup that targets only their own labeled resources.
    To inspect what's behind the counts:
      docker ps -a --filter status=exited
      docker images --filter dangling=true
      docker volume ls --filter dangling=true
    Ephemeral scratch images opted in to cleanup with their label:
    groundwork-docker-tidy previews the tidy (dry run by default), and
    groundwork-docker-tidy --yes removes only the tidy-eligible ones —
    enumerated, re-checked, deleted by image ID; never volumes, never
    unlabeled images, never dangling images or builder cache.
    Stopped containers, dangling images, and builder cache are DAEMON-WIDE
    (every project on this machine): that cleanup is the separate, owner-run
    groundwork-docker-cache-tidy.
    A dangling volume can still be the only copy of a database. Check the
    volume name and owner before removing anything, and avoid blanket
    'docker system prune' — it reaches into every project's state at once.
EOF
    fi
  fi

  if [[ "$settings_hint" == true ]]; then
    note "engine settings live in Docker Desktop -> Settings -> Docker Engine (work Macs: the managed Colima template already sets them). See the Platforms page for the exact JSON."
  fi
}


# The release floor Groundwork enforces in update-all. Keep this in step with
# groundwork-update-run; the validator asserts they agree.
GROUNDWORK_RELEASE_FLOOR="${GROUNDWORK_RELEASE_FLOOR:-5d}"

runtimes_section() {
  heading "Runtime release age"

  if ! command -v mise >/dev/null 2>&1; then
    note "mise is not installed; skipping runtime checks."
    return 0
  fi
  if ! command -v jq >/dev/null 2>&1; then
    note "jq is not installed; skipping runtime release-age checks."
    return 0
  fi
  if ! mise upgrade --help 2>/dev/null | grep -q -- '--minimum-release-age'; then
    warn "this mise cannot enforce a release floor (--minimum-release-age is missing) — update-all skips runtime upgrades entirely until it can. Upgrade mise: brew upgrade mise"
    return 0
  fi

  # A cooldown only filters what you ACQUIRE. It never retires a version already
  # on disk, so a runtime taken before the floor existed — or during a window
  # when it was not enforced — stays put and silently violates the policy.
  # Nothing else surfaces that, which is why this section exists.
  #
  # The release date is read from the tool's own backend, NOT from mise's
  # upgrade warning: that warning only appears when mise's remote-version cache
  # happens to be cold, so a check built on it would pass or fail by luck.
  local floor_days
  floor_days="${GROUNDWORK_RELEASE_FLOOR%d}"
  [[ "$floor_days" =~ ^[0-9]+$ ]] || floor_days=5

  local tools_json
  tools_json="$(mise ls --current --json 2>/dev/null || true)"
  if [[ -z "$tools_json" ]]; then
    note "mise reported no active tools."
    return 0
  fi

  local flagged=0 checked=0
  local tool version released age_days
  while IFS=$'\t' read -r tool version; do
    [[ -n "$tool" && -n "$version" ]] || continue
    released=""
    case "$tool" in
      node)
        released="$(curl -fsS --max-time 10 https://nodejs.org/dist/index.json 2>/dev/null \
          | jq -r --arg v "v$version" '.[] | select(.version == $v) | .date' 2>/dev/null | head -n 1)"
        ;;
      pnpm | npm:*)
        local pkg="${tool#npm:}"
        released="$(curl -fsS --max-time 10 "https://registry.npmjs.org/$pkg" 2>/dev/null \
          | jq -r --arg v "$version" '.time[$v] // empty' 2>/dev/null | head -n 1)"
        ;;
    esac

    if [[ -z "$released" ]]; then
      # Say so plainly rather than implying a clean bill of health.
      note "$tool $version: release date unavailable (no date source for this backend, or offline) — age not verified."
      continue
    fi

    # Both real formats must parse: nodejs.org gives a bare date, npm gives an
    # ISO timestamp with fractional seconds. fromdateiso8601 accepts neither
    # as-is.
    age_days="$(jq -rn --arg d "$released" '
      ($d
        | if test("T") then . else . + "T00:00:00Z" end
        | sub("\\.[0-9]+"; "")
        | if test("Z$") then . else . + "Z" end
        | fromdateiso8601) as $t
      | ((now - $t) / 86400 | floor)' 2>/dev/null || true)"
    if ! [[ "$age_days" =~ ^-?[0-9]+$ ]]; then
      note "$tool $version: could not parse its release date ($released) — age not verified."
      continue
    fi
    checked=$((checked + 1))

    if ((age_days < floor_days)); then
      warn "$tool $version is only ${age_days}d old — younger than the ${floor_days}d release floor update-all enforces."
      note "  It was adopted before the floor applied. A cooldown filters what you acquire; it never rolls back what you already have."
      note "  Pin a vetted version now:   mise use -g $tool@<older-version>   (mise ls-remote $tool lists them)"
      note "  Or wait it out: in $((floor_days - age_days))d this version clears the floor and update-all keeps it."
      flagged=$((flagged + 1))
    else
      ok "$tool $version is ${age_days}d old — past the ${floor_days}d floor"
    fi
  done < <(printf '%s' "$tools_json" \
    | jq -r 'to_entries[] | .key as $t | .value[] | select(.active) | "\($t)\t\(.version)"' 2>/dev/null || true)

  if ((checked == 0 && flagged == 0)); then
    note "no runtime release dates could be verified (offline, or no date source for these backends)."
  fi
}

shell_section() {
  heading "Shell runtime"

  # The shared probe is sourced HERE, not at file scope: a diagnostic must not
  # lose its unrelated Docker checks because one component is missing. See
  # lib/shell-runtime.sh — it never executes the candidate zsh, because ownership
  # is proven from Homebrew metadata and the filesystem first.
  local lib="${GROUNDWORK_SHELL_LIB:-$HOME/.local/share/groundwork/lib/shell-runtime.sh}"
  if [[ ! -r "$lib" ]]; then
    warn "Groundwork's shell-runtime probe is missing: $lib"
    note "Restore it (this runs no install hooks): chezmoi apply --exclude=scripts ~/.local/share/groundwork"
    return 0
  fi
  # shellcheck source=/dev/null
  . "$lib"

  # A diagnostic must survive a damaged machine: nothing below returns early, so
  # a broken Homebrew is reported rather than suppressing unrelated facts.
  gw_shell_probe

  case "$GW_LOGIN_STATE" in
    ok) note "login shell (account): $GW_LOGIN_SHELL" ;;
    *) warn "login shell (account): UNREADABLE — restore the account lookup (directory service / getent / /etc/passwd); Groundwork will not change a shell it cannot verify." ;;
  esac
  note "\$SHELL (session value): ${GW_SESSION_SHELL:-unset}"
  case "$GW_PARENT_STATE" in
    path) note "invoking process: $GW_PARENT_EXE" ;;
    name-only) note "invoking process: $GW_PARENT_EXE (executable path could not be verified)" ;;
    *) note "invoking process: unknown" ;;
  esac

  # --- Homebrew and OWNERSHIP: no green "managed" claim before it is proven ---
  case "$GW_BREW_STATE" in
    missing)
      warn "Homebrew is not on PATH, so Groundwork's managed zsh cannot be checked or upgraded."
      note "Recovery does not need Homebrew: groundwork-shell-adopt --revert"
      ;;
    broken)
      warn "'brew --prefix' failed or returned nothing — the Homebrew installation looks damaged. Try 'brew doctor'."
      note "Recovery does not need Homebrew: groundwork-shell-adopt --revert"
      ;;
  esac
  case "$GW_OWNERSHIP" in
    owned)
      ok "managed zsh: Homebrew owns it — $GW_MANAGED_ZSH ($(gw_managed_zsh_version)) -> $GW_RESOLVED_ZSH"
      ;;
    unowned)
      # Neutral language, and NOT executed: path equality is not ownership, and
      # this is exactly the binary a diagnostic must not run to identify.
      warn "zsh candidate at $GW_MANAGED_ZSH does NOT resolve into Homebrew's zsh formula (resolves to ${GW_RESOLVED_ZSH:-unknown}) — ownership is not established. Reinstall with 'brew reinstall zsh'."
      ;;
    absent)
      warn "managed zsh absent: $GW_MANAGED_ZSH — run 'chezmoi apply' (installs the Brewfile) or 'brew install zsh'."
      ;;
  esac

  # --- registration ---
  if [[ "$GW_OWNERSHIP" != "unknown" ]]; then
    case "$GW_SHELLS_STATE" in
      registered) note "registered in $GW_SHELLS_FILE" ;;
      not-registered) warn "not in $GW_SHELLS_FILE — chsh will refuse it. Run 'groundwork-shell-adopt'." ;;
      *) warn "$GW_SHELLS_FILE is unreadable, so registration is UNKNOWN (not the same as unregistered)." ;;
    esac
  fi

  # --- login shell, gated on ownership: pointing at the expected path is not
  # the same as that path being a verified Homebrew zsh. ---
  if [[ -n "$GW_MANAGED_ZSH" && "$GW_LOGIN_SHELL" == "$GW_MANAGED_ZSH" ]]; then
    if [[ "$GW_OWNERSHIP" == "owned" ]]; then
      ok "login shell is the managed zsh"
    else
      warn "login shell points at $GW_MANAGED_ZSH, but that path is not currently a verified Homebrew zsh — your login shell is an unverified binary."
    fi
  elif [[ -n "$GW_LOGIN_SHELL" && ! -x "$GW_LOGIN_SHELL" ]]; then
    warn "login shell points at a missing binary: $GW_LOGIN_SHELL — run 'groundwork-shell-adopt', or 'groundwork-shell-adopt --revert' to restore your previous shell."
  elif [[ "$GW_LOGIN_STATE" == "ok" && "$GW_OWNERSHIP" != "unknown" ]]; then
    warn "login shell is $GW_LOGIN_SHELL, not the managed zsh — run 'groundwork-shell-adopt' to adopt it."
  fi

  # --- is THIS terminal running it? (a login-shell change only affects new
  # terminals — the thing everyone trips over). Also gated on ownership. ---
  if [[ "$GW_OWNERSHIP" == "owned" && "$GW_LOGIN_SHELL" == "$GW_MANAGED_ZSH" && -n "$GW_PARENT_EXE" ]]; then
    local parent_canonical
    parent_canonical="$(gw_canonical_path "$GW_PARENT_EXE" 2>/dev/null || printf '%s' "$GW_PARENT_EXE")"
    if [[ "$GW_PARENT_EXE" == "$GW_MANAGED_ZSH" || "$parent_canonical" == "$GW_RESOLVED_ZSH" ]]; then
      ok "this terminal is running the managed zsh"
    elif [[ "$GW_PARENT_STATE" == "path" ]]; then
      note "this terminal is running $GW_PARENT_EXE, not the managed zsh; new terminals use it (or run: exec \"$GW_MANAGED_ZSH\" -l)."
    else
      note "this terminal reports '$GW_PARENT_EXE', but its executable path could not be verified; new terminals use the managed zsh."
    fi
  fi

  # --- recovery path: what --revert would restore ---
  case "$GW_PREV_STATE" in
    recorded) ok "recovery shell intact: $GW_PREV_SHELL" ;;
    missing-binary) warn "the recorded previous shell is missing: $GW_PREV_SHELL — pick one explicitly with 'groundwork-shell-adopt --revert-to <shell>'." ;;
    *)
      if [[ -n "$GW_MANAGED_ZSH" && "$GW_LOGIN_SHELL" == "$GW_MANAGED_ZSH" ]]; then
        warn "no previous login shell recorded, so --revert has nothing to restore; use 'groundwork-shell-adopt --revert-to <shell>'."
      fi
      ;;
  esac

  # --- config and plugin manager: knowable with or without Homebrew ---
  if [[ -r "$HOME/.zshrc" ]]; then
    ok "Groundwork zsh config present: $HOME/.zshrc"
  else
    warn "$HOME/.zshrc is missing — run 'chezmoi apply'."
  fi
  # antidote is sourced, not a PATH binary. Include the Linuxbrew prefix and the
  # non-Homebrew fallback so a broken brew does not hide a working plugin layer.
  local antidote_found="" candidate
  for candidate in "${GW_BREW_PREFIX:+$GW_BREW_PREFIX/share/antidote/antidote.zsh}" \
    /opt/homebrew/share/antidote/antidote.zsh \
    /usr/local/share/antidote/antidote.zsh \
    /home/linuxbrew/.linuxbrew/share/antidote/antidote.zsh \
    "$HOME/.local/share/antidote/antidote.zsh"; do
    [[ -n "$candidate" && -f "$candidate" ]] || continue
    antidote_found="$candidate"
    break
  done
  if [[ -n "$antidote_found" ]]; then
    ok "plugin manager available: antidote ($antidote_found)"
  else
    warn "antidote (plugin manager) not found — run 'chezmoi apply' to install the Brewfile."
  fi
}

section=""

while (($#)); do
  case "$1" in
    --docker) section="docker" ;;
    --shell) section="shell" ;;
    --runtimes) section="runtimes" ;;
    -h|--help) usage; exit 0 ;;
    *)
      echo "groundwork-doctor: unknown option: $1" >&2
      echo "Run 'groundwork-doctor --help' for usage." >&2
      exit 2
      ;;
  esac
  shift
done

echo "groundwork-doctor: read-only report; nothing is changed or deleted."

case "$section" in
  "")
    shell_section
    runtimes_section
    docker_section
    ;;
  shell) shell_section ;;
  runtimes) runtimes_section ;;
  docker) docker_section ;;
esac
