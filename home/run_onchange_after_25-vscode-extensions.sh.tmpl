#!/usr/bin/env bash
set -euo pipefail
{{ if and (eq .chezmoi.os "darwin") (not .headless) -}}
{{- $extList := joinPath .chezmoi.sourceDir "vscode-extensions.txt.tmpl" }}
{{- if stat $extList }}
# extensions hash: {{ include "vscode-extensions.txt.tmpl" | sha256sum }}
{{- end }}

list="$HOME/vscode-extensions.txt"
[[ -f "$list" ]] || exit 0

export NODE_NO_WARNINGS=1

install_into() {
  local cmd="$1"
  local target="$2"
  local ext
  command -v "$cmd" >/dev/null || return 0
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    case "$line" in
      code:*)
        [[ "$target" == "code" ]] || continue
        ext="${line#code:}"
        ;;
      cursor:*)
        [[ "$target" == "cursor" ]] || continue
        ext="${line#cursor:}"
        ;;
      *)
        ext="$line"
        ;;
    esac
    "$cmd" --install-extension "$ext" --force \
      || echo "  skip: $ext unavailable in $cmd's registry" >&2
  done < "$list"
}

install_into code code
install_into cursor cursor
{{- end }}
